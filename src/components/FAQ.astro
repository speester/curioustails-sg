---
import { whatsappLink } from '../data/site';
import PawPrint from './decor/PawPrint.astro';
import Bone from './decor/Bone.astro';
import Sparkle from './decor/Sparkle.astro';
import Blob from './decor/Blob.astro';

interface Item {
  question: string;
  answer: string;
}
interface Props {
  heading?: string;
  items: Item[];
}
const { heading = 'Frequently Asked Questions', items } = Astro.props;
---

<section class="mx-auto max-w-[1400px] px-5 sm:px-8 py-16">
  <h2 class="font-semibold text-[var(--color-cream-900)]" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">{heading}</h2>

  <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_320px]">
    <div class="space-y-4">
      {items.map((item, i) => (
        <details class="group clay bg-[var(--color-surface-card)] px-5 py-1 open:pb-4" data-reveal style={`--i:${i % 6}`}>
          <summary class="flex cursor-pointer list-none items-start gap-4 py-4 text-base font-bold text-[var(--color-cream-800)] marker:content-none">
            <span class="font-[family-name:var(--font-heading)] text-[var(--color-coral-500)] shrink-0" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="flex-1">{item.question}</span>
            <svg
              width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              class="shrink-0 mt-0.5 text-[var(--color-coral-600)] transition-transform group-open:rotate-45"
              aria-hidden="true"
            >
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </summary>
          <p class="pl-9 text-base leading-relaxed text-[var(--color-cream-600)]">{item.answer}</p>
        </details>
      ))}
    </div>

    <aside class="relative hidden lg:block" data-reveal>
      <div class="clay sticky top-32 overflow-hidden bg-[var(--color-lilac-900)] p-7 text-center">
        <Blob class="pointer-events-none absolute -top-10 -right-10 h-40 w-40 fill-white/5 blob-drift-slow" aria-hidden="true" />
        <Blob class="pointer-events-none absolute -bottom-12 -left-8 h-36 w-36 fill-[var(--color-coral-500)]/15 blob-drift" aria-hidden="true" />

        <span class="wiggle-hover relative mx-auto flex h-16 w-16 items-center justify-center rounded-full border-3 border-[var(--color-coral-400)] bg-white/10 text-[var(--color-coral-400)]">
          <PawPrint class="h-8 w-8" />
        </span>
        <Sparkle class="absolute right-10 top-8 h-4 w-4 text-[var(--color-coral-300)] blob-drift" />
        <Bone class="absolute left-8 bottom-16 h-6 w-6 text-white/20 rotate-12 blob-drift-slow" />

        <p class="relative mt-5 font-[family-name:var(--font-heading)] text-xl font-semibold text-white">
          Still have questions?
        </p>
        <p class="relative mt-2 text-sm leading-relaxed text-white/75">
          Nelson and Kim answer every message personally, usually within the hour.
        </p>
        <a
          href={whatsappLink("Hi! I have a question that's not covered in the FAQ.")}
          class="clay-btn relative mt-6 inline-flex w-full items-center justify-center gap-2 bg-[var(--color-accent)] px-5 py-3 text-sm font-bold text-white hover:bg-[var(--color-accent-hover)]"
        >
          WhatsApp us directly
        </a>
      </div>
    </aside>
  </div>
</section>
