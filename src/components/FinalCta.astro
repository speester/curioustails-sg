---
// Final call-to-action block for a breed/money page: a prominent 2/3 "visit or
// message us" card paired with a 1/3 "still deciding?" secondary card, then a
// full-width "browse all" navigation card. Shared across all breed pages so the
// closing CTA is consistent and only styled once.
import { site, whatsappLink } from '../data/site';
import PawPrint from './decor/PawPrint.astro';

interface Props {
  breed: string; // e.g. "Cavapoo"
  heading?: string; // override for non-breed pages (default: "Meet Our {breed}s at Balestier")
  body?: string; // override for the small copy under the address
  reserveMessage?: string; // WhatsApp prefill for the primary CTA
  quizHref?: string; // secondary CTA target
  browseHref?: string; // full-width "browse all" card target
  browseLabel?: string;
}
const {
  breed,
  heading = `Meet Our ${breed}s at Balestier`,
  body = `Can't make the trip? WhatsApp us for current ${breed} photos and prices, with free home delivery across Singapore.`,
  reserveMessage = `Hi! I'd like to reserve a ${breed} puppy.`,
  quizHref = '/first-time-owners/breed-selector/',
  browseHref = '/puppies/',
  browseLabel = 'Browse all our puppy breeds',
} = Astro.props;
---

<section class="mx-auto max-w-[1400px] px-5 sm:px-8 py-12">
  <div class="grid gap-5 lg:grid-cols-3">
    <!-- 2/3: primary visit / WhatsApp card -->
    <div class="clay relative overflow-hidden lg:col-span-2 bg-[var(--color-lilac-900)] border-[var(--color-coral-500)] p-8 sm:p-10 flex flex-col justify-between gap-7">
      <PawPrint class="pointer-events-none absolute -right-8 -bottom-10 h-44 w-44 rotate-12 text-white/5" aria-hidden="true" />
      <PawPrint class="pointer-events-none absolute right-24 top-6 h-14 w-14 -rotate-12 text-white/[0.04]" aria-hidden="true" />
      <div class="relative">
        <p class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-bold uppercase text-[var(--color-mint-300)]" style="letter-spacing: 0.08em;">
          <PawPrint class="h-3.5 w-3.5" />
          Visit or message us
        </p>
        <h2 class="mt-4 font-[family-name:var(--font-heading)] font-semibold text-white" style="font-size: clamp(1.9rem, 3.2vw, 2.75rem);">
          {heading}
        </h2>
        <p class="mt-3 max-w-[46ch] text-base leading-relaxed text-white/75">
          {site.address.full}
        </p>
        <p class="mt-1 text-sm text-white/60">{site.hours}</p>
        <p class="mt-4 max-w-[48ch] text-sm leading-relaxed text-white/70">
          {body}
        </p>
      </div>
      <div class="relative flex flex-wrap items-center gap-3">
        <a
          href={whatsappLink(reserveMessage)}
          class="clay-btn inline-flex items-center gap-2 bg-[var(--color-accent)] px-7 py-3.5 text-base font-bold text-white hover:bg-[var(--color-accent-hover)]"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.8 14.13c-.25.7-1.44 1.33-1.99 1.37-.53.05-.53.42-3.34-.7-2.81-1.12-4.55-3.98-4.69-4.16-.14-.19-1.12-1.49-1.12-2.84 0-1.35.71-2.01.96-2.29.25-.28.55-.35.73-.35.18 0 .37 0 .53.01.17.01.4-.06.62.48.25.6.85 2.06.92 2.21.07.14.12.31.02.5-.09.19-.14.31-.28.47-.14.16-.29.36-.42.48-.14.14-.28.28-.12.56.16.28.71 1.17 1.53 1.9 1.05.94 1.94 1.23 2.22 1.37.28.14.44.12.6-.07.16-.19.69-.81.88-1.09.19-.28.37-.23.62-.14.25.09 1.6.76 1.87.9.28.14.46.21.53.32.07.12.07.65-.18 1.35z" />
          </svg>
          WhatsApp {site.phoneDisplay}
        </a>
        <a
          href={site.gbpUrl}
          target="_blank"
          rel="noopener"
          class="clay-btn-outline inline-flex items-center gap-1.5 bg-white/5 px-6 py-3.5 text-base font-bold text-white hover:text-[var(--color-mint-300)]"
        >
          Get directions
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
    </div>

    <!-- 1/3 column: secondary "still deciding" card + browse-all card stacked -->
    <div class="flex flex-col gap-5">
    <div class="clay relative overflow-hidden bg-[var(--color-peach-100)] p-8 flex flex-1 flex-col justify-between gap-6">
      <PawPrint class="pointer-events-none absolute -right-6 -bottom-8 h-32 w-32 rotate-12 text-[var(--color-coral-300)]/25" aria-hidden="true" />
      <div class="relative">
        <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white text-[var(--color-coral-500)] shadow-[0_4px_0_0_var(--color-coral-300)]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.8.4-1 .9-1 1.7M12 17h.01" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="12" cy="12" r="9.5" />
          </svg>
        </span>
        <h3 class="mt-4 font-[family-name:var(--font-heading)] text-2xl font-semibold text-[var(--color-cream-900)]">
          Still weighing your options?
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-cream-700)]">
          Take the two-minute breed selector, matched to your actual routine and home.
        </p>
      </div>
      <a
        href={quizHref}
        class="clay-btn relative inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] px-6 py-3 text-sm font-bold text-white hover:bg-[var(--color-accent-hover)]"
      >
        Take the quiz
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>

    <!-- browse-all navigation card, stacked under the secondary card -->
    <a
      href={browseHref}
      data-tilt
      class="clay clay-hover clay-press group flex items-center justify-between gap-4 bg-[var(--color-surface-card)] px-6 py-5"
    >
      <span class="flex items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[var(--color-peach-100)] text-[var(--color-coral-500)]">
          <PawPrint class="h-5 w-5" />
        </span>
        <span class="text-base font-semibold text-[var(--color-cream-900)] group-hover:text-[var(--color-coral-600)]">
          {browseLabel}
        </span>
      </span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="shrink-0 text-[var(--color-cream-400)] transition-transform group-hover:translate-x-1 group-hover:text-[var(--color-coral-500)]" aria-hidden="true">
        <path d="m9 6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
    </div>
  </div>
</section>
