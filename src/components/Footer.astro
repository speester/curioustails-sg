---
import { site } from '../data/site';
import PawPrint from './decor/PawPrint.astro';
import Blob from './decor/Blob.astro';
// Lean chrome: NAP + hours + legal only. Architecture links live in body
// content and per-page <aside> blocks, not the footer.
---

<footer class="relative overflow-hidden bg-[var(--color-lilac-900)] text-[var(--color-cream-100)] mt-24 rounded-t-[2.5rem]">
  <Blob class="pointer-events-none absolute -top-10 -left-16 h-64 w-64 fill-[var(--color-lilac-700)]/60 blob-drift-slow" aria-hidden="true" />
  <Blob class="pointer-events-none absolute bottom-0 right-[8%] h-52 w-52 fill-[var(--color-coral-600)]/15 blob-drift" aria-hidden="true" />

  <div class="relative mx-auto max-w-[1400px] px-5 sm:px-8 py-14 flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <div class="flex items-center gap-2.5">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border-3 border-[var(--color-coral-400)] bg-[var(--color-lilac-700)] text-[var(--color-coral-400)]">
          <PawPrint class="h-5 w-5" />
        </span>
        <p class="font-[family-name:var(--font-heading)] text-lg font-semibold text-white">{site.businessName}</p>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-[var(--color-lilac-100)]/85 max-w-[36ch]">
        AVS licensed, {site.address.full}.
      </p>
      <p class="mt-2 text-sm text-[var(--color-lilac-100)]/85">{site.hours}</p>
      <p class="mt-1 text-sm">
        <a href={`tel:+65${site.phone}`} class="hover:text-white">{site.phoneDisplay}</a>
        &middot;
        <a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a>
      </p>
    </div>

    <div class="flex gap-4 text-sm sm:pt-1">
      <a href={site.social.instagram} class="inline-block py-1.5 hover:text-white">Instagram</a>
      <a href={site.social.facebook} class="inline-block py-1.5 hover:text-white">Facebook</a>
      <a href={site.gbpUrl} class="inline-block py-1.5 hover:text-white">Google reviews</a>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 py-5 flex flex-col sm:flex-row gap-2 justify-between text-xs text-[var(--color-lilac-100)]/60">
      <p>&copy; {new Date().getFullYear()} {site.businessName}. AVS licensed, {site.license.number}.</p>
      <p class="flex gap-4">
        <a href="/privacy-policy" class="py-1 hover:text-white">Privacy policy</a>
        <span class="py-1">Balestier Road, Singapore</span>
      </p>
    </div>
  </div>
</footer>
