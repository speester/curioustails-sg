---
import { site, whatsappLink } from '../data/site';
import PawPrint from './decor/PawPrint.astro';

// Lean chrome: logo + four money links + CTA. The site's architecture is
// carried by contextual body links (Root-Seed-Node contract), not the nav.
const nav = [
  { label: 'Our Puppies', href: '/puppies' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Starter Kit', href: '/starter-kit' },
  { label: 'Contact', href: '/contact' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');

const pillBase =
  'rounded-full px-3.5 py-2 text-sm font-semibold transition-colors';
const pillIdle =
  'text-[var(--color-cream-700)] hover:bg-[var(--color-peach-100)] hover:text-[var(--color-coral-600)]';
const pillActive = 'bg-[var(--color-coral-100)] text-[var(--color-coral-600)]';
---

<header class="sticky top-0 z-sticky bg-[var(--color-surface)]/90 backdrop-blur-sm">
  <div class="mx-auto max-w-[1400px] px-5 sm:px-8 flex items-center justify-between h-20 py-3">
    <a href="/" class="flex items-center gap-2.5 group shrink-0">
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border-3 border-[var(--color-coral-600)] bg-[var(--color-coral-100)] text-[var(--color-coral-600)] shadow-[0_4px_0_0_var(--color-coral-600)] transition-transform group-hover:-rotate-6">
        <PawPrint class="h-6 w-6" />
      </span>
      <span class="font-[family-name:var(--font-heading)] text-xl font-semibold text-[var(--color-cream-900)]">
        {site.businessName}
      </span>
    </a>

    <nav aria-label="Primary" class="hidden lg:flex items-center gap-0.5 rounded-full border-3 border-[var(--color-border)] bg-[var(--color-surface-card)] px-2 py-1.5">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class={`${pillBase} ${isActive(item.href) ? pillActive : pillIdle}`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden lg:block shrink-0">
      <a
        href={whatsappLink("Hi! I'd like to ask about your puppies.")}
        class="clay-btn inline-flex items-center gap-2 bg-[var(--color-accent)] px-5 py-2.5 text-sm font-bold text-white hover:bg-[var(--color-accent-hover)]"
      >
        WhatsApp us
      </a>
    </div>

    <button
      type="button"
      class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-2xl border-3 border-[var(--color-border)] bg-[var(--color-surface-card)] text-[var(--color-cream-800)]"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-menu-toggle
    >
      <span class="sr-only">Open menu</span>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav
    id="mobile-nav"
    aria-label="Mobile"
    class="lg:hidden hidden flex-col gap-1 mx-5 mb-4 rounded-3xl border-3 border-[var(--color-border)] bg-[var(--color-surface-card)] px-4 py-4 shadow-tint-md"
    data-menu-panel
  >
    {nav.map((item) => (
      <a
        href={item.href}
        aria-current={isActive(item.href) ? 'page' : undefined}
        class={`rounded-xl px-3 py-2.5 font-semibold ${isActive(item.href) ? 'bg-[var(--color-coral-100)] text-[var(--color-coral-600)]' : 'text-[var(--color-cream-800)]'}`}
      >
        {item.label}
      </a>
    ))}
    <a
      href={whatsappLink("Hi! I'd like to ask about your puppies.")}
      class="clay-btn mt-2 inline-flex items-center justify-center bg-[var(--color-accent)] px-5 py-3 text-sm font-bold text-white"
    >
      WhatsApp us
    </a>
  </nav>
</header>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const panel = document.querySelector('[data-menu-panel]');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    panel?.classList.toggle('hidden');
    panel?.classList.toggle('flex');
  });
</script>
