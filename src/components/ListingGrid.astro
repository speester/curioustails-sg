---
import PlaceholderImage from './PlaceholderImage.astro';
import PawPrint from './decor/PawPrint.astro';

interface Item {
  title: string;
  href: string;
  imageAlt: string;
  imageSrc?: ImageMetadata;
  meta: string;
  points?: string[]; // quick point-form facts shown on the card
  ctaLabel?: string; // when set, renders a "View Breed"-style button instead of the WhatsApp one
  tag?: string;
  comingSoon?: boolean; // page not built yet: render a non-clickable "Coming soon" card (no link, no 404)
  gender?: 'Male' | 'Female';
  age?: string; // e.g. "2 months"
}
interface Props {
  heading: string;
  headingAccent?: string;
  subhead?: string;
  items: Item[];
  footerCtaLabel?: string;
  footerCtaHref?: string;
}
const { heading, headingAccent, subhead, items, footerCtaLabel, footerCtaHref } = Astro.props;
const headingParts = headingAccent ? heading.split(headingAccent) : [heading, ''];
const rotations = ['-rotate-2', 'rotate-2', '-rotate-1', 'rotate-1', '-rotate-2', 'rotate-1', '-rotate-1'];
---

<section class="mx-auto max-w-[1400px] px-5 sm:px-8 py-16">
  <div class="max-w-[65ch]">
    <h2 class="font-semibold text-[var(--color-cream-900)]" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
      {headingParts[0]}{headingAccent && <span class="text-[var(--color-coral-500)]">{headingAccent}</span>}{headingParts[1]}
    </h2>
    {subhead && <p class="mt-2 text-base text-[var(--color-cream-600)]">{subhead}</p>}
  </div>

  <ul class="mt-9 grid gap-7" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
    {items.map((item, i) => (
      <li data-reveal style={`--i:${i % 6}`}>
        <div
          data-tilt
          class={`group clay clay-hover flex h-full flex-col bg-[var(--color-surface-card)] overflow-hidden ${rotations[i % rotations.length]}`}
        >
          <div class="relative p-3 pb-0">
            <div class="overflow-hidden rounded-[1.1rem]">
              <div class="transition-transform duration-500 ease-out group-hover:scale-[1.08]">
                <PlaceholderImage alt={item.imageAlt} src={item.imageSrc} ratio="aspect-[4/3]" />
              </div>
            </div>
            {item.tag && (
              <span
                class:list={[
                  'absolute left-5 top-5 inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-bold text-white',
                  item.comingSoon
                    ? 'bg-[var(--color-lilac-900)] shadow-[0_3px_0_0_rgba(0,0,0,0.18)]'
                    : 'bg-[var(--color-coral-500)] shadow-[0_3px_0_0_var(--color-coral-700)]',
                ]}
              >
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-white"></span>
                {item.tag}
              </span>
            )}
          </div>
          <div class="flex flex-1 flex-col p-5">
            <h3 class="text-lg font-[family-name:var(--font-heading)] font-semibold text-[var(--color-cream-900)]">
              {item.title}
            </h3>
            {item.points && item.points.length > 0 && (
              <ul class="mt-3.5 mb-5 space-y-2 border-t-2 border-dashed border-[var(--color-cream-200)] pt-3.5">
                {item.points.map((point) => (
                  <li class="flex items-start gap-2.5 text-sm leading-snug text-[var(--color-cream-700)]">
                    <PawPrint class="mt-0.5 h-3.5 w-3.5 shrink-0 text-[var(--color-coral-400)]" />
                    {point}
                  </li>
                ))}
              </ul>
            )}
            {(item.gender || item.age) && (
              <div class="mt-3 flex flex-wrap gap-2">
                {item.gender && (
                  <span
                    class:list={[
                      'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-bold',
                      item.gender === 'Female'
                        ? 'bg-[var(--color-coral-100)] text-[var(--color-coral-700)]'
                        : 'bg-[var(--color-lilac-100)] text-[var(--color-lilac-700)]',
                    ]}
                  >
                    {item.gender === 'Female' ? (
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="9" r="5" /><path d="M12 14v7M9 18h6" stroke-linecap="round" /></svg>
                    ) : (
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="10" cy="14" r="5" /><path d="M15 9l5-5M15 4h5v5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    )}
                    {item.gender}
                  </span>
                )}
                {item.age && (
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--color-mint-100)] px-3 py-1 text-xs font-bold text-[var(--color-lilac-700)]">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    {item.age}
                  </span>
                )}
              </div>
            )}
            {item.comingSoon ? (
              <span
                aria-label={`${item.title} — page coming soon`}
                class="mt-auto inline-flex w-full items-center justify-center gap-2 rounded-[var(--radius-btn,0.9rem)] border-2 border-dashed border-[var(--color-cream-300)] bg-[var(--color-cream-100)] px-5 py-3 text-sm font-bold text-[var(--color-cream-600)]"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M12 7v5l3 2" />
                </svg>
                Page coming soon
              </span>
            ) : item.ctaLabel ? (
              <a
                href={item.href}
                aria-label={`${item.ctaLabel}: ${item.title} — ${item.meta}`}
                class="clay-btn clay-press mt-auto inline-flex w-full items-center justify-center gap-2 bg-[var(--color-accent)] px-5 py-3 text-sm font-bold text-white transition-transform hover:bg-[var(--color-accent-hover)]"
              >
                {item.ctaLabel}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            ) : (
            <a
              href={item.href}
              aria-label={`${item.meta} — ${item.title}`}
              class="clay-btn clay-press mt-5 inline-flex w-full items-center justify-center gap-2 bg-[#25D366] px-5 py-3 text-sm font-bold text-white transition-transform hover:bg-[#1ebe57]"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.8 14.13c-.25.7-1.44 1.33-1.99 1.37-.53.05-.53.42-3.34-.7-2.81-1.12-4.55-3.98-4.69-4.16-.14-.19-1.12-1.49-1.12-2.84 0-1.35.71-2.01.96-2.29.25-.28.55-.35.73-.35.18 0 .37 0 .53.01.17.01.4-.06.62.48.25.6.85 2.06.92 2.21.07.14.12.31.02.5-.09.19-.14.31-.28.47-.14.16-.29.36-.42.48-.14.14-.28.28-.12.56.16.28.71 1.17 1.53 1.9 1.05.94 1.94 1.23 2.22 1.37.28.14.44.12.6-.07.16-.19.69-.81.88-1.09.19-.28.37-.23.62-.14.25.09 1.6.76 1.87.9.28.14.46.21.53.32.07.12.07.65-.18 1.35z" />
              </svg>
              {item.meta}
            </a>
            )}
          </div>
        </div>
      </li>
    ))}
  </ul>

  {footerCtaLabel && footerCtaHref && (
    <div class="mt-9">
      <a href={footerCtaHref} class="clay-btn-outline inline-flex items-center gap-2 bg-white px-6 py-3 text-base font-bold text-[var(--color-coral-600)]">
        {footerCtaLabel}
      </a>
    </div>
  )}
</section>
