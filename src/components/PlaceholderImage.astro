---
import { Image } from 'astro:assets';
interface Props {
  alt: string;
  src?: ImageMetadata;
  ratio?: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
}
const {
  alt,
  src,
  ratio = 'aspect-[4/3]',
  class: className = '',
  loading = 'lazy',
  fetchpriority,
  sizes = '(max-width: 1023px) 100vw, 50vw',
} = Astro.props;
// Cap srcset candidates at the source width so Astro never upscales.
const widths = src ? [480, 768, 1024, 1400].filter((w) => w <= src.width).concat(src.width > 1400 ? [] : [src.width]) : [];
---

{src ? (
  <div class={`${ratio} rounded-2xl overflow-hidden ${className}`}>
    <Image
      src={src}
      alt={alt}
      class="w-full h-full object-cover"
      loading={loading}
      fetchpriority={fetchpriority}
      widths={widths.length ? [...new Set(widths)] : undefined}
      sizes={widths.length ? sizes : undefined}
    />
  </div>
) : (
  <div
    class:list={[
      ratio,
      className,
      'flex items-end rounded-2xl bg-gradient-to-br from-[var(--color-peach-200)] to-[var(--color-mint-100)] overflow-hidden',
    ]}
    role="img"
    aria-label={alt}
  >
    <span class="m-3 rounded-full bg-[var(--color-lilac-900)]/75 px-3 py-1 text-xs font-semibold text-white">
      Image pending: {alt}
    </span>
  </div>
)}
