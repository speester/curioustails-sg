---
// Progressive-enhancement sortable table. The full table renders in raw HTML;
// a ~1KB inline script upgrades the headers into sort buttons. No framework.
interface Row {
  label: string;
  href?: string;
  cells: string[];
  // one sortable value per column (label column first); strings compare
  // alphabetically, numbers numerically
  sort: (string | number)[];
}
interface Props {
  heading: string;
  headingAccent?: string;
  subhead?: string;
  headers: string[];
  rows: Row[];
}
const { heading, headingAccent, subhead, headers, rows } = Astro.props;
const headingHtml = headingAccent
  ? heading.replace(headingAccent, `<span class="text-[var(--color-coral-600)]">${headingAccent}</span>`)
  : heading;
---

<section class="mx-auto max-w-[1400px] px-5 sm:px-8 py-10" data-sortable-table>
  <h2 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-semibold text-[var(--color-cream-900)]" set:html={headingHtml} />
  {subhead && <p class="mt-3 max-w-[62ch] text-[var(--color-cream-600)] leading-relaxed">{subhead}</p>}
  <div class="mt-6 overflow-x-auto rounded-3xl border-3 border-[var(--color-border)] bg-[var(--color-surface-card)]">
    <table class="w-full min-w-[640px] text-sm">
      <thead>
        <tr class="border-b-3 border-[var(--color-border)] text-left">
          {headers.map((h, i) => (
            <th scope="col" class="px-5 py-4 font-bold text-[var(--color-cream-800)]" data-col={i}>
              <span class="inline-flex items-center gap-1.5">
                {h}
                <span class="sort-arrow text-[var(--color-cream-500)]" aria-hidden="true"></span>
              </span>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="border-b border-[var(--color-border)]/40 last:border-0 hover:bg-[var(--color-peach-100)]/40 transition-colors">
            <th scope="row" class="px-5 py-3.5 font-semibold text-[var(--color-cream-900)] whitespace-nowrap" data-sort={row.sort[0]}>
              {row.href ? (
                <a href={row.href} class="underline underline-offset-2 decoration-[var(--color-coral-400)] hover:text-[var(--color-coral-600)]">{row.label}</a>
              ) : (
                row.label
              )}
            </th>
            {row.cells.map((cell, i) => (
              <td class="px-5 py-3.5 text-[var(--color-cream-700)] leading-relaxed" data-sort={row.sort[i + 1]}>{cell}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-sortable-table]').forEach((root) => {
    const tbody = root.querySelector('tbody');
    if (!tbody) return;
    root.querySelectorAll<HTMLElement>('thead th').forEach((th) => {
      th.style.cursor = 'pointer';
      th.setAttribute('role', 'button');
      th.setAttribute('tabindex', '0');
      th.setAttribute('aria-label', `Sort by ${th.textContent?.trim()}`);
      const activate = () => {
        const col = Number(th.dataset.col);
        const dir = th.dataset.dir === 'asc' ? 'desc' : 'asc';
        root.querySelectorAll<HTMLElement>('thead th').forEach((o) => {
          delete o.dataset.dir;
          const a = o.querySelector('.sort-arrow');
          if (a) a.textContent = '';
        });
        th.dataset.dir = dir;
        const arrow = th.querySelector('.sort-arrow');
        if (arrow) arrow.textContent = dir === 'asc' ? '▲' : '▼';
        const rows = [...tbody.querySelectorAll('tr')];
        rows.sort((r1, r2) => {
          const v1 = r1.children[col]?.getAttribute('data-sort') ?? '';
          const v2 = r2.children[col]?.getAttribute('data-sort') ?? '';
          const n1 = Number(v1), n2 = Number(v2);
          const cmp = !isNaN(n1) && !isNaN(n2) ? n1 - n2 : v1.localeCompare(v2);
          return dir === 'asc' ? cmp : -cmp;
        });
        rows.forEach((r) => tbody.appendChild(r));
      };
      th.addEventListener('click', activate);
      th.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
      });
    });
  });
</script>
