---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ValueBundle from '../components/ValueBundle.astro';
import ListingGrid from '../components/ListingGrid.astro';
import DefBox from '../components/DefBox.astro';
import Tabs from '../components/Tabs.astro';
import StatStrip from '../components/StatStrip.astro';
import ComparisonSplit from '../components/ComparisonSplit.astro';
import CaptionedBlock from '../components/CaptionedBlock.astro';
import BannerRibbon from '../components/BannerRibbon.astro';
import Carousel from '../components/Carousel.astro';
import FAQ from '../components/FAQ.astro';
import Schema from '../components/Schema.astro';
import PawPrint from '../components/decor/PawPrint.astro';
import Sparkle from '../components/decor/Sparkle.astro';
import Blob from '../components/decor/Blob.astro';
import PawTrail from '../components/decor/PawTrail.astro';
import CloudDivider from '../components/decor/CloudDivider.astro';
import ScatterFloat from '../components/decor/ScatterFloat.astro';
import { site, whatsappLink } from '../data/site';
import { localBusinessSchema, organizationSchema, websiteSchema, webPageSchema, personSchema, serviceSchema, reviewSchema, aggregateOfferSchema, faqPageSchema, itemListSchema, definedTermSchema } from '../lib/schema';
import { priceForHref, fmtPrice, OVERALL_LOW, OVERALL_HIGH } from '../data/pricing';
import heroCavapoo from '../assets/home/1-cavapoo-puppy-hero-balestier.png';
import starterKit from '../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import trainingLesson from '../assets/home/3-avs-certified-trainer-puppy-training-lesson.webp';
import playpenSetup from '../assets/home/4-playpen-setup-delivery-home-balestier.webp';
import settlingIn from '../assets/home/5-cavapoo-puppy-settling-playpen-first-day.webp';
import healthCheck from '../assets/home/6-puppy-health-check-vet-care-avs.webp';
import careSupport from '../assets/home/7-nelson-kim-puppy-care-aftercare-support.png';
import first24Hours from '../assets/home/8-puppy-first-24-hours-settling-playpen.webp';
import hdbLivingRoom from '../assets/home/9-small-breed-puppy-hdb-flat-living-room.webp';
import cavapooPortrait from '../assets/cavapoo/2-cavapoo-puppy-portrait-available.webp';
import maltipooPortrait from '../assets/maltipoo/3-maltipoo-puppy-portrait-available.webp';
import maltesePortrait from '../assets/maltese/3-maltese-puppy-portrait-available.webp';
import bichonFrisePortrait from '../assets/bichon-frise/6-bichon-frise-puppy-white-male-portrait.webp';
import cavapoochonPortrait from '../assets/cavapoochon/6-cavapoochon-puppy-apricot-female-portrait.webp';
import chihuahuaPortrait from '../assets/chihuahua/6-chihuahua-puppy-fawn-male-portrait.webp';
import dachshundPortrait from '../assets/mini-dachshund/4-mini-dachshund-cream-longhair-portrait.webp';
import corgiPortrait from '../assets/corgi/2-corgi-red-white-portrait.webp';
import shibaPortrait from '../assets/shiba-inu/2-shiba-red-portrait.webp';
import bichonpooPortrait from '../assets/bichonpoo/2-bichonpoo-white-portrait.webp';
import cockapooPortrait from '../assets/cockapoo/2-cockapoo-apricot-portrait.webp';

const title = 'Puppy for Sale Singapore | AVS Licensed | Curious Tails';
const description =
  'AVS licensed puppies for sale in Singapore — Cavapoo, Maltipoo & more. $500+ starter kit, free delivery. WhatsApp today.';

const breeds = [
  {
    title: 'Cavapoo', href: '/puppies/cavapoo', imageSrc: cavapooPortrait, imageAlt: 'Cavapoo puppy sitting on a light wood floor',
    meta: 'Gentle and easygoing, a favourite for working households', ctaLabel: 'View Breed',
    points: ['Gentle, easygoing temperament', 'Copes well alone during work hours', 'Low-shedding poodle-cross coat', 'HDB-approved cross'],
  },
  {
    title: 'Maltipoo', href: '/puppies/maltipoo', imageSrc: maltipooPortrait, imageAlt: 'Maltipoo puppy with a wavy cream coat',
    meta: 'Affectionate and people focused, happiest with company at home', ctaLabel: 'View Breed',
    points: ['Affectionate and people-focused', 'Happiest with company at home', 'Low-shedding, easy-care coat', 'HDB-approved cross'],
  },
  {
    title: 'Maltese', href: '/puppies/maltese', imageSrc: maltesePortrait, imageAlt: 'Maltese puppy with a silky white coat',
    meta: 'The classic white companion, gentle and devoted to its people', ctaLabel: 'View Breed',
    points: ['Gentle, devoted lap companion', 'Happiest with company at home', 'Silky white, very low-shedding coat', 'HDB-approved breed'],
  },
  {
    title: 'Mini Dachshund', href: '/puppies/mini-dachshund', imageSrc: dachshundPortrait, imageAlt: 'Cream long-haired Mini Dachshund puppy portrait',
    meta: 'Compact, curious, and full of personality', ctaLabel: 'View Breed',
    points: ['Compact with a big personality', 'Curious, confident little explorer', 'Short coat, minimal grooming', 'HDB-approved small breed'],
  },
  {
    title: 'Corgi', href: '/puppies/corgi', imageSrc: corgiPortrait, imageAlt: 'Corgi puppy with upright ears',
    meta: 'Big character in a small body, active and alert', ctaLabel: 'View Breed',
    points: ['Big character, active and alert', 'Needs daily exercise and play', 'Double coat, sheds regularly', 'Not HDB-approved — private property'],
  },
  {
    title: 'Shiba Inu', href: '/puppies/shiba-inu', imageSrc: shibaPortrait, imageAlt: 'Shiba Inu puppy with a fox-like face',
    meta: 'Independent and clean, for owners who want a calmer bond', ctaLabel: 'View Breed',
    points: ['Independent, calm, cat-like nature', 'Naturally clean and tidy habits', 'Suits owners who respect space', 'Not HDB-approved — private property'],
  },
  {
    title: 'Bichonpoo', href: '/puppies/bichonpoo', imageSrc: bichonpooPortrait, imageAlt: 'Bichonpoo puppy with a white curly coat',
    meta: 'Low shedding and playful, an easy fit for small homes', ctaLabel: 'View Breed',
    points: ['Playful, cheerful and gentle', 'Low-shedding, allergy-friendlier coat', 'Easy fit for smaller homes', 'HDB-approved cross'],
  },
  {
    title: 'Cockapoo', href: '/puppies/cockapoo', imageSrc: cockapooPortrait, imageAlt: 'Cockapoo puppy with long floppy ears',
    meta: 'Warm and sociable, a natural with children', ctaLabel: 'View Breed',
    points: ['Warm and sociable, great with kids', 'Adaptable to most daily routines', 'Low-shedding wavy coat', 'HDB-approved cross'],
  },
  {
    title: 'Bichon Frise', href: '/puppies/bichon-frise', imageSrc: bichonFrisePortrait, imageAlt: 'Bichon Frise puppy with a white curly coat',
    meta: 'The cheerful white classic, happiest with company around', ctaLabel: 'View Breed',
    points: ['Famously cheerful and sociable', 'Happiest with company at home', 'Curly low-shedding double coat', 'HDB-approved breed'],
  },
  {
    title: 'Cavapoochon', href: '/puppies/cavapoochon', imageSrc: cavapoochonPortrait, imageAlt: 'Cavapoochon puppy with a soft teddy-bear coat',
    meta: 'The teddy-bear triple cross, gentle with everyone', ctaLabel: 'View Breed',
    points: ['Gentle, adaptable family all-rounder', 'Keeps its teddy-bear puppy look', 'Low-shedding soft coat', 'HDB-friendly approved cross'],
  },
  {
    title: 'Chihuahua', href: '/puppies/chihuahua', imageSrc: chihuahuaPortrait, imageAlt: 'Chihuahua puppy with upright ears and a fawn coat',
    meta: 'Tiny devoted companion with a big-dog personality', ctaLabel: 'View Breed',
    points: ['Devoted, alert lap companion', 'The world\'s smallest breed, 1.5 to 3 kg', 'Easiest grooming in our lineup', 'HDB-approved toy breed'],
  },
];

const pricedBreeds = breeds.map((b) => ({ ...b, tag: `From $${fmtPrice(priceForHref(b.href).low)}` }));

const jumpLinks = [
  { label: 'Puppies', href: '#puppies' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Starter Kit', href: '#starter-kit' },
  { label: 'Training', href: '#training' },
  { label: 'Reviews', href: '#reviews' },
  { label: 'Trust', href: '#trust' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'Which puppy breed is best for first-time owners in Singapore?',
    answer:
      "It depends more on your daily routine than on the breed itself. If nobody's home during the day, a Cavapoo, Cockapoo, or Mini Dachshund tends to cope better than a Maltipoo or Bichonpoo, which prefer more company. For a first time dog owner in Singapore, this matters more than popularity. Take our 2-minute breed quiz for a match based on your actual routine.",
  },
  {
    question: 'How much does a puppy cost in Singapore?',
    answer:
      'At Curious Tails, puppies published from $3,288 all-in, and that price includes a $500+ starter kit, free delivery and setup, and a free first training lesson. Elsewhere, prices for comparable breeds can run higher once those extras are added separately.',
  },
  {
    question: 'How do I know if a pet shop is licensed in Singapore?',
    answer:
      "Search the shop's name or licence number on the AVS public registry. Curious Tails holds AVS pet shop licence AS24J00046. If a seller can't be found there, they aren't licensed, regardless of what they claim.",
  },
  {
    question: "What's included in your starter kit?",
    answer:
      'Over 30 items across eight categories: a playpen, a carrier, grooming tools, food, outdoor gear, toilet training supplies, oral health care, and toys, worth more than $500 in total. We also walk you through how to use each one.',
  },
  {
    question: 'Can I keep a Corgi or Shiba Inu in an HDB flat?',
    answer:
      "Not under the standard HDB approved list. If you're set on either breed, you'd need private property, or to look at an approved cross instead. We'll tell you this upfront rather than let you find out later.",
  },
  {
    question: 'How do I avoid buying a smuggled puppy?',
    answer:
      "Check the seller's AVS licence number on the public registry before you pay a deposit. Smuggled puppies are usually sold outside licensed channels, often without vaccination, and the health risk to the puppy, and the legal risk to you, is real.",
  },
  {
    question: 'What happens after I reserve a puppy?',
    answer:
      "You WhatsApp us, place a deposit, and we board your puppy for free until you're ready. Delivery is scheduled around your availability, and everything is set up before you arrive home.",
  },
  {
    question: 'Is the free training lesson really free?',
    answer:
      'Yes. It is included in the price of every puppy, delivered by an AVS Accredited Certified Dog Trainer, with no add-on fee.',
  },
];

const schemas = [
  localBusinessSchema(),
  organizationSchema(),
  websiteSchema(),
  personSchema(),
  webPageSchema({
    path: '/',
    title,
    description,
    aboutName: 'AVS licensed pet shop',
    aboutAlternateName: 'pet shop licence Singapore',
    datePublished: '2024-01-01',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  serviceSchema({
    name: 'Free First Training Lesson',
    description: 'Free training lesson with an AVS-Accredited Certified Dog Trainer included with every puppy purchase',
    price: 'Included',
  }),
  serviceSchema({
    name: 'Free Home Delivery & Setup',
    description: 'Free home delivery across Singapore with playpen, bed, and toys setup included',
    price: 'Included',
  }),
  serviceSchema({
    name: 'Ongoing Customer Support',
    description: 'Free post-purchase customer service and 5-day nurse-back safety net if puppy falls sick',
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody: "Couldn't recommend Curious Tails in Balestier enough after bringing home our Cavapoo. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  aggregateOfferSchema({
    priceLow: String(OVERALL_LOW),
    priceHigh: String(OVERALL_HIGH),
    priceCurrency: 'SGD',
  }),
  faqPageSchema(faqItems),
  itemListSchema(pricedBreeds.map((b) => ({
    name: `${b.title} puppy`,
    url: b.href,
    description: b.meta,
    price: String(priceForHref(b.href).low),
    image: b.imageSrc.src,
  }))),
  definedTermSchema({
    name: 'AVS-licensed pet shop',
    description: 'An AVS-licensed pet shop is a Singapore business approved by the Animal and Veterinary Service, a unit of the National Parks Board, to keep and sell dogs, cats, or rabbits, subject to welfare inspections, mandatory owner-suitability screening, and annual licence renewal.',
    sameAs: 'https://avs.nparks.gov.sg/businesses/pet-shop-owners/pet-shop-licence/',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/">
  <Hero
    eyebrow="AVS Licensed Puppy Shop in Balestier"
    h1="Puppies for Sale in Singapore"
    h1Accent="Sale"
    subhead="Every puppy comes with a $500+ starter kit, free home delivery, and a free first training lesson. Priced honestly, not padded for marketing spend."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your puppies."
    secondaryCtaLabel="See available puppies & pricing"
    secondaryCtaHref="#puppies"
    priceAnchor="From $3,288, all-in — starter kit, home delivery and first training lesson included."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, '2+ years in Balestier']}
    imageAlt="Cavapoo puppy in a set-up playpen at a Balestier Road home"
    imageSrc={heroCavapoo}
    tagLabel="40+ breeds"
    proofChip="5.0 on Google"
  />

  <Tabs items={jumpLinks} />

  <ValueBundle
    eyebrow="Included with every puppy"
    heading="One honest price. Everything to settle in."
    headingAccent="honest price"
    subhead="No add-ons quietly billed later. The kit, the delivery and the first lesson are already in the price you see."
    items={[
      {
        icon: 'kit',
        title: '$500+ Starter Kit',
        body: 'Over 30 items across eight categories — playpen, carrier, grooming, food, outdoor gear, toilet training, oral care and toys. Included, never sold separately.',
        highlight: '30+ items',
      },
      {
        icon: 'delivery',
        title: 'Free Home Delivery & Setup',
        body: 'We bring your puppy home and set up the playpen, bed and toys before you arrive, scheduled around your own availability.',
        highlight: 'Free',
      },
      {
        icon: 'training',
        title: 'Free First Training Lesson',
        body: 'Your first lesson with an AVS-Accredited Certified Dog Trainer, built into the price to cover settling in and a potty routine.',
        highlight: 'AVS-certified',
      },
    ]}
  />

  <PawTrail bg="bg-[var(--color-surface)]" colorClass="text-[var(--color-coral-300)]" />

  <div id="puppies" class="scroll-mt-40">
    <ListingGrid
      heading="Meet Our Puppies"
      headingAccent="Puppies"
      subhead="Eleven breeds, each with its own published starting price, all-in. More are added as we bring new litters home."
      items={pricedBreeds}
      footerCtaLabel="Not sure which breed fits you? Take the 2-minute quiz"
      footerCtaHref="/first-time-owners/breed-selector"
    />
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is an AVS-licensed puppy shop?"
      definition="An AVS-licensed pet shop is a Singapore business approved by the Animal and Veterinary Service, a unit of the National Parks Board, to keep and sell dogs. Licensing means welfare inspections, mandatory owner-suitability screening, and annual renewal, not just a name on a shopfront."
      bridge="Curious Tails holds AVS pet shop licence AS24J00046. You can check ours, or any shop's, on the public registry below."
      citationLabel="Search the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">What licensing actually requires</p>
        <ul class="mt-4 space-y-3">
          {[
            'Regular welfare inspections of how animals are kept and sold',
            'Mandatory owner-suitability screening before a sale (the Pet Purchase Declaration)',
            'Annual licence renewal, not a one-time approval',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">A shop with none of this is unlicensed, regardless of what it claims.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families trust Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '2+', label: 'years in Balestier' },
      { value: '7', label: 'breeds, more added regularly' },
      { value: '$500+', label: 'starter kit included free' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="pricing" class="scroll-mt-40">
    <ComparisonSplit
      heading="Why Our Puppies Cost Less, Not More"
      headingAccent="Less"
      subhead="From $3,288 per puppy, all in."
      mode="split"
      columns={[
        {
          heading: 'Many Singapore pet shops',
          items: [
            'Price covers the puppy only',
            'Starter supplies sold separately',
            'Training is an add-on, if offered at all',
            'Delivery arranged and charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            'From $3,288, starter kit included',
            '$500+ worth of starter kit items, no extra cost',
            'First training lesson free, with an AVS-certified trainer',
            'Free home delivery, with the playpen already set up',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Want the market-wide numbers, what drives them, and the deposit-to-homecoming process? It's all in the <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">full breakdown of puppy prices in Singapore</a>.
      </p>
    </div>
  </div>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />

  <div id="starter-kit" class="scroll-mt-40">
    <CaptionedBlock heading="What's Actually Inside the Starter Kit" imageAlt="Starter kit items including a playpen, carrier, and grooming tools" imageSrc={starterKit} variant="mid">
      <p>Every puppy leaves Curious Tails with more than 30 items, worth over $500, covering eight categories: a playpen, a carrier, grooming tools, food, outdoor gear, toilet training supplies, oral health care, and toys. Your puppy is microchipped and vaccinated before going home, so the paperwork and the health side are already settled.</p>
      <p>We don't just hand over a box. On delivery day, Nelson or Kim goes through each item with you: how to use it, and how it fits into caring for your puppy day to day. We'll talk you through the first night home, the potty routine, and what's normal in the first week, so you're not guessing at 11pm.</p>
      <p>That's deliberate. Most of the questions a new owner would normally have to ask later are already answered before we leave your home. For the item-by-item detail, see <a href="/starter-kit" class="underline underline-offset-2 text-[var(--color-accent-hover)]">what's inside our puppy starter kit</a>.</p>
    </CaptionedBlock>
    <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

    <ComparisonSplit
      heading="Starter Kit Itemized Value Breakdown"
      headingAccent="Value Breakdown"
      subhead="No competitor lists itemized pricing. This is what the $500+ actually covers."
      mode="table"
      tableHeaders={['Category', 'Retail Value']}
      rows={[
        { label: 'Playpen (wooden) + soft-sided carrier', values: ['$150'] },
        { label: 'Bed and blankets (2)', values: ['$50'] },
        { label: 'Food and water bowls, premium puppy food (2kg)', values: ['$40'] },
        { label: 'Brush, nail clippers, wipes', values: ['$30'] },
        { label: 'Pee pads (100 count), clicker, training treats', values: ['$35'] },
        { label: 'Plush toys, balls, chew toys (8)', values: ['$50'] },
        { label: 'Collar, leash, poop bags', values: ['$30'] },
        { label: 'Microchip insertion and vaccination', values: ['$100'] },
        { label: 'Care guide and setup instructions', values: ['$10'] },
        { label: 'Total retail value', values: ['$500+'] },
      ]}
    />
  </div>

  <div id="training" class="scroll-mt-40">
    <CaptionedBlock heading="Your Free First Training Lesson, Explained" imageAlt="AVS-certified trainer working with a puppy" imageSrc={trainingLesson} imagePosition="left">
      <p>
        Every puppy includes a free first lesson with an{' '}
        <a href="https://avs.nparks.gov.sg/outreach/resources/acdt-dog-trainers/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">AVS-Accredited Certified Dog Trainer</a>,
        under the scheme introduced to raise the standard of dog training in Singapore. This is your AVS-certified training lesson for new puppy owners, covering settling in and a first potty routine.
      </p>
      <p>This isn't an upsell we mention once and forget. It's built into the price, and it's designed to cover what a new owner actually needs first: settling in, a potty routine, and not feeling overwhelmed in the first week. Curious how the booking and the lesson itself work? <a href="/free-training" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Your free first lesson, explained in full</a>.</p>
    </CaptionedBlock>
  </div>

  <CaptionedBlock heading="Free Boarding, Then Delivery When You're Ready" imageAlt="Playpen and bed set up in a Singapore home ahead of a puppy's arrival" imageSrc={playpenSetup} imageRotate="left">
    <p>After you place a deposit, we don't rush you. Curious Tails boards your puppy for free, lodging and food both covered, until you're ready to bring them home.</p>
    <p>Delivery is then scheduled around your own availability, usually in the morning or the evening. We arrive with the playpen, bed, and toys already set up, so your puppy has a calm space waiting rather than a box to unpack.</p>
    <p>It's the reason a Cavapoo we placed with a working couple settled into her playpen without distress on day one, instead of arriving to an empty room.</p>
  </CaptionedBlock>

  <CaptionedBlock heading="Your Puppy's First 24 Hours" imageAlt="Puppy settling into a pre-set-up playpen on arrival day" imageSrc={first24Hours} variant="card">
    <p>Because the playpen, bed, and toys are already set up before you arrive, your puppy sees it as their space from hour one, not a new, scary place.</p>
    <ul class="mt-4 space-y-3 text-base leading-relaxed text-[var(--color-cream-700)]">
      <li><strong class="text-[var(--color-cream-900)]">Hour 0, Arrival:</strong> Puppy explores the playpen at their own pace, no overwhelming introductions yet.</li>
      <li><strong class="text-[var(--color-cream-900)]">Hour 2, First Meal:</strong> Fed on the same food brand they're used to, with water available at all times and noise kept low.</li>
      <li><strong class="text-[var(--color-cream-900)]">Hour 4, Potty Training Starts:</strong> Outside plus training pads inside, with treats for success and no scolding for accidents, they're normal.</li>
      <li><strong class="text-[var(--color-cream-900)]">Hour 8, Social Interaction:</strong> Gentle play with the included toys as your puppy gets used to your voice and touch.</li>
      <li><strong class="text-[var(--color-cream-900)]">Evening, Sleep Routine:</strong> Dim lights, a quiet room, and the playpen as a safe space. Some whimpering is a normal part of adjusting.</li>
    </ul>
  </CaptionedBlock>

  <div id="match" class="relative">
    <ScatterFloat />
  <ComparisonSplit
      heading="Find Your Perfect Match: What Kind of Day Do You Actually Have?"
      subhead="The right breed depends less on how a puppy looks, and more on what your day actually looks like. We match by lifestyle, whether you're a working couple, a retiree, or a family with kids looking for a gentle, playful companion."
      mode="table"
      tableHeaders={['Your day', 'Breeds that tend to fit']}
      rows={[
        { label: 'Nobody home 8am to 6pm on weekdays', values: ['Cavapoo, Cockapoo, or Mini Dachshund tend to cope better alone'] },
        { label: 'Someone home most of the day (helper, retiree, remote work)', values: ['Maltipoo or Bichonpoo thrive on company'] },
        { label: 'Active, outdoor routine, condo or landed property', values: ['Corgi or Shiba Inu, check HDB rules first, see below'] },
        { label: 'Family with kids, or adding a second dog to the home', values: ['Cockapoo or Cavapoo, both gentle and sociable enough to settle in alongside children or an existing pet'] },
      ]}
    />
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Ask Andrew Mak" imageAlt="Cavapoo puppy settled in her playpen at home" imageSrc={settlingIn} variant="dark" imageRotate="right">
    <p>A couple came in wanting a Maltipoo. Both of them work from 8am to 6pm, with nobody home during the day. Maltipoos tend to need more company than that, so we recommended one of our <a href="/puppies/cavapoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoo puppies, a calmer fit for working couples</a> instead, even though it wasn't what they'd walked in for.</p>
    <p>They took the Cavapoo home. She settled into the playpen we'd set up, with her bed and toys already in place, and adjusted to being alone during the day without the distress a Maltipoo might have shown.</p>
    <p>"Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do," Andrew wrote afterwards. "We loved the aftercare support, you can tell they truly care about the pups and the owners."</p>
    <p>Nelson's own rule of thumb: we'd rather talk you out of the wrong breed than sell you the wrong dog.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <BannerRibbon
    heading="Still deciding?"
    body="Take our 2-minute breed quiz, matched to your actual routine, not just looks."
