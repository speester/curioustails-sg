  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="What Happens After You Reserve a Puppy" imageAlt="Curious Tails puppy carrier and delivery kit ready for a home visit" variant="mid" imagePosition="none">
