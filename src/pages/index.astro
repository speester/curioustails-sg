        <li data-reveal style={`--i:${i}`} class="clay clay-hover bg-[var(--color-surface-card)] p-5">
          <span class="font-[family-name:var(--font-heading)] font-bold text-[var(--color-coral-500)]" style="font-size: clamp(2rem, 3vw, 2.75rem); line-height: 1;">
