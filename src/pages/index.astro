        <span class="wiggle-hover relative mx-auto flex h-20 w-20 items-center justify-center rounded-full border-3 border-[var(--color-mint-300)] bg-white/10 text-[var(--color-mint-300)]">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
