---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import imgHero from '../../assets/cavalier-king-charles-spaniel/1-blenheim-cavalier-king-charles-spaniel-puppy-sitting-in.webp';
import imgScene1 from '../../assets/cavalier-king-charles-spaniel/2-blenheim-cavalier-king-charles-spaniel-puppy-portrait-o.webp';
import imgScene2 from '../../assets/cavalier-king-charles-spaniel/3-cavalier-king-charles-spaniel-puppy-cuddled-on-a-family.webp';
import imgScene3 from '../../assets/cavalier-king-charles-spaniel/4-cavalier-king-charles-spaniel-puppy-having-its-silky-ea.webp';
import imgScene4 from '../../assets/cavalier-king-charles-spaniel/5-cavalier-king-charles-spaniel-puppy-at-a-veterinary-hea.webp';
import imgScene5 from '../../assets/cavalier-king-charles-spaniel/6-cavalier-puppy-settling-into-a-set-up-playpen-during-it.webp';
import imgCard1 from '../../assets/cavalier-king-charles-spaniel/7-blenheim-male-cavalier-king-charles-spaniel-puppy-avail.webp';
import imgCard2 from '../../assets/cavalier-king-charles-spaniel/8-tricolour-female-cavalier-king-charles-spaniel-puppy-av.webp';
import imgCard3 from '../../assets/cavalier-king-charles-spaniel/9-ruby-male-cavalier-king-charles-spaniel-puppy-available.webp';
import imgCard4 from '../../assets/cavalier-king-charles-spaniel/10-black-and-tan-female-cavalier-king-charles-spaniel-pupp.webp';
import imgCard5 from '../../assets/cavalier-king-charles-spaniel/11-blenheim-female-cavalier-king-charles-spaniel-puppy-ava.webp';
import imgCard6 from '../../assets/cavalier-king-charles-spaniel/12-tricolour-male-cavalier-king-charles-spaniel-puppy-avai.webp';

const title = 'Cavalier King Charles Spaniel Singapore | Price & Puppies';
const description =
  'Cavalier King Charles Spaniel puppies for sale in Singapore from $5,588, AVS licensed and HDB-approved. Real prices, temperament, health honesty and the $500+ starter kit.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Grooming', href: '#grooming' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'How much does a Cavalier King Charles Spaniel cost in Singapore?',
    answer:
      'Cavalier prices in Singapore commonly run from around $3,000 to $6,500 depending on colour and shop. At Curious Tails, Cavalier King Charles Spaniel puppies are $5,588 to $6,588, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a Cavalier King Charles Spaniel HDB-approved?',
    answer:
      'Yes. The Cavalier King Charles Spaniel is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and we complete the dog licensing for you at purchase, so the paperwork is handled.',
  },
  {
    question: 'Can a Cavalier be left alone while we are at work?',
    answer:
      'This is the breed\'s honest weakness. Cavaliers were bred purely for companionship and they take the job seriously: a home that is empty 8am to 6pm every weekday is hard on them, and separation stress shows up as crying and destructive chewing. If that is your routine, the Cavapoo, which mixes in the Poodle\'s independence, is the kinder choice, and we will say so before you buy.',
  },
  {
    question: 'Are Cavaliers good with children and other pets?',
    answer:
      'Outstanding, arguably the best of any breed we carry. The Cavalier is gentle, patient, and sociable with children, other dogs, and even cats. It was bred for centuries to be agreeable company, and it shows in everything the breed does.',
  },
  {
    question: 'What health problems do Cavaliers have?',
    answer:
      'The big one is mitral valve disease, a heart condition that affects the breed at much higher rates than most dogs, usually appearing in middle age. We are upfront about it because every honest Cavalier conversation includes it: annual heart checks from around age five are part of responsible Cavalier ownership. Ears also need weekly care, and the breed gains weight easily.',
  },
  {
    question: 'Do Cavaliers shed?',
    answer:
      'Moderately. The silky, feathered coat drops hair year-round at a level between the low-shedding Poodle crosses and the heavy-shedding spitz breeds. Brushing 2 to 3 times a week keeps it manageable. For allergy-sensitive homes, the Cavapoo carries much of the Cavalier temperament in a low-shedding coat.',
  },
  {
    question: 'What are the disadvantages of a Cavalier King Charles Spaniel, and is one worth it?',
    answer:
      "Three honest downsides, and none is a secret. First, they cannot be left alone all day: this is a company-loving breed that gets genuinely low in an empty home. Second, the heart: mitral valve disease runs high in Cavaliers, so annual heart checks from around age five are simply part of the deal. Third, the coat and ears need weekly care and the breed gains weight easily. Weighed against a gentleness few breeds match, most owners in the right home find a Cavalier absolutely worth it; if your home is empty on weekdays, we will honestly point you elsewhere.",
  },
  {
    question: 'What happens after I reserve a Cavalier?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/cavalier-king-charles-spaniel',
    title,
    description,
    aboutName: 'Cavalier King Charles Spaniel',
    aboutAlternateName: 'Cavalier',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Cavalier_King_Charles_Spaniel',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Cavalier King Charles Spaniel puppy',
      url: '/puppies/cavalier-king-charles-spaniel',
      description:
        'Cavalier King Charles Spaniel puppy from an AVS licensed Singapore pet shop, priced $5,588 to $6,588 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '5588',
      image: imgHero.src,
    },
  ]),
  serviceSchema({
    name: 'Cavalier Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Cavalier puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Cavalier King Charles Spaniel',
    description:
      'The Cavalier King Charles Spaniel is a toy spaniel of roughly 5.5 to 8 kg with a silky feathered coat in four colours and one of the gentlest, most affectionate temperaments in the dog world. Lifespan is typically 10 to 14 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Cavalier_King_Charles_Spaniel',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/cavalier-king-charles-spaniel">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Cavalier King Charles Spaniel Puppies in Singapore"
    h1Accent="Cavalier"
    subhead="Cavalier prices in Singapore commonly run $3,000 to $6,500. Ours are $5,588 to $6,588, with the $500+ starter kit, free home delivery and setup, and a free first training lesson already in the price."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Cavalier King Charles Spaniel puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $5,588 all-in. HDB-approved. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'HDB-approved toy spaniel']}
    imageAlt="Blenheim Cavalier King Charles Spaniel puppy sitting in a set-up playpen at a Balestier home" imageSrc={imgHero}
    tagLabel="Cavalier"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies/' }, { label: 'Cavalier King Charles Spaniel', href: '/puppies/cavalier-king-charles-spaniel/' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Cavalier in Singapore?" imageAlt="Blenheim Cavalier King Charles Spaniel puppy portrait, one of the Cavalier puppies available in Singapore" imageSrc={imgScene1} variant="mid">
      <p>Our Cavalier puppies in Singapore arrive and are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, colour, and exact prices for the Cavalier King Charles Spaniel puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Cavalier for sale in Singapore here is between $5,588 and $6,588, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Cavalier puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Cavalier photos and prices</a>, or meet our Cavalier puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Cavalier Puppies"
      headingAccent="Available"
      subhead="A few of the Cavalier puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Blenheim boy', href: whatsappLink('Hi! I\'d like more photos and the price for the Blenheim male Cavalier puppy.'), imageAlt: 'Blenheim male Cavalier King Charles Spaniel puppy available in Singapore', imageSrc: imgCard1, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Tricolour girl', href: whatsappLink('Hi! I\'d like more photos and the price for the tricolour female Cavalier puppy.'), imageAlt: 'Tricolour female Cavalier King Charles Spaniel puppy available in Singapore', imageSrc: imgCard2, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Ruby boy', href: whatsappLink('Hi! I\'d like more photos and the price for the ruby male Cavalier puppy.'), imageAlt: 'Ruby male Cavalier King Charles Spaniel puppy available in Singapore', imageSrc: imgCard3, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'Black & tan girl', href: whatsappLink('Hi! I\'d like more photos and the price for the black and tan female Cavalier puppy.'), imageAlt: 'Black and tan female Cavalier King Charles Spaniel puppy available in Singapore', imageSrc: imgCard4, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Blenheim girl', href: whatsappLink('Hi! I\'d like more photos and the price for the Blenheim female Cavalier puppy.'), imageAlt: 'Blenheim female Cavalier King Charles Spaniel puppy available in Singapore', imageSrc: imgCard5, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '2 months' },
        { title: 'Tricolour boy', href: whatsappLink('Hi! I\'d like more photos and the price for the tricolour male Cavalier puppy.'), imageAlt: 'Tricolour male Cavalier King Charles Spaniel puppy available in Singapore', imageSrc: imgCard6, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '12 weeks' },
      ]}
    />
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is a Cavalier King Charles Spaniel?"
      definition="The Cavalier King Charles Spaniel is a toy spaniel of roughly 5.5 to 8 kg, bred from the lap spaniels of English royal courts. It carries a silky, feathered coat in four colours (Blenheim, tricolour, ruby, black & tan) and a temperament so gentle and sociable that it is regularly recommended as the ideal first dog. Lifespan is typically 10 to 14 years."
      bridge="Curious Tails is an AVS licensed pet shop at 2 Balestier Road. We match by lifestyle first, and the Cavalier is the softest-hearted dog in the shop: perfect for homes with company, wrong for homes that are empty all day."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Cavalier at a glance</p>
        <ul class="mt-4 space-y-3">
          {[
            'The gentlest temperament we carry',
            'Roughly 5.5 to 8 kg fully grown',
            'Four colours: Blenheim, tricolour, ruby, black & tan',
            'Superb with children, dogs and cats',
            '10 to 14 year lifespan',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Sizes vary by line; ask us about a specific puppy's expected adult weight.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Cavalier from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$5,588', label: 'Cavalier pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Cavalier Temperament: Bred for Four Centuries to Love You" imageAlt="Cavalier King Charles Spaniel puppy cuddled on a family sofa" imageSrc={imgScene2} imagePosition="left">
      <p>Most breeds were bred to do something. The Cavalier was bred to be with someone, and four centuries of that selection produced the most reliably gentle, affectionate dog we carry. It loves your children, your visitors, your other dog, and quite possibly your cat. It doesn't guard, rarely barks with intent, and its idea of a perfect day is following you from room to room, then falling asleep touching some part of you.</p>
      <p>The honest part, from two years of matching puppies to families: that devotion has no off switch. A Cavalier alone in an empty flat from 8am to 6pm is not a mildly disappointed dog; it is a genuinely distressed one, and the crying and chewed skirting boards are how you find out. This is the single most important question we ask Cavalier buyers, and we'd rather lose the sale than place this breed in an empty home.</p>
      <p>If your weekdays are away and the Cavalier's sweetness is what drew you, the <a href="/puppies/cavapoo/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoo</a> exists for exactly this reason.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Cavalier Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Honestly: this is the worst breed we carry for that routine, and we won't dress it up. Cavaliers were never bred to be alone and they never learned. Homes where someone is around most of the day, retirees, work-from-home households, families with a helper, get the best dog of their lives. Empty weekday homes get a heartbroken one.</p>
      <p>If your routine is out 8am to 6pm, the <a href="/puppies/cavapoo/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoo</a> keeps most of the Cavalier warmth with a genuinely better tolerance for alone time. Message us your routine and we'll tell you straight.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'Someone is home most of the day',
            'Family with children or other pets',
            'You want the gentlest possible first dog',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Cavalier Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for the royal lap spaniel."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 5.5 to 8 kg; kept lean, because the breed gains easily'] },
        { label: 'Height', values: ['Around 30 to 33 cm at the shoulder'] },
        { label: 'Coat', values: ['Silky, medium-length with feathering; Blenheim (chestnut & white), tricolour, ruby, black & tan'] },
        { label: 'Lifespan', values: ['10 to 14 years; heart health is the main variable, see below'] },
        { label: 'Exercise', values: ['About 30 to 45 minutes a day, plus play; adaptable to your pace'] },
        { label: 'Shedding & allergies', values: ['Moderate year-round shedding; not the pick for allergy-sensitive homes'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        The Cavalier's adaptability is its quiet superpower: it matches an active family's pace or a retiree's, as long as its people are in view. For the same temperament in a low-shedding coat, the Cavapoo and <a href="/puppies/cavapoochon/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoochon</a> are its most popular descendants.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Cavalier Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="Most shops make you WhatsApp them just to learn the number. Here's ours in writing: $5,588 to $6,588, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Cavalier price commonly $3,000 to $6,500',
            'Price usually not published; enquiry required',
            'Blenheims often priced at a premium',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$5,588 to $6,588, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on our transparent puppy pricing page, and plan the ongoing costs with the first-year puppy budget guide.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Cavalier Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Cavalier leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, small-breed puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this breed the ear cleanser earns its place fast, those beautiful drop ears need weekly attention in our humidity, and the measuring cup guards against the Cavalier's talent for gaining weight.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Cavalier's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See the full 30+ item kit breakdown, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Cavalier Right for Your Lifestyle?"
      subhead="We ask about your routine before recommending any breed. Here's the honest short version for a Cavalier."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Someone home most of the day', values: ['Ideal. This is the Cavalier home, and no breed rewards it more'] },
        { label: 'Family with children or other pets', values: ['Ideal. The most reliably gentle breed we carry with kids, dogs and cats'] },
        { label: 'First-time owner wanting a soft, forgiving dog', values: ['Great fit. Eager, gentle, and biddable; just mind the alone-time rule'] },
        { label: 'Out 8am to 6pm on weekdays', values: ['Reconsider, honestly. This is the one breed we won\'t place in an empty home; the Cavapoo is the kinder pick'] },
        { label: 'Allergy-sensitive household', values: ['Reconsider. Cavaliers shed moderately; the Cavapoo or Cavapoochon covers the temperament with less hair'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Cavalier is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my daily routine. Is a Cavalier King Charles Spaniel the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Cavalier vs Cavapoo: The Original or the Cross?" imagePosition="none" variant="dark">
    <p>The Cavapoo is half Cavalier, so the sweetness carries over; the Poodle half adds independence and subtracts most of the shedding. The honest trade: the purebred Cavalier is gentler still and more predictable in looks and temperament, but it needs company through the day and carries the breed's known heart risk. The Cavapoo handles working households far better and its mixed parentage broadens the health base.</p>
    <p>Our plain-language rule: someone home most of the day and you want the gentlest dog possible, Cavalier. Out at work weekdays, Cavapoo, no hesitation. With us the price, the starter kit, and the aftercare are identical either way.</p>
    <p>Weighing the two? See our Cavapoo puppies, or message us your routine and we'll tell you straight.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
      <ul class="mt-4 space-y-3">
        {[
          'Cavalier: gentlest, needs daytime company, sheds moderately',
          'Cavapoo: more independent, low-shedding, working-household proof',
          'Same price, same starter kit, same aftercare either way',
        ].map((fact) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
