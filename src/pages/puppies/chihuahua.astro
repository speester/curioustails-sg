---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import heroChihuahua from '../../assets/chihuahua/1-chihuahua-puppy-hero-playpen-balestier.webp';
import companionLap from '../../assets/chihuahua/2-chihuahua-puppy-companion-lap.webp';
import chihuahuaGrooming from '../../assets/chihuahua/3-chihuahua-puppy-grooming-coat-care.webp';
import chihuahuaVet from '../../assets/chihuahua/4-chihuahua-puppy-vet-health-check.webp';
import chihuahuaSettling from '../../assets/chihuahua/5-chihuahua-puppy-settling-playpen.webp';
import fawnBoyPortrait from '../../assets/chihuahua/6-chihuahua-puppy-fawn-male-portrait.webp';
import blackTanGirlPortrait from '../../assets/chihuahua/7-chihuahua-puppy-black-tan-female-portrait.webp';
import chocolateBoyPortrait from '../../assets/chihuahua/8-chihuahua-puppy-chocolate-male-portrait.webp';
import creamLongCoatGirlPortrait from '../../assets/chihuahua/9-chihuahua-puppy-cream-long-coat-female-portrait.webp';
import whiteBoyPortrait from '../../assets/chihuahua/10-chihuahua-puppy-white-male-portrait.webp';
import redSableBoyPortrait from '../../assets/chihuahua/11-chihuahua-puppy-red-sable-male-portrait.webp';
import blueFawnGirlPortrait from '../../assets/chihuahua/12-chihuahua-puppy-blue-fawn-female-portrait.webp';
import fawnWhiteGirlPortrait from '../../assets/chihuahua/13-chihuahua-puppy-fawn-white-female-portrait.webp';
import blackWhiteBoyPortrait from '../../assets/chihuahua/14-chihuahua-puppy-black-white-male-portrait.webp';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';

const title = 'Chihuahua Puppy for Sale Singapore | Curious Tails';
const description =
  'Chihuahua puppies for sale in Singapore from $4,288, AVS licensed and HDB-approved. Real prices, temperament, coat types and the $500+ starter kit included. WhatsApp us.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Grooming', href: '#grooming' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'How much does a Chihuahua cost in Singapore?',
    answer:
      'Chihuahua prices in Singapore commonly run from around $2,500 to $6,000 depending on coat, colour, and shop, with "teacup" listings priced higher still. At Curious Tails, Chihuahua puppies are $4,288 to $4,888, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a Chihuahua HDB-approved?',
    answer:
      'Yes. The Chihuahua is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and we complete the dog licensing for you at purchase, so the paperwork is handled.',
  },
  {
    question: 'Can a Chihuahua be left alone while we are at work?',
    answer:
      'Moderately well, and better than most of our companion crosses. Chihuahuas bond hard to their people but carry a certain self-contained streak, so with a settled routine, a safe playpen, and something to do, most handle a working household. The bigger question is socialisation: an under-socialised Chihuahua becomes a yappy one, which is why the free training lesson matters.',
  },
  {
    question: 'How big does a Chihuahua get?',
    answer:
      'The Chihuahua is the smallest dog breed in the world: most reach roughly 1.5 to 3 kg fully grown, standing 15 to 23 cm at the shoulder. That is already tiny; be cautious with anyone advertising a "teacup" Chihuahua below that range, because the health trade-offs are real and no honest seller can guarantee adult size.',
  },
  {
    question: 'Are Chihuahuas good with children?',
    answer:
      'With calm, older children, yes. With boisterous toddlers, honestly, no: at 1.5 to 3 kg a Chihuahua is delicate, and a dropped or squeezed puppy gets hurt. For young families we usually point to the sturdier Cockapoo instead, and we will say so before you buy.',
  },
  {
    question: 'Smooth coat or long coat: what is the difference?',
    answer:
      'Purely grooming and look. The smooth coat needs just a weekly brush; the long coat needs brushing 2 to 3 times a week. Both shed lightly year-round, both come in the full range of Chihuahua colours, and temperament is the same either way.',
  },
  {
    question: 'What happens after I reserve a Chihuahua?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/chihuahua',
    title,
    description,
    aboutName: 'Chihuahua',
    aboutAlternateName: 'Chihuahua dog',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Chihuahua_(dog_breed)',
    datePublished: '2026-07-08',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Chihuahua puppy',
      url: '/puppies/chihuahua',
      description:
        'Chihuahua puppy from an AVS licensed Singapore pet shop, priced $4,288 to $4,888 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '4288',
      image: heroChihuahua.src,
    },
  ]),
  serviceSchema({
    name: 'Chihuahua Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Chihuahua puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Chihuahua',
    description:
      'The Chihuahua is the smallest dog breed in the world, roughly 1.5 to 3 kg, with smooth or long coat varieties in many colours. It is a devoted, alert companion with a big-dog personality and a lifespan of 14 to 16 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Chihuahua_(dog_breed)',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/chihuahua" ogImage="/assets/chihuahua/og-chihuahua.jpg">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Chihuahua Puppies for Sale in Singapore"
    h1Accent="Chihuahua"
    subhead="Chihuahua prices in Singapore commonly run $2,500 to $6,000, and higher for 'teacup' listings. Ours are $4,288 to $4,888, with the $500+ starter kit, free home delivery and setup, and a free first training lesson already in the price."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Chihuahua puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $4,288 all-in. HDB-approved. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'HDB-approved toy breed']}
    imageAlt="Fawn Chihuahua puppy sitting in a set-up playpen at a Balestier home"
    imageSrc={heroChihuahua}
    tagLabel="Chihuahua"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies' }, { label: 'Chihuahua', href: '/puppies/chihuahua' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Chihuahua in Singapore?" imageAlt="Fawn Chihuahua puppy portrait, one of the Chihuahua puppies available in Singapore" imageSrc={fawnBoyPortrait} variant="mid">
      <p>Our Chihuahua puppies in Singapore arrive and are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, coat type, and exact prices for the Chihuahua puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Chihuahua for sale in Singapore here is between $4,288 and $4,888, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Chihuahua puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Chihuahua photos and prices</a>, or meet our Chihuahua puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Chihuahua Puppies"
      headingAccent="Available"
      subhead="A few of the Chihuahua puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Fawn boy', href: whatsappLink('Hi! I\'d like more photos and the price for the fawn male Chihuahua puppy.'), imageAlt: 'Fawn male Chihuahua puppy available in Singapore', imageSrc: fawnBoyPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Black & tan girl', href: whatsappLink('Hi! I\'d like more photos and the price for the black and tan female Chihuahua puppy.'), imageAlt: 'Black and tan female Chihuahua puppy available in Singapore', imageSrc: blackTanGirlPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Chocolate boy', href: whatsappLink('Hi! I\'d like more photos and the price for the chocolate male Chihuahua puppy.'), imageAlt: 'Chocolate male Chihuahua puppy available in Singapore', imageSrc: chocolateBoyPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'Cream long-coat girl', href: whatsappLink('Hi! I\'d like more photos and the price for the cream long-coat female Chihuahua puppy.'), imageAlt: 'Cream long-coat female Chihuahua puppy available in Singapore', imageSrc: creamLongCoatGirlPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'White boy', href: whatsappLink('Hi! I\'d like more photos and the price for the white male Chihuahua puppy.'), imageAlt: 'White male Chihuahua puppy available in Singapore', imageSrc: whiteBoyPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Red sable boy', href: whatsappLink('Hi! I\'d like more photos and the price for the red sable male Chihuahua puppy.'), imageAlt: 'Red sable male Chihuahua puppy available in Singapore', imageSrc: redSableBoyPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '12 weeks' },
        { title: 'Blue fawn girl', href: whatsappLink('Hi! I\'d like more photos and the price for the blue fawn female Chihuahua puppy.'), imageAlt: 'Blue fawn female Chihuahua puppy available in Singapore', imageSrc: blueFawnGirlPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Fawn & white girl', href: whatsappLink('Hi! I\'d like more photos and the price for the fawn and white female Chihuahua puppy.'), imageAlt: 'Fawn and white female Chihuahua puppy available in Singapore', imageSrc: fawnWhiteGirlPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '3 months' },
        { title: 'Black & white boy', href: whatsappLink('Hi! I\'d like more photos and the price for the black and white male Chihuahua puppy.'), imageAlt: 'Black and white male Chihuahua puppy available in Singapore', imageSrc: blackWhiteBoyPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '8 weeks' },
      ]}
    />
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is a Chihuahua?"
      definition="The Chihuahua is the smallest dog breed in the world, roughly 1.5 to 3 kg, with smooth-coat and long-coat varieties in nearly every colour. It is a devoted, alert companion with a famously big-dog personality and a lifespan of 14 to 16 years."
      bridge="Curious Tails is an AVS licensed pet shop at 2 Balestier Road. We match by lifestyle first, and the Chihuahua suits a specific home well: adults or older children who want a devoted, portable companion."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Chihuahua at a glance</p>
        <ul class="mt-4 space-y-3">
          {[
            'The world\'s smallest dog breed',
            'Roughly 1.5 to 3 kg fully grown',
            'Smooth or long coat, nearly every colour',
            'Devoted and alert, with a big-dog attitude',
            '14 to 16 year lifespan',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Sizes vary by line; ask us about a specific puppy's expected adult weight.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Chihuahua from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$4,288', label: 'Chihuahua pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Chihuahua Temperament: A Big Dog in a 2 kg Body" imageAlt="Chihuahua puppy cuddled close on a caregiver's lap at home" imageSrc={companionLap} imagePosition="left">
      <p>Nobody told the Chihuahua it is small. This is a confident, alert, fiercely devoted little dog that picks its people and commits completely. It makes an excellent watchdog for a flat, quick to announce the doorbell, and an even better lap companion once the announcement is made.</p>
      <p>The honest part, from two years of matching puppies to families: a Chihuahua's confidence needs shaping. A well-socialised Chihuahua is charming and portable; an under-socialised one becomes suspicious and yappy. Early, gentle exposure to people and other dogs decides which one you get, and the free first training lesson with an AVS-certified trainer is exactly where that starts.</p>
      <p>With calm older children, a Chihuahua does well. With boisterous toddlers, we say no plainly: at this size, a squeeze or a fall genuinely injures. The sturdier <a href="/puppies/cockapoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cockapoo</a> is the kinder family pick.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Chihuahua Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Moderately well, and honestly better than most toy companions. Chihuahuas bond deeply but keep a self-contained streak: with a safe playpen, a settled routine, and something to work on, most handle a working household's hours once matured into it.</p>
      <p>Two caveats we give every buyer: keep the home routine warm, because a Chihuahua alone AND under-handled turns suspicious; and mind the aircon, because a 2 kg dog chills easily. If your home is empty 8am to 6pm and you want maximum independence, compare the <a href="/puppies/mini-dachshund" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Mini Dachshund</a> before deciding.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'Adults or older children in the home',
            'You want a devoted, portable companion',
            'Small flat; the breed needs little space',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Chihuahua Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers, including the ones the teacup listings skip."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 1.5 to 3 kg; the smallest breed we carry'] },
        { label: 'Height', values: ['Around 15 to 23 cm at the shoulder'] },
        { label: 'Coat', values: ['Two varieties: smooth (weekly brush) and long coat (brush 2 to 3 times a week); colours from fawn and cream to chocolate, black & tan, sable and blue'] },
        { label: 'Lifespan', values: ['14 to 16 years, among the longest of any breed'] },
        { label: 'Exercise', values: ['About 20 to 30 minutes a day, plus indoor play; a flat is genuinely enough space'] },
        { label: 'Shedding & allergies', values: ['Light year-round shedding in both coat types; not a low-shedding breed'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        How big do Chihuahuas get? Not very: 1.5 to 3 kg is the healthy range, and that is precisely why the breed is the number-one target of "teacup" marketing. The 14-to-16-year lifespan is dependable with good care, one more reason to choose health over an unusually tiny size.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Chihuahua Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="Most shops make you WhatsApp them just to learn the number. Here's ours in writing: $4,288 to $4,888, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Chihuahua price commonly $2,500 to $6,000',
            'Price usually not published; enquiry required',
            '"Teacup" and "micro" listings priced at a premium',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$4,288 to $4,888, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and plan the ongoing costs with the <a href="/first-time-owners/budget-guide" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Chihuahua Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Chihuahua leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, small-breed puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For a tiny breed like the Chihuahua, the oral care items and the toy-breed feeding routine matter from day one.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Chihuahua's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Chihuahua Right for Your Lifestyle?"
      subhead="We ask about your routine before recommending any breed. Here's the honest short version for a Chihuahua."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Adults or older children wanting a devoted lap dog', values: ['Ideal. This is the Chihuahua home; the devotion is the whole point'] },
        { label: 'Small flat, modest exercise appetite', values: ['Great fit. A flat is genuinely enough space, and 20 to 30 minutes a day covers it'] },
        { label: 'Working household with a settled routine', values: ['Workable. More self-contained than our companion crosses; socialisation is the real task'] },
        { label: 'Home with boisterous toddlers', values: ['Reconsider. At 1.5 to 3 kg a Chihuahua is delicate; a sturdier Cockapoo is the kinder match'] },
        { label: 'Allergy-sensitive household', values: ['Reconsider. Chihuahuas shed lightly year-round; a Bichon Frise or Maltese is the better pick'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Chihuahua is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my daily routine. Is a Chihuahua the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Chihuahua vs Mini Dachshund: Which Small Character Fits Your Home?" imagePosition="none" variant="dark">
    <p>Both are compact character breeds with proper watchdog voices and light-maintenance coats, which is why buyers often cross-shop them. The honest differences: the Chihuahua is smaller, lighter to carry everywhere, and more of a one-person devotee; the Mini Dachshund is sturdier, more independent, and better with younger children.</p>
    <p>Both announce the doorbell with enthusiasm, and both need early training to keep the announcements brief. With us the price, the starter kit, and the aftercare are identical either way.</p>
    <p>Weighing the two? See our <a href="/puppies/mini-dachshund" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Mini Dachshund puppies</a>, or message us your routine and we'll tell you straight.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
