---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import imgHero from '../../assets/cocker-spaniel/1-cocker-spaniel-puppy-sitting-in-a-set-up-playpen-at-a-s.webp';
import imgScene1 from '../../assets/cocker-spaniel/2-cocker-spaniel-puppy-portrait-one-of-the-cocker-puppies.webp';
import imgScene2 from '../../assets/cocker-spaniel/3-cocker-spaniel-puppy-playing-gently-with-children-in-a.webp';
import imgScene3 from '../../assets/cocker-spaniel/4-cocker-spaniel-having-its-long-ears-and-silky-coat-groo.webp';
import imgScene4 from '../../assets/cocker-spaniel/5-cocker-spaniel-puppy-at-a-veterinary-health-check-befor.webp';
import imgScene5 from '../../assets/cocker-spaniel/6-cocker-spaniel-puppy-settling-into-a-set-up-playpen-dur.webp';
import imgCard1 from '../../assets/cocker-spaniel/7-golden-male-cocker-spaniel-puppy-available-in-singapore.webp';
import imgCard2 from '../../assets/cocker-spaniel/8-black-and-tan-female-cocker-spaniel-puppy-available-in.webp';
import imgCard3 from '../../assets/cocker-spaniel/9-blue-roan-male-cocker-spaniel-puppy-available-in-singap.webp';
import imgCard4 from '../../assets/cocker-spaniel/10-chocolate-female-cocker-spaniel-puppy-available-in-sing.webp';
import imgCard5 from '../../assets/cocker-spaniel/11-golden-female-cocker-spaniel-puppy-available-in-singapo.webp';
import imgCard6 from '../../assets/cocker-spaniel/12-black-male-cocker-spaniel-puppy-available-in-singapore.webp';

const title = 'Cocker Spaniel Singapore | Price & Puppies | Curious Tails';
const description =
  'Cocker Spaniel puppies for sale in Singapore from $4,588 all-in. Honest part first: Cockers are not HDB-approved. The merry medium spaniel, real prices, ear-care truth for our humidity, and the $500+ starter kit.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Ears & Coat', href: '#ears' },
  { label: 'Size', href: '#size' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'Can I keep a Cocker Spaniel in an HDB flat?',
    answer:
      'No. The Cocker Spaniel is a medium-sized sporting breed and is not on the HDB-approved list. Condos and landed homes may keep up to three dogs, subject to the estate\'s own rules, which is where the Cocker belongs in Singapore. HDB readers: our HDB-approved breeds guide maps the approved small breeds and companion crosses that fit both the rules and flat living.',
  },
  {
    question: 'How much does a Cocker Spaniel cost in Singapore?',
    answer:
      'Cocker Spaniel prices in Singapore range widely: pet-shop puppies commonly run $3,000 to $6,000, while show or imported lines are quoted far higher, with enthusiasts citing $6,000 to $15,000. At Curious Tails, Cocker Spaniel puppies are $4,588 to $5,988, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Are Cocker Spaniels good family dogs?',
    answer:
      'Wonderfully so. The "merry Cocker" is affectionate, gentle and sociable, brilliant with children and happy in the thick of family life. The honest notes: they are sensitive dogs that do not enjoy long days alone, and they need a good daily walk and regular grooming. Give them company, exercise and ear care and you have one of the sweetest family companions there is.',
  },
  {
    question: 'Why do Cocker Spaniels get ear infections, and how do I prevent them?',
    answer:
      'Those beautiful long, hairy, low-hanging ears trap heat and moisture, and in Singapore\'s humidity that is the perfect setup for infection. Prevention is simple and non-negotiable: check the ears weekly, keep them clean and dry, dry them thoroughly after any swim or bath, and keep the hair around the ear canal trimmed. Managed this way, ear trouble is the exception, not the rule.',
  },
  {
    question: 'How much exercise and grooming does a Cocker Spaniel need?',
    answer:
      'Around an hour of exercise a day, split across the cool hours, and this sporting breed genuinely enjoys it. Grooming is the bigger commitment: the silky coat needs brushing several times a week and a professional groom every 6 to 8 weeks to stay mat-free, along with the weekly ear routine. Budget for the coat before you buy.',
  },
  {
    question: 'English or American Cocker Spaniel: what is the difference?',
    answer:
      'They are two distinct breeds. The English Cocker Spaniel is a little taller with a longer muzzle and a moderate coat, closer to its working-gundog roots and the type most often seen in Singapore. The American Cocker Spaniel is smaller, with a domed head and a much heavier, longer coat that needs even more grooming. Temperament is similar and merry in both; the practical difference for you is size and coat workload. Ask us which we currently have and we will show you the difference in person.',
  },
  {
    question: 'What happens after I reserve a Cocker Spaniel?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items, including the ear-and-coat routine, before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/cocker-spaniel',
    title,
    description,
    aboutName: 'Cocker Spaniel',
    aboutAlternateName: 'Cocker',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Cocker_Spaniel',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Cocker Spaniel puppy',
      url: '/puppies/cocker-spaniel',
      description:
        'Cocker Spaniel puppy from an AVS licensed Singapore pet shop, priced $4,588 to $5,988 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '4588',
      image: imgHero.src,
    },
  ]),
  serviceSchema({
    name: 'Cocker Spaniel Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Cocker Spaniel puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Cocker Spaniel',
    description:
      'The Cocker Spaniel is a merry medium sporting dog of roughly 12 to 16 kg with a silky coat and long feathered ears. Affectionate and sociable, it is not on Singapore\'s HDB-approved list and suits private housing, with a lifespan of about 12 to 15 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Cocker_Spaniel',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/cocker-spaniel">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Cocker Spaniel Puppies for Sale in Singapore"
    h1Accent="Cocker Spaniel"
    subhead="The honest part first: Cockers are not HDB-approved, so this page is for condo and landed homes. The merry Cocker is one of the sweetest family dogs there is — the catch is the coat and those lovely ears, which need real care in our humidity. Elsewhere Cockers run from about $3,000 at pet shops to $15,000 for show or imported lines; ours are $4,588 to $5,988, all-in and printed."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Cocker Spaniel puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $4,588 all-in. Private housing only. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'Private-housing family breed']}
    imageAlt="Cocker Spaniel puppy sitting in a set-up playpen at a Singapore condo" imageSrc={imgHero}
    tagLabel="Cocker Spaniel"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies/' }, { label: 'Cocker Spaniel', href: '/puppies/cocker-spaniel/' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Cocker Spaniel in Singapore?" imageAlt="Cocker Spaniel puppy portrait, one of the Cocker puppies available in Singapore" imageSrc={imgScene1} variant="mid">
      <p>Our Cocker Spaniel puppies in Singapore are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, colour, and exact prices for the Cocker puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Cocker Spaniel for sale in Singapore here is between $4,588 and $5,988, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Cocker Spaniel puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Cocker photos and prices</a>, or meet our Cocker Spaniel puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Cocker Spaniel Puppies"
      headingAccent="Available"
      subhead="A few of the Cocker puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Golden boy', href: whatsappLink('Hi! I\'d like more photos and the price for the golden male Cocker Spaniel puppy.'), imageAlt: 'Golden male Cocker Spaniel puppy available in Singapore', imageSrc: imgCard1, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Black & tan girl', href: whatsappLink('Hi! I\'d like more photos and the price for the black and tan female Cocker Spaniel puppy.'), imageAlt: 'Black and tan female Cocker Spaniel puppy available in Singapore', imageSrc: imgCard2, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Roan boy', href: whatsappLink('Hi! I\'d like more photos and the price for the roan male Cocker Spaniel puppy.'), imageAlt: 'Blue roan male Cocker Spaniel puppy available in Singapore', imageSrc: imgCard3, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'Chocolate girl', href: whatsappLink('Hi! I\'d like more photos and the price for the chocolate female Cocker Spaniel puppy.'), imageAlt: 'Chocolate female Cocker Spaniel puppy available in Singapore', imageSrc: imgCard4, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Golden girl', href: whatsappLink('Hi! I\'d like more photos and the price for the golden female Cocker Spaniel puppy.'), imageAlt: 'Golden female Cocker Spaniel puppy available in Singapore', imageSrc: imgCard5, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '2 months' },
        { title: 'Black boy', href: whatsappLink('Hi! I\'d like more photos and the price for the black male Cocker Spaniel puppy.'), imageAlt: 'Black male Cocker Spaniel puppy available in Singapore', imageSrc: imgCard6, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '12 weeks' },
      ]}
    />
  </div>

  <div id="hdb" class="relative scroll-mt-40">
    <ScatterFloat />
    <DefBox
      term="Can you keep a Cocker Spaniel in an HDB flat? No"
      definition="The Cocker Spaniel is a medium-sized sporting breed and is not on the HDB-approved breed list. HDB flats may keep one dog of an approved small breed; condos and landed homes may keep up to three dogs, subject to the estate's own rules, which is where the Cocker belongs in Singapore."
      bridge="We tell you this before you fall for the photos. If you love the merry-spaniel character but live in an HDB flat, our HDB-approved breeds guide maps the approved small breeds and companion crosses that fit both the rules and flat living. Private housing readers: carry on, the rest of this page is yours."
      citationLabel="Read HDB's guidelines on keeping pets"
      citationHref="https://www.hdb.gov.sg/managing-my-home/home-ownership/keeping-pets"
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The housing rules, straight</p>
        <ul class="mt-4 space-y-3">
          {[
            'HDB flat: Cocker Spaniel not approved',
            'Condo / landed: up to three dogs (AVS limits of ownership)',
            'HDB readers: see the approved alternatives guide below',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">
          Source: <a href="https://avs.nparks.gov.sg/pets/licensing-a-pet/information-on-dog-and-cat-licences/limits-of-ownership/" class="underline underline-offset-2">AVS limits of ownership</a> · Full list: <a href="/first-time-owners/hdb-breeds/" class="underline underline-offset-2">HDB-approved breeds guide</a>
        </p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Cocker Spaniel from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$4,588', label: 'Cocker pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Cocker Spaniel Temperament: The Merry Family Dog" imageAlt="Cocker Spaniel puppy playing gently with children in a garden" imageSrc={imgScene2} imagePosition="left">
      <p>The Cocker earned its nickname honestly: the "merry Cocker" is cheerful, affectionate and sociable to its core, with a perpetually wagging tail and a soft spot for its people. Gentle with children, friendly with strangers and other dogs, and eager to please, it is a sporting breed with a companion's heart, and one of the loveliest family dogs a private-housing home can choose.</p>
      <p>The honest footnotes, from two years of matching families to dogs. First, this is a sensitive, people-oriented breed that does not thrive left alone all week; it wants to be with you. Second, the sporting heritage is real, so a proper daily walk is part of the deal, not a nice-to-have. Third, the grooming and ear care below are the true ongoing commitment, and the reason some owners underestimate the breed.</p>
      <p>Give a Cocker company, exercise and consistent grooming, and you get a devoted, joyful shadow for a decade and more.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Cocker Spaniel Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Less happily than many breeds, and honesty matters here. Cockers are sensitive and companionable, and long daily isolation can lead to separation anxiety in this breed more than most. A midday walker, a puzzle toy, and evenings that genuinely belong to the dog make all the difference; a home that is empty from morning to night most days should think carefully.</p>
      <p>The room needs the usual tropical basics — ventilation, shade, water — and the exercise and grooming routines below decide the rest.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'Private housing and a sociable, present family',
            'Someone is around much of the day, or a midday walker',
            'You will keep up the coat and weekly ear care',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="ears" class="scroll-mt-40">
    <CaptionedBlock heading="Those Ears and That Coat: Care in Our Humidity" imageAlt="Cocker Spaniel having its long ears and silky coat groomed" imageSrc={imgScene3} imagePosition="left">
      <p>The Cocker's long, feathered, low-hanging ears are its signature and its weak spot. In Singapore's humidity they trap heat and moisture beautifully, which is exactly what an ear infection needs to take hold, so this breed's owners learn one weekly habit early: lift the ear, check and clean, keep the canal hair trimmed, and dry the ears thoroughly after every swim or bath. It takes minutes and prevents the single most common Cocker vet visit.</p>
      <p>The silky coat is the other commitment. It needs brushing several times a week to stay mat-free, especially the feathering on the ears, legs and belly, and a professional groom every 6 to 8 weeks. None of it is hard, but all of it is regular, and owners who plan for it enjoy the breed at its best. It is why the brush and the ear cleaner are among the working tools in the starter kit.</p>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Cocker Spaniel Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for a merry medium sporting breed."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 12 to 16 kg; a compact, sturdy medium dog'] },
        { label: 'Height', values: ['Around 38 to 43 cm at the shoulder'] },
        { label: 'Coat', values: ['Silky, feathered; solid gold, black, chocolate, or roan and parti-colours'] },
        { label: 'Lifespan', values: ['About 12 to 15 years with good weight and ear care'] },
        { label: 'Exercise', values: ['Around an hour daily in the cool hours; a keen, happy walker'] },
        { label: 'Grooming', values: ['Brush several times a week; professional groom every 6 to 8 weeks; weekly ear care'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        A Cocker settles happily into a condo, provided the daily walk is real and the grooming routine is kept. This is a companionship-and-care breed, not a space-hungry one.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Cocker Spaniel Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="The market runs from about $3,000 at pet shops to $15,000 for show or imported lines. Here's ours in writing: $4,588 to $5,988, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Cocker price $3,000 to $6,000 at pet shops, up to $15,000 for show lines',
            'Sought-after colours quoted higher',
            'Inclusions rarely spelt out',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$4,588 to $5,988, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and factor the ongoing grooming cost with the <a href="/first-time-owners/budget-guide/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Cocker Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Cocker Spaniel leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this breed the brush and the ear cleaner are the tools that earn their keep, and on delivery day we show you the weekly ear-and-coat routine hands-on.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Cocker's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Cocker Spaniel Right for Your Lifestyle?"
      subhead="We ask about your housing, your company at home and your grooming appetite before your heart gets a vote. Here's the honest short version."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Private housing, present family, daily walker', values: ['Ideal. This is the merry family shadow at its very best'] },
        { label: 'Home with company most of the day', values: ['Great fit. Cockers give back every bit of the attention they get'] },
        { label: 'HDB flat', values: ['Not eligible. See the HDB-approved breeds guide for genuine alternatives'] },
        { label: 'Out from morning to night most days', values: ['Reconsider. This sensitive breed is prone to separation anxiety'] },
        { label: 'No time or budget for grooming', values: ['Reconsider. The coat and ears need regular, non-negotiable care'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Cocker is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your housing type and daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my housing type and daily routine. Is a Cocker Spaniel the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <div id="health" class="scroll-mt-40">
    <CaptionedBlock heading="Cocker Spaniel Health: What We Check and What to Watch" imageAlt="Cocker Spaniel puppy at a veterinary health check before going home" imageSrc={imgScene4} variant="mid">
      <p>Every Cocker goes home vet-checked, vaccinated, dewormed, and microchipped. The breed's watch-points are well known and mostly manageable: ears first and foremost, for the humidity reasons above; eyes, where the breed can carry a few hereditary conditions worth a vet's routine check; and weight, because a merry Cocker will happily eat its way to problems if portions aren't controlled. Keep the ears clean, the eyes checked and the waistline honest, and most Cockers live long, cheerful lives.</p>
      <p>Feeding is simple: your puppy comes with the food it is already eating, portioned for its size, and any change should be gradual over a week. See the <a href="/learn/puppy-health/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">puppy health checks explained</a> guide.</p>
    </CaptionedBlock>
  </div>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <CaptionedBlock heading="Your Cocker Spaniel's First Week at Home" imageAlt="Cocker Spaniel puppy settling into a set-up playpen during its first week home" imageSrc={imgScene5} imagePosition="left">
    <p>Day 0: we deliver, free, at a time that suits you. The playpen, bed, water, and toys are set up before your Cocker explores the room, and we walk you through all 30+ starter-kit items in person, including the ear-and-coat routine. Learn more about <a href="/delivery/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">how our free home delivery and setup works</a>.</p>
    <p>Days 1 to 3: keep it calm. A fixed feeding routine with measured portions, the toilet pads where we placed them, and gentle play that helps your puppy settle into its new room.</p>
    <p>Days 4 to 7: the routine sticks, and now is the time to build good habits. Book your free first lesson with an AVS-certified trainer, and start short, positive handling of the ears and coat so your Cocker grows up loving the grooming it will need for life. See <a href="/free-training/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">what the free AVS-certified training lesson covers</a>.</p>
  </CaptionedBlock>

