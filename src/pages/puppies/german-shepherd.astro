        { label: 'First-time owner, willing to learn and commit', values: ['Workable with our free training and honest guidance; go in eyes open'] },
        { label: 'HDB flat', values: ['Not eligible, full stop. See the HDB-approved breeds guide for alternatives'] },
        { label: 'Uncomfortable with the leash-and-muzzle rule', values: ['Reconsider honestly. It is the law here and part of daily life'] },
        { label: 'Sedentary household, no time to train', values: ['Reconsider. A bored, untrained Shepherd is a large, clever problem'] },
