---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import imgHero from '../../assets/golden-retriever/1-golden-retriever-puppy-sitting-in-a-set-up-playpen-at-a.webp';
import imgScene1 from '../../assets/golden-retriever/2-golden-retriever-puppy-portrait-one-of-the-golden-puppi.webp';
import imgScene2 from '../../assets/golden-retriever/3-golden-retriever-puppy-playing-gently-with-children-in.webp';
import imgScene3 from '../../assets/golden-retriever/4-golden-retriever-on-a-morning-walk-along-a-park-connect.webp';
import imgScene4 from '../../assets/golden-retriever/5-golden-retriever-having-its-double-coat-brushed-with-an.webp';
import imgScene5 from '../../assets/golden-retriever/6-golden-retriever-puppy-at-a-veterinary-health-check-bef.webp';
import imgScene6 from '../../assets/golden-retriever/7-golden-retriever-puppy-settling-into-a-set-up-playpen-d.webp';
import imgCard1 from '../../assets/golden-retriever/8-golden-male-golden-retriever-puppy-available-in-singapo.webp';
import imgCard2 from '../../assets/golden-retriever/9-cream-female-golden-retriever-puppy-available-in-singap.webp';
import imgCard3 from '../../assets/golden-retriever/10-deep-gold-male-golden-retriever-puppy-available-in-sing.webp';
import imgCard4 from '../../assets/golden-retriever/11-light-golden-female-golden-retriever-puppy-available-in.webp';
import imgCard5 from '../../assets/golden-retriever/12-golden-female-golden-retriever-puppy-available-in-singa.webp';
import imgCard6 from '../../assets/golden-retriever/13-cream-male-golden-retriever-puppy-available-in-singapor.webp';

const title = 'Golden Retriever Puppy for Sale Singapore | Curious Tails';
const description =
  'Golden Retriever puppies for sale in Singapore from $4,588 all-in. Honest part first: Goldens are not HDB-approved. Real prices, exercise reality, heat care and the $500+ starter kit.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Exercise', href: '#exercise' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'Can I keep a Golden Retriever in an HDB flat?',
    answer:
      'No. The Golden Retriever is not on the HDB-approved breed list at any weight, and we won\'t pretend otherwise. Condos and landed homes may keep up to three dogs, so a Golden is very much on the table there. HDB readers: our HDB-approved breeds guide maps the approved alternatives, from the Sheltie\'s trainable family brain to the low-shedding companion crosses.',
  },
  {
    question: 'How much does a Golden Retriever cost in Singapore?',
    answer:
      'Golden Retriever prices in Singapore commonly run $3,000 to $8,000, usually quoted only on enquiry and rarely with inclusions spelt out. At Curious Tails, Golden Retriever puppies are $4,588 to $5,500, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a condo big enough for a Golden Retriever?',
    answer:
      'Usually yes, and the honest reason surprises people: floor area matters far less than the exercise contract. A Golden that gets its genuine 60+ minutes of daily outdoor exercise is calm in a 90-square-metre condo; a Golden that doesn\'t is destructive in a bungalow. Judge your routine, not your floor plan.',
  },
  {
    question: 'How much exercise does a Golden need in our heat?',
    answer:
      'A genuine hour a day minimum, split across the cool hours: a proper walk before 9am and another after 6pm, never midday exertion. Swimming is the perfect Singapore pressure valve for this water-loving breed — dog pools and dog-friendly beaches let a Golden burn energy without the heat load.',
  },
  {
    question: 'Do Golden Retrievers shed badly?',
    answer:
      'Honestly, yes: the golden double coat sheds year-round and blows twice a year in serious volume. Brushing 3 to 4 times a week (daily during blows) keeps it managed, and one rule is absolute in our climate: never shave a double coat — it insulates against heat as well as cold, and shaving damages regrowth. Allergy-sensitive homes should look at the Goldendoodle instead.',
  },
  {
    question: 'Do Goldens cope with Singapore\'s climate?',
    answer:
      'Yes, with discipline. Thousands of Goldens live happily here on three habits: exercise in the cool hours only, a well-brushed (never shaved) coat, and water always available with shade on every outing. It is more work than a small short-coated breed, and worth saying so before you buy.',
  },
  {
    question: 'What happens after I reserve a Golden Retriever?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/golden-retriever',
    title,
    description,
    aboutName: 'Golden Retriever',
    aboutAlternateName: 'Golden',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Golden_Retriever',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Golden Retriever puppy',
      url: '/puppies/golden-retriever',
      description:
        'Golden Retriever puppy from an AVS licensed Singapore pet shop, priced $4,588 to $5,500 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '4588',
    },
  ]),
  serviceSchema({
    name: 'Golden Retriever Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Golden Retriever puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Golden Retriever',
    description:
      'The Golden Retriever is a large gundog of roughly 25 to 34 kg with a golden double coat and the temperament that made it the world\'s benchmark family dog: gentle, eager to please, endlessly social. It is not on Singapore\'s HDB-approved list and suits private housing, with a lifespan of 10 to 12 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Golden_Retriever',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/golden-retriever">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Golden Retriever Puppies for Sale in Singapore"
    h1Accent="Golden Retriever"
    subhead="The honest part first: Goldens are not HDB-approved, so this page is for condo and landed homes — HDB readers, the approved alternatives are one link away. Golden prices here run $3,000 to $8,000 behind enquiry forms; ours are $4,588 to $5,500, with the $500+ starter kit, free delivery and setup, and a free first training lesson included."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Golden Retriever puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $4,588 all-in. Private housing only. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'Private-housing family breed']}
    imageAlt="Golden Retriever puppy sitting in a set-up playpen at a Singapore condo" imageSrc={imgHero}
    tagLabel="Golden Retriever"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies' }, { label: 'Golden Retriever', href: '/puppies/golden-retriever' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Golden Retriever in Singapore?" imageAlt="Golden Retriever puppy portrait, one of the Golden puppies available in Singapore" imageSrc={imgScene1} variant="mid">
      <p>Our Golden Retriever puppies in Singapore arrive and are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, coat shade, and exact prices for the Golden puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Golden Retriever for sale in Singapore here is between $4,588 and $5,500, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready — a genuine help if you're mid-renovation.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Golden Retriever puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Golden photos and prices</a>, or meet our Golden Retriever puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Golden Retriever Puppies"
      headingAccent="Available"
      subhead="A few of the Golden puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Golden boy', href: whatsappLink('Hi! I\'d like more photos and the price for the golden male Golden Retriever puppy.'), imageAlt: 'Golden male Golden Retriever puppy available in Singapore', imageSrc: imgCard1, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Cream girl', href: whatsappLink('Hi! I\'d like more photos and the price for the cream female Golden Retriever puppy.'), imageAlt: 'Cream female Golden Retriever puppy available in Singapore', imageSrc: imgCard2, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Deep gold boy', href: whatsappLink('Hi! I\'d like more photos and the price for the deep gold male Golden Retriever puppy.'), imageAlt: 'Deep gold male Golden Retriever puppy available in Singapore', imageSrc: imgCard3, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'Light golden girl', href: whatsappLink('Hi! I\'d like more photos and the price for the light golden female Golden Retriever puppy.'), imageAlt: 'Light golden female Golden Retriever puppy available in Singapore', imageSrc: imgCard4, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Golden girl', href: whatsappLink('Hi! I\'d like more photos and the price for the golden female Golden Retriever puppy.'), imageAlt: 'Golden female Golden Retriever puppy available in Singapore', imageSrc: imgCard5, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '2 months' },
        { title: 'Cream boy', href: whatsappLink('Hi! I\'d like more photos and the price for the cream male Golden Retriever puppy.'), imageAlt: 'Cream male Golden Retriever puppy available in Singapore', imageSrc: imgCard6, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '12 weeks' },
      ]}
    />
  </div>

  <div id="hdb" class="relative scroll-mt-40">
    <ScatterFloat />
    <DefBox
      term="Can you keep a Golden Retriever in an HDB flat? No"
      definition="The Golden Retriever is not on the HDB-approved breed list, at any weight or age, and no licensing route changes that. HDB flats may keep one dog of an approved small breed; condos and landed homes may keep up to three dogs, subject to the estate's own rules, which is where the Golden belongs in Singapore."
      bridge="We tell you this before you fall for the photos, because more Singaporeans search for this breed than any other and most live in flats. If that's you, our HDB-approved breeds guide maps the genuine alternatives, and the Sheltie deserves special mention: a trainable, family-devoted brain that IS on the list. Private housing readers: carry on, the rest of this page is yours."
      citationLabel="Read HDB's guidelines on keeping pets"
      citationHref="https://www.hdb.gov.sg/managing-my-home/home-ownership/keeping-pets"
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The housing rules, straight</p>
        <ul class="mt-4 space-y-3">
          {[
            'HDB flat: Golden not approved, no exceptions we can promise',
            'Condo / landed: up to three dogs (AVS limits of ownership)',
            'HDB readers: see the approved alternatives guide below',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">
          Source: <a href="https://avs.nparks.gov.sg/pets/licensing-a-pet/information-on-dog-and-cat-licences/limits-of-ownership/" class="underline underline-offset-2">AVS limits of ownership</a> · Full list: <a href="/first-time-owners/hdb-breeds" class="underline underline-offset-2">HDB-approved breeds guide</a>
        </p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Golden from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$4,588', label: 'Golden pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Golden Temperament: The Benchmark, Honestly Footnoted" imageAlt="Golden Retriever puppy playing gently with children in a garden" imageSrc={imgScene2} imagePosition="left">
      <p>Every family-dog list on earth starts here, and the reputation is earned: gentle with children, eager to please, quick to train, sociable with everything that breathes. The Golden doesn't guard, doesn't hold grudges, and treats every visitor as a long-lost friend. If your picture of "family dog" came from a movie, it was probably this breed.</p>
      <p>The honest footnotes, from two years of matching families to dogs: first, the calm adult Golden everyone falls for takes about two years to arrive, and the puppy that precedes it is thirty kilograms of boisterous enthusiasm that needs training from week one. Second, this is a deeply social breed: it wants to be part of family life, not decoration for it, and homes where the dog would be alone and unengaged most of the week should choose differently. Third, the exercise section below is not optional reading.</p>
      <p>Want the temperament with a low-shedding coat? That's the <a href="/puppies/goldendoodle" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Goldendoodle</a>, honestly compared further down.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Golden Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Moderately, once mature and provided the mornings and evenings genuinely belong to the dog. A well-exercised adult Golden naps through a workday contentedly; an under-exercised or under-included one redecorates. The breed's sociability means weekends and evenings are the contract: this is a dog for families who want a dog in the family.</p>
      <p>The room needs the usual tropical basics, ventilation, shade, water, and the exercise contract below decides everything else.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'Private housing and an active family',
            'Someone walks daily, mornings and evenings',
            'You want the classic family all-rounder',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="exercise" class="scroll-mt-40">
    <CaptionedBlock heading="The Exercise Contract: An Hour a Day, in Our Heat" imageAlt="Golden Retriever on a morning walk along a park connector" imageSrc={imgScene3} imagePosition="left">
      <p>Here's the section no listing writes and every Golden owner lives. This breed needs a genuine hour of daily exercise, minimum, for a decade, and in Singapore that hour has rules: a proper walk before 9am, another after 6pm, and never hard exertion in the midday furnace. Under-exercise a Golden and the surplus converts directly into chewed furniture, weight gain, and a dog too big to ignore being bored.</p>
      <p>The good news is uniquely Golden: this breed loves water the way it loves food, and swimming is the perfect tropical pressure valve. Dog pools and dog-friendly stretches of beach let a Golden burn an hour's energy in twenty cool minutes, and a swimming Golden is the happiest animal in Singapore. Budget for it; it's cheaper than a new sofa.</p>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Golden Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for a genuinely large dog."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 25 to 34 kg; this is a large dog, lean or not'] },
        { label: 'Height', values: ['Around 51 to 61 cm at the shoulder'] },
        { label: 'Coat', values: ['Golden double coat, cream through deep gold; feathering on legs and tail'] },
        { label: 'Lifespan', values: ['10 to 12 years with good weight and health care'] },
        { label: 'Exercise', values: ['60+ minutes daily in the cool hours, for life; swimming strongly recommended'] },
        { label: 'Shedding & allergies', values: ['Heavy: year-round shedding plus two serious blows. The wrong breed for allergy-sensitive homes'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        On condo space, the honest answer: floor area matters less than the exercise contract. A properly exercised Golden is calm in 90 square metres; an under-exercised one is destructive in a bungalow. Judge your routine, not your floor plan.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Golden Retriever Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="The market runs $3,000 to $8,000 behind enquiry forms. Here's ours in writing: $4,588 to $5,500, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Golden price commonly $3,000 to $8,000',
            'Price usually not published; enquiry required',
            'Inclusions rarely spelt out',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$4,588 to $5,500, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and plan the ongoing costs, which for a large breed deserve real budgeting, with the <a href="/first-time-owners/budget-guide" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Golden Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Golden Retriever leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this breed the brush and the leash are the working tools, both will see daily use for a decade, and on delivery day we talk through large-breed feeding: controlled growth in the first year protects those hips for life.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Golden's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Golden Right for Your Lifestyle?"
      subhead="We ask about your housing and your mornings before your heart gets a vote. Here's the honest short version."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Private housing, active family, daily walker', values: ['Ideal. This is what the world\'s favourite family dog was made for'] },
        { label: 'Condo with pool/park access nearby', values: ['Great fit, if the exercise hour is real. Space matters less than routine'] },
        { label: 'HDB flat', values: ['Not eligible, full stop. See the HDB-approved breeds guide for genuine alternatives'] },
        { label: 'Sedentary household, no daily walker', values: ['Reconsider honestly. An under-exercised Golden is a big, bored problem'] },
        { label: 'Allergy-sensitive household', values: ['Reconsider. The shedding is heavy and constant; the Goldendoodle is the low-shed remix'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Golden is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your housing type and daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my housing type and daily routine. Is a Golden Retriever the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Golden Retriever vs Goldendoodle: Original or Low-Shed Remix" imagePosition="none" variant="dark">
    <p>The most natural cross-shop on this page: same golden warmth, one crucial coat difference. The purebred Golden gives you complete predictability, the temperament, the look, the water-love, all guaranteed, and pays for it in hair: heavy shedding, twice-yearly blows, a vacuum on retainer. The <a href="/puppies/goldendoodle" class="underline underline-offset-2">Goldendoodle</a> trades a little predictability (crosses vary) for a low-shedding coat that swaps the vacuum for a salon schedule.</p>
    <p>Both are private-housing breeds in Singapore, both need the same real exercise, and with us the price, the starter kit, and the aftercare are identical. Allergies or hair-free floors point to the doodle; benchmark predictability points to the original; the <a href="/puppies/labradoodle" class="underline underline-offset-2">Labradoodle</a> rounds out the trio.</p>
    <p>Message us your priorities and we'll tell you straight which fits.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
