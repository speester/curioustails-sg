---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import ValueBundle from '../../components/ValueBundle.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  faqPageSchema,
  itemListSchema,
} from '../../lib/schema';
import heroCavapoo from '../../assets/cavapoo/1-cavapoo-puppy-hero-playpen-balestier.webp';
import cavapooPortrait from '../../assets/cavapoo/2-cavapoo-puppy-portrait-available.webp';
import maltipooPortrait from '../../assets/maltipoo/3-maltipoo-puppy-portrait-available.webp';
import dachshundPortrait from '../../assets/mini-dachshund/2-mini-dachshund-red-smooth-portrait.webp';
import corgiPortrait from '../../assets/corgi/2-corgi-red-white-portrait.webp';
import shibaPortrait from '../../assets/shiba-inu/2-shiba-red-portrait.webp';
import bichonpooPortrait from '../../assets/bichonpoo/2-bichonpoo-white-portrait.webp';
import cockapooPortrait from '../../assets/cockapoo/2-cockapoo-apricot-portrait.webp';

const title = 'Our Puppy Breeds | 7 Breeds, One Honest Match | Curious Tails';
const description =
  'Cavapoo to Corgi: browse the 7 puppy breeds at Curious Tails Singapore, each $2,888 to $4,488 all-in. HDB status, lifestyle fit, and honest matching advice.';

const breeds = [
  { title: 'Cavapoo', href: '/puppies/cavapoo', imageSrc: cavapooPortrait, imageAlt: 'Cavapoo puppy, an HDB-approved independent companion breed in Singapore', meta: 'HDB-approved. The independent one: best pick for working couples.', tag: 'HDB ✓' },
  { title: 'Maltipoo', href: '/puppies/maltipoo', imageSrc: maltipooPortrait, imageAlt: 'Maltipoo puppy, an HDB-approved companion breed that thrives on company', meta: 'HDB-approved. Affectionate and people-focused; happiest with company at home.', tag: 'HDB ✓' },
  { title: 'Mini Dachshund', href: '/puppies/mini-dachshund', imageSrc: dachshundPortrait, imageAlt: 'Mini Dachshund puppy, an HDB-approved bold small hound in Singapore', meta: 'HDB-approved. Bold little hound; independent, with a proper watchdog bark.', tag: 'HDB ✓' },
  { title: 'Cockapoo', href: '/puppies/cockapoo', imageSrc: cockapooPortrait, imageAlt: 'Cockapoo puppy, an HDB-approved family-friendly cross in Singapore', meta: 'HDB-approved. The family all-rounder; kindest pick for first-time owners.', tag: 'HDB ✓' },
  { title: 'Bichonpoo', href: '/puppies/bichonpoo', imageSrc: bichonpooPortrait, imageAlt: 'Bichonpoo puppy, an HDB-approved low-shedding playful cross in Singapore', meta: 'HDB-approved. Low-shedding sunshine; wants people around during the day.', tag: 'HDB ✓' },
  { title: 'Corgi', href: '/puppies/corgi', imageSrc: corgiPortrait, imageAlt: 'Corgi puppy, a herding breed for private housing in Singapore (not HDB-approved)', meta: 'NOT HDB-approved. Big personality, real energy; condos and landed homes.', tag: 'Private housing' },
  { title: 'Shiba Inu', href: '/puppies/shiba-inu', imageSrc: shibaPortrait, imageAlt: 'Shiba Inu puppy, an independent breed for private housing in Singapore (not HDB-approved)', meta: 'NOT HDB-approved. Independent and cat-clean; condos and landed homes.', tag: 'Private housing' },
];

const faqItems = [
  {
    question: 'Which breeds does Curious Tails carry?',
    answer:
      'Seven: Cavapoo, Maltipoo, Mini Dachshund, Cockapoo, Bichonpoo, Corgi, and Shiba Inu. All sit in the same published price range of $2,888 to $4,488, with the $500+ starter kit, free delivery and setup, and a free training lesson included.',
  },
  {
    question: 'Which of your breeds are HDB-approved?',
    answer:
      'Cavapoo, Maltipoo, Mini Dachshund, Cockapoo, and Bichonpoo: yes. Corgi and Shiba Inu: no, they are not on the HDB-approved list and suit condos and landed homes only. We flag this on every breed card because finding out after falling in love is the worst order of operations.',
  },
  {
    question: 'Which breed suits a working couple best?',
    answer:
      'The independent ones: Cavapoo and Mini Dachshund for HDB homes, Shiba Inu for private housing. Maltipoo and Bichonpoo thrive on company and find an empty 8am to 6pm home hard; we will say so before you buy.',
  },
  {
    question: 'Do all breeds cost the same?',
    answer:
      'All seven sit inside the same published range, $2,888 to $4,488 all-in. The exact figure for an individual puppy depends on its coat, colour, and age, which is why we quote per puppy on WhatsApp.',
  },
  {
    question: 'Can you help us choose between breeds?',
    answer:
      'That is the whole point of how we sell. Message us your daily routine and housing type, or take the two-minute breed selector, and we will tell you straight, including which breed not to get. We have talked customers out of the wrong breed before, and it earned us reviews, not complaints.',
  },
  {
    question: 'Can we meet the breeds in person before deciding?',
    answer:
      'Yes, at 2 Balestier Road #01-701, weekdays 12pm to 6pm and weekends 10am to 6pm. WhatsApp first so we can have the right puppies ready for the breeds you are considering.',
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies',
    title,
    description,
    aboutName: 'Puppy breeds in Singapore',
    aboutAlternateName: 'dog breeds Singapore',
    datePublished: '2026-07-06',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema(breeds.map((b) => ({
    name: `${b.title} puppy`,
    url: b.href,
    description: b.meta,
    price: '2888',
  }))),
  faqPageSchema(faqItems),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies" ogImage="/assets/cavapoo/og-cavapoo.jpg">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Cavapoo to Corgi: Choose Your Perfect Puppy"
    h1Accent="Perfect Puppy"
    subhead="Seven breeds, one published price range of $2,888 to $4,488 all-in, and one rule that never changes: we match the breed to your routine, not to the photo you fell for. HDB status is flagged on every card below."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'm choosing between breeds. Here's my routine and housing type:"
    secondaryCtaLabel="Browse the 7 breeds"
    secondaryCtaHref="#breeds"
    priceAnchor="Every breed: $2,888 to $4,488, kit, delivery and training included."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, '2+ years in Balestier']}
    imageAlt="Puppy breeds Singapore: Cavapoo puppy in a set-up playpen, one of seven breeds at Curious Tails"
    imageSrc={heroCavapoo}
    tagLabel="7 breeds"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies' }]} />
  </Hero>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="How do you choose a puppy breed in Singapore?"
      definition="Three questions decide it: is the breed HDB-approved if you live in a flat, how many hours will the dog be alone on a normal weekday, and how much grooming and exercise genuinely fit your week. The right breed is the one that fits your answers, not the one with the best photos."
      bridge="Every breed card below carries its HDB status and its honest fit line. Answer the three questions, then let the cards disagree with you if they need to."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The 3 questions</p>
        <ul class="mt-4 space-y-3">
          {[
            '1. HDB flat? Then only approved breeds',
            '2. Alone 8am to 6pm? Then the independent breeds',
            '3. Grooming and walks: what really fits your week?',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Shortcut: the <a href="/first-time-owners/breed-selector" class="underline underline-offset-2">two-minute breed selector</a> asks these for you.</p>
      </div>
    </DefBox>
  </div>

  <div id="breeds" class="scroll-mt-40">
    <ListingGrid
      heading="The Seven Breeds We Carry"
      headingAccent="Seven Breeds"
      subhead="Every card links to the full honest profile: temperament, real prices, HDB rules, and the parts other listings leave out."
      items={breeds}
      footerCtaLabel="Not sure which fits? Take the 2-minute quiz"
      footerCtaHref="/first-time-owners/breed-selector"
    />
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Same promise, whichever breed"
    stats={[
      { value: '7', label: 'breeds, honestly matched' },
      { value: '$2,888', label: 'every breed starts here, all-in' },
      { value: '$500+', label: 'starter kit with every puppy' },
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <ComparisonSplit
    heading="Match by Your Day, Not the Photo"
    headingAccent="Your Day"
    subhead="Two years of placements distilled into one honest table."
    mode="table"
    tableHeaders={['Your situation', 'Start with']}
    rows={[
      { label: 'Working couple, out 8am to 6pm, HDB flat', values: ['Cavapoo or Mini Dachshund; both handle alone time with a settled routine'] },
      { label: 'Someone home most of the day', values: ['Maltipoo or Bichonpoo; they thrive on exactly that company'] },
      { label: 'Family with young children', values: ['Cockapoo first, Cavapoo close second; both meet kids halfway'] },
      { label: 'First dog, want the forgiving option', values: ['Cockapoo; eager to please and kind to beginner mistakes'] },
      { label: 'Private housing, active outdoor routine', values: ['Corgi for engagement, Shiba Inu for independence'] },
      { label: 'Allergy-sensitive household', values: ['Bichonpoo, Maltipoo, or Cavapoo; low-shedding, though no dog is allergen-free'] },
    ]}
  />

  <div id="hdb-check" class="scroll-mt-40">
    <ComparisonSplit
      heading="HDB Quick Check"
      headingAccent="Quick Check"
      subhead="The rule we flag before anything else."
      mode="table"
      tableHeaders={['Breed', 'HDB flat']}
      rows={[
        { label: 'Cavapoo', values: ['Yes, approved cross'] },
        { label: 'Maltipoo', values: ['Yes, approved cross'] },
        { label: 'Mini Dachshund', values: ['Yes, approved breed'] },
        { label: 'Cockapoo', values: ['Yes, approved cross'] },
        { label: 'Bichonpoo', values: ['Yes, approved cross'] },
        { label: 'Corgi', values: ['No; private housing only'] },
        { label: 'Shiba Inu', values: ['No; private housing only'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        The full rules, the one-dog-per-flat limit, and what to do if your heart is set on a non-approved breed are in the <a href="/first-time-owners/hdb-breeds" class="underline underline-offset-2 text-[var(--color-accent-hover)]">HDB-approved dog breeds guide</a>.
      </p>
    </div>
  </div>

  <PawTrail bg="bg-[var(--color-surface)]" colorClass="text-[var(--color-coral-300)]" />

  <ValueBundle
    eyebrow="Included with every breed"
    heading="What every puppy comes with"
    headingAccent="every puppy"
    subhead="The price on every card is the full price, whichever breed you choose. Details on the transparent pricing page."
    items={[
      {
        icon: 'kit',
        title: '$500+ Starter Kit',
        body: 'Over 30 items across eight categories, from playpen to toys, delivered with your puppy and explained item by item.',
        highlight: '30+ items',
      },
      {
        icon: 'delivery',
        title: 'Free Delivery & Setup',
        body: 'Island-wide, scheduled around you, with the playpen set up before your puppy explores the room.',
        highlight: 'Free',
      },
      {
        icon: 'training',
        title: 'Free Training Lesson',
        body: 'A first lesson with an AVS-Accredited Certified Dog Trainer, booked into week one while the routine forms.',
        highlight: 'AVS-certified',
      },
    ]}
  />
  <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-4 pb-10">
    <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
      Full inclusions, market comparisons, and the deposit-to-homecoming process: <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing</a>.
    </p>
  </div>

  <BannerRibbon
    heading="Still torn between two breeds?"
    body="Message us your daily routine and housing type. We'll tell you straight, including which breed not to get. It's how we work."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'm torn between two breeds. Here's my routine and housing:"
    variant="dark"
  />

  <div id="faq" class="scroll-mt-40">
    <FAQ heading="Breed Questions, Answered" items={faqItems} />
  </div>

  <FinalCta
    breed="Puppy"
    heading="Meet All Seven at Balestier"
    body="Can't make the trip? WhatsApp us which breeds you're considering and we'll send current photos and prices for each."
    reserveMessage="Hi! I'd like to ask about your available puppies across breeds."
  />

  <Schema {schemas} />
</BaseLayout>
