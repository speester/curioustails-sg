    points: ['Husky looks at half the scale', 'Playful, energetic and vocal', 'Size varies; double coat', 'Not HDB-approved — private housing'],
  },
  {
    title: 'Beagle', href: '/puppies/beagle/', imageSrc: beagleCard, imageAlt: 'Beagle puppy, a merry scent hound for private housing in Singapore (not HDB-approved)',
    meta: 'The merry nose on legs; friendly and food-driven', ctaLabel: 'View Breed',
    points: ['Merry, friendly scent hound', 'Food-motivated and vocal', 'Needs daily exercise', 'Not HDB-approved — private housing'],
  },
  {
    title: 'Cocker Spaniel', href: '/puppies/cocker-spaniel/', imageSrc: cockerSpanielCard, imageAlt: 'Cocker Spaniel puppy, a merry medium spaniel for private housing in Singapore (not HDB-approved)',
    meta: 'Merry medium spaniel; sociable and silky-coated', ctaLabel: 'View Breed',
    points: ['Merry, affectionate medium spaniel', 'Silky coat; needs regular ear care', 'Sociable and active', 'Not HDB-approved — private housing'],
  },
  {
    title: 'English Bulldog', href: '/puppies/english-bulldog/', imageSrc: englishBulldogCard, imageAlt: 'English Bulldog puppy, a gentle heavyweight breed for private housing in Singapore (not HDB-approved)',
    meta: 'The gentle heavyweight; strict heat care needed', ctaLabel: 'View Breed',
    points: ['Gentle, calm heavyweight', 'Flat-faced; the strictest heat care', 'Low exercise, big personality', 'Not HDB-approved — private housing'],
  },
  {
    title: 'German Shepherd', href: '/puppies/german-shepherd/', imageSrc: germanShepherdCard, imageAlt: 'German Shepherd puppy, a loyal working guardian breed for private housing in Singapore (not HDB-approved)',
    meta: 'Loyal working guardian; a scheduled breed', ctaLabel: 'View Breed',
    points: ['Loyal, intelligent working guardian', 'Needs training, space and exercise', 'Scheduled breed; extra rules apply', 'Not HDB-approved — private housing'],
  },
  {
    title: 'Goldendoodle', href: '/puppies/goldendoodle/', imageSrc: goldendoodleCard, imageAlt: 'Goldendoodle puppy, a low-shedding golden cross for private housing in Singapore (not HDB-approved)',
    meta: 'Golden warmth with a low-shed coat; big and friendly', ctaLabel: 'View Breed',
    points: ['Golden warmth, low-shed coat', 'Friendly, trainable and sociable', 'Big dog; needs space', 'Not HDB-approved — private housing'],
  },
  {
    title: 'Labradoodle', href: '/puppies/labradoodle/', imageSrc: labradoodleCard, imageAlt: 'Labradoodle puppy, the original doodle cross for private housing in Singapore (not HDB-approved)',
    meta: 'The original doodle; sociable and low-shedding', ctaLabel: 'View Breed',
    points: ['The original doodle cross', 'Sociable, active and trainable', 'Low-shedding coat; needs space', 'Not HDB-approved — private housing'],
  },
  {
    title: 'Whippet', href: '/puppies/whippet/', imageSrc: whippetCard, imageAlt: 'Whippet puppy, a gentle sighthound for private housing in Singapore (not HDB-approved)',
    meta: 'The gentle sprinter; calm indoors, fast outdoors', ctaLabel: 'View Breed',
    points: ['Gentle, quiet sighthound', 'Calm indoors, a sprinter outdoors', 'Short coat, minimal grooming', 'Not HDB-approved — private housing'],
  },
];

const breeds = [...hdbBreeds, ...privateBreeds];
const liveBreeds = breeds.filter((b) => !b.comingSoon);
const withPrice = (list) => list.map((b) => ({ ...b, tag: `From $${fmtPrice(priceForHref(b.href).low)}` }));
const hdbPriced = withPrice(hdbBreeds);
const privatePriced = withPrice(privateBreeds);

const faqItems = [
  {
    question: 'Which breeds does Curious Tails carry?',
    answer:
      'Over forty, with more arriving regularly. The range spans HDB-approved companions like the Cavapoo, Maltipoo, Maltese, Bichon Frise, Pomeranian, Shih Tzu, Pug and Cavalier King Charles Spaniel, through to private-housing breeds like the Corgi, Shiba Inu, French Bulldog, Golden Retriever and Siberian Husky. Prices start from $3,288 all-in and vary by breed, and every price includes the $500+ starter kit, free delivery and setup, and a free training lesson.',
  },
  {
    question: 'Which of your breeds are HDB-approved?',
    answer:
      'Most of them. The great majority of our breeds are HDB-approved companions and crosses, from the Cavapoo, Maltese and Bichon Frise to the Pug, Pomeranian, Shih Tzu and Cavalier King Charles Spaniel. A smaller group, including the Corgi, Shiba Inu, French Bulldog, Golden Retriever, Samoyed, Chow Chow and Siberian Husky, are not on the HDB-approved list and suit condos and landed homes only. We flag this on every breed card because finding out after falling in love is the worst order of operations.',
  },
  {
    question: 'Which breed suits a working couple best?',
    answer:
      'The independent ones: Cavapoo and Mini Dachshund for HDB homes, Shiba Inu for private housing. Maltipoo, Maltese, and Bichonpoo thrive on company and find an empty 8am to 6pm home hard; we will say so before you buy.',
  },
  {
    question: 'Do all breeds cost the same?',
    answer:
      'No. Each breed has its own published price, starting from $3,288 all-in and rising with breed, coat, colour, and age. Every price still includes the starter kit, delivery and training, and we quote the exact figure per puppy on WhatsApp.',
  },
  {
    question: 'Can you help us choose between breeds?',
    answer:
      'That is the whole point of how we sell. Message us your daily routine and housing type, or take the two-minute breed selector, and we will tell you straight, including which breed not to get. We have talked customers out of the wrong breed before, and it earned us reviews, not complaints.',
  },
  {
    question: 'Can we meet the breeds in person before deciding?',
    answer:
      'Yes, at 2 Balestier Road #01-701, weekdays 12pm to 6pm and weekends 10am to 6pm. WhatsApp first so we can have the right puppies ready for the breeds you are considering.',
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies',
    title,
    description,
    aboutName: 'Puppy breeds in Singapore',
    aboutAlternateName: 'dog breeds Singapore',
    datePublished: '2026-07-06',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema(liveBreeds.map((b) => ({
    name: `${b.title} puppy`,
    url: b.href,
    description: b.meta,
    price: String(priceForHref(b.href).low),
  }))),
  faqPageSchema(faqItems),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies" ogImage="/assets/cavapoo/og-cavapoo.jpg">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Puppies for Sale in Singapore, from Cavapoo to Corgi"
    h1Accent="Puppies for Sale"
    subhead="Over forty breeds, each with its own published price from $3,288 all-in, and one rule that never changes: we match the breed to your routine, not to the photo you fell for. HDB status is flagged on every card below."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'm choosing between breeds. Here's my routine and housing type:"
    secondaryCtaLabel="Browse all breeds"
    secondaryCtaHref="#breeds"
    priceAnchor="Every breed priced from $3,288, kit, delivery and training included."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, '2+ years in Balestier']}
    imageAlt="Puppy breeds Singapore: Cavapoo puppy in a set-up playpen, one of the breeds at Curious Tails"
    imageSrc={heroCavapoo}
    tagLabel="40+ breeds"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies/' }]} />
  </Hero>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="How do you choose a puppy breed in Singapore?"
      definition="Three questions decide it: is the breed HDB-approved if you live in a flat, how many hours will the dog be alone on a normal weekday, and how much grooming and exercise genuinely fit your week. The right breed is the one that fits your answers, not the one with the best photos."
      bridge="Every breed card below carries its HDB status and its honest fit line. Answer the three questions, then let the cards disagree with you if they need to."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The 3 questions</p>
        <ul class="mt-4 space-y-3">
          {[
            '1. HDB flat? Then only approved breeds',
            '2. Alone 8am to 6pm? Then the independent breeds',
            '3. Grooming and walks: what really fits your week?',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Shortcut: the <a href="/first-time-owners/breed-selector/" class="underline underline-offset-2">two-minute breed selector</a> asks these for you.</p>
      </div>
    </DefBox>
  </div>

  <div id="breeds" class="scroll-mt-40">
    <ListingGrid
      heading="HDB-Approved Breeds for Flat Living"
      headingAccent="HDB-Approved"
      subhead="Approved for HDB flats, one dog per flat. Every card links to the full honest profile: temperament, real prices, HDB rules, and the parts other listings leave out."
      items={hdbPriced}
    />
    <ListingGrid
      heading="Private Housing Breeds: Condo & Landed"
      headingAccent="Private Housing"
      subhead="Not on the HDB-approved list, so these suit condos and landed homes only. We flag it plainly, because finding out after you have fallen for a puppy is the worst order of operations. More breeds are landing soon."
      items={privatePriced}
      footerCtaLabel="Not sure which fits? Take the 2-minute quiz"
      footerCtaHref="/first-time-owners/breed-selector/"
    />
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Same promise, whichever breed"
    stats={[
      { value: '40+', label: 'breeds, honestly matched' },
      { value: '$3,288', label: 'every breed starts here, all-in' },
      { value: '$500+', label: 'starter kit with every puppy' },
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <ComparisonSplit
    heading="Match by Your Day, Not the Photo"
    headingAccent="Your Day"
    subhead="Two years of placements distilled into one honest table."
    mode="table"
    tableHeaders={['Your situation', 'Start with']}
    rows={[
      { label: 'Working couple, out 8am to 6pm, HDB flat', values: ['Cavapoo or Mini Dachshund; both handle alone time with a settled routine'] },
      { label: 'Someone home most of the day', values: ['Maltipoo, Maltese, Bichon Frise, or Bichonpoo; they thrive on exactly that company'] },
      { label: 'Family with young children', values: ['Cockapoo first, Cavapoo close second; both meet kids halfway'] },
      { label: 'First dog, want the forgiving option', values: ['Cockapoo; eager to please and kind to beginner mistakes'] },
      { label: 'Private housing, active outdoor routine', values: ['Corgi for engagement, Shiba Inu for independence'] },
      { label: 'Allergy-sensitive household', values: ['Bichon Frise, Bichonpoo, Maltese, Maltipoo, or Cavapoo; low-shedding, though no dog is allergen-free'] },
    ]}
  />

  <div id="hdb-check" class="scroll-mt-40">
    <ComparisonSplit
      heading="HDB Quick Check"
      headingAccent="Quick Check"
      subhead="A sample of the rule we flag before anything else. Every breed card above carries its own HDB status too."
      mode="table"
      tableHeaders={['Breed', 'HDB flat']}
      rows={[
        { label: 'Cavapoo', values: ['Yes, approved cross'] },
        { label: 'Maltipoo', values: ['Yes, approved cross'] },
        { label: 'Maltese', values: ['Yes, approved breed'] },
        { label: 'Bichon Frise', values: ['Yes, approved breed'] },
        { label: 'Cavapoochon', values: ['Yes, approved cross'] },
        { label: 'Chihuahua', values: ['Yes, approved breed'] },
        { label: 'Mini Dachshund', values: ['Yes, approved breed'] },
        { label: 'Cockapoo', values: ['Yes, approved cross'] },
        { label: 'Bichonpoo', values: ['Yes, approved cross'] },
        { label: 'Corgi', values: ['No; private housing only'] },
        { label: 'Shiba Inu', values: ['No; private housing only'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        The full rules, the one-dog-per-flat limit, and what to do if your heart is set on a non-approved breed are in the <a href="/first-time-owners/hdb-breeds/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">HDB-approved dog breeds guide</a>.
      </p>
    </div>
  </div>

  <PawTrail bg="bg-[var(--color-surface)]" colorClass="text-[var(--color-coral-300)]" />

  <ValueBundle
    eyebrow="Included with every breed"
    heading="What every puppy comes with"
    headingAccent="every puppy"
    subhead="The price on every card is the full price, whichever breed you choose. Details on the transparent pricing page."
    items={[
      {
        icon: 'kit',
        title: '$500+ Starter Kit',
        body: 'Over 30 items across eight categories, from playpen to toys, delivered with your puppy and explained item by item.',
        highlight: '30+ items',
      },
      {
        icon: 'delivery',
        title: 'Free Delivery & Setup',
        body: 'Island-wide, scheduled around you, with the playpen set up before your puppy explores the room.',
        highlight: 'Free',
      },
      {
        icon: 'training',
        title: 'Free Training Lesson',
        body: 'A first lesson with an AVS-Accredited Certified Dog Trainer, booked into week one while the routine forms.',
        highlight: 'AVS-certified',
      },
    ]}
  />
  <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-4 pb-10">
    <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
      Full inclusions, market comparisons, and the deposit-to-homecoming process: <a href="/pricing/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing</a>.
    </p>
  </div>

  <BannerRibbon
    heading="Still torn between two breeds?"
    body="Message us your daily routine and housing type. We'll tell you straight, including which breed not to get. It's how we work."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'm torn between two breeds. Here's my routine and housing:"
    variant="dark"
  />

  <div id="faq" class="scroll-mt-40">
    <FAQ heading="Breed Questions, Answered" items={faqItems} />
  </div>

  <FinalCta
    breed="Puppy"
    heading="Meet Our Breeds at Balestier"
    body="Can't make the trip? WhatsApp us which breeds you're considering and we'll send current photos and prices for each."
    reserveMessage="Hi! I'd like to ask about your available puppies across breeds."
  />

  <Schema {schemas} />
</BaseLayout>
