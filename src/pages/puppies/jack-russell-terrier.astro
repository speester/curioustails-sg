---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import imgHero from '../../assets/jack-russell-terrier/1-white-and-tan-jack-russell-terrier-puppy-sitting-in-a-s.webp';
import imgScene1 from '../../assets/jack-russell-terrier/2-white-and-tan-jack-russell-terrier-puppy-portrait-one-o.webp';
import imgScene2 from '../../assets/jack-russell-terrier/3-jack-russell-terrier-puppy-sprinting-after-a-ball-at-a.webp';
import imgScene3 from '../../assets/jack-russell-terrier/4-jack-russell-terrier-puppy-being-brushed-after-a-walk.webp';
import imgScene4 from '../../assets/jack-russell-terrier/5-jack-russell-terrier-puppy-at-a-veterinary-health-check.webp';
import imgScene5 from '../../assets/jack-russell-terrier/6-jack-russell-puppy-settling-into-a-set-up-playpen-durin.webp';
import imgCard1 from '../../assets/jack-russell-terrier/7-white-and-tan-male-jack-russell-terrier-puppy-available.webp';
import imgCard2 from '../../assets/jack-russell-terrier/8-tricolour-female-jack-russell-terrier-puppy-available-i.webp';
import imgCard3 from '../../assets/jack-russell-terrier/9-broken-coat-male-jack-russell-terrier-puppy-available-i.webp';
import imgCard4 from '../../assets/jack-russell-terrier/10-white-and-black-female-jack-russell-terrier-puppy-avail.webp';
import imgCard5 from '../../assets/jack-russell-terrier/11-smooth-coat-male-jack-russell-terrier-puppy-available-i.webp';
import imgCard6 from '../../assets/jack-russell-terrier/12-rough-coat-female-jack-russell-terrier-puppy-available.webp';

const title = 'Jack Russell Terrier Singapore | Price & Puppies';
const description =
  'Jack Russell Terrier puppies for sale in Singapore from $3,888, AVS licensed and HDB-approved. Real prices, energy honesty, temperament and the $500+ starter kit included.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Grooming', href: '#grooming' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'How much does a Jack Russell Terrier cost in Singapore?',
    answer:
      'Jack Russell prices in Singapore range more widely than most expect: pet-shop pups often sit around $2,000 to $4,500, while some shops quote as high as $7,000 to $9,000. At Curious Tails, Jack Russell Terrier puppies are $3,888 to $5,988, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a Jack Russell Terrier HDB-approved?',
    answer:
      'Yes. The Jack Russell Terrier is named on the HDB-approved breed list, so you can keep one in an HDB flat, which makes it the highest-energy dog on the approved list by some distance. The flat is fine; the exercise has to happen outside it. We complete the dog licensing for you at purchase.',
  },
  {
    question: 'How much exercise does a Jack Russell need?',
    answer:
      'More than any other breed we carry: a genuine hour a day minimum, split across walks and hard play, plus mental work like training games or puzzle feeders. This was bred as a working fox terrier and the engine never idles. Under-exercised Jack Russells dig, chew, bark and escape; well-exercised ones are brilliant, hilarious companions.',
  },
  {
    question: 'Can a Jack Russell be left alone while we are at work?',
    answer:
      'Only with the exercise contract honoured: a proper hard outing before work, enrichment during the day, and another outing after. A tired Jack Russell sleeps through a workday; a fresh one dismantles the flat, and we mean that more literally than with any other breed. If your mornings can\'t fit real exercise, choose a different breed and we\'ll happily point you to one.',
  },
  {
    question: 'Are Jack Russells good with children and other pets?',
    answer:
      'With active, dog-savvy children, genuinely great: few breeds match a school-age kid\'s energy better. With very small children, supervise; the play is boisterous. With cats, hamsters and rabbits, be honest with yourself: this is a hunting terrier with real prey drive, and small pets are a risk we\'d rather flag now than after.',
  },
  {
    question: 'Are Jack Russells easy to train?',
    answer:
      'They are extremely smart and learn fast, including things you didn\'t intend to teach. Training a Jack Russell is less about repetition and more about being more interesting than the environment. Keep sessions short, active and rewarding, start early, and use the free first lesson with an AVS-certified trainer to set the pattern.',
  },
  {
    question: 'Is a miniature Jack Russell a real breed?',
    answer:
      'Not as a separate breed. Jack Russells naturally come in different heights and leg lengths, and the shorter-legged type is often marketed as a "miniature" or "short" Jack Russell, but it is the same breed, not a distinct "mini" variety, and there is certainly no healthy "teacup" version. We tell you the honest expected adult size for each puppy rather than selling you a size label.',
  },
  {
    question: 'What happens after I reserve a Jack Russell?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/jack-russell-terrier',
    title,
    description,
    aboutName: 'Jack Russell Terrier',
    aboutAlternateName: 'Jack Russell',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Jack_Russell_Terrier',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Jack Russell Terrier puppy',
      url: '/puppies/jack-russell-terrier',
      description:
        'Jack Russell Terrier puppy from an AVS licensed Singapore pet shop, priced $3,888 to $5,988 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '3888',
      image: imgHero.src,
    },
  ]),
  serviceSchema({
    name: 'Jack Russell Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Jack Russell puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Jack Russell Terrier',
    description:
      'The Jack Russell Terrier is a small working terrier of roughly 5 to 8 kg, bred in England for fox work. Mostly white with tan or black markings in smooth, broken or rough coats, it is athletic, fearless and extremely intelligent, with a lifespan of 13 to 16 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Jack_Russell_Terrier',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/jack-russell-terrier">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Jack Russell Terrier Puppies for Sale in Singapore"
    h1Accent="Jack Russell"
    subhead="Jack Russell prices in Singapore swing widely, from about $2,000 to a quoted $9,000. Ours are $3,888 to $5,988, with the $500+ starter kit, free home delivery and setup, and a free first training lesson already in the price. Read the energy section before you fall for the face."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Jack Russell Terrier puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $3,888 all-in. HDB-approved. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'HDB-approved working terrier']}
    imageAlt="White and tan Jack Russell Terrier puppy sitting in a set-up playpen at a Balestier home" imageSrc={imgHero}
    tagLabel="Jack Russell"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies/' }, { label: 'Jack Russell Terrier', href: '/puppies/jack-russell-terrier/' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Jack Russell in Singapore?" imageAlt="White and tan Jack Russell Terrier puppy portrait, one of the Jack Russell puppies available in Singapore" imageSrc={imgScene1} variant="mid">
      <p>Our Jack Russell puppies in Singapore arrive and are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, coat type, and exact prices for the Jack Russell Terrier puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Jack Russell for sale in Singapore here is between $3,888 and $5,988, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Jack Russell puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Jack Russell photos and prices</a>, or meet our Jack Russell puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Jack Russell Puppies"
      headingAccent="Available"
      subhead="A few of the Jack Russell puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'White & tan boy', href: whatsappLink('Hi! I\'d like more photos and the price for the white and tan male Jack Russell puppy.'), imageAlt: 'White and tan male Jack Russell Terrier puppy available in Singapore', imageSrc: imgCard1, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Tricolour girl', href: whatsappLink('Hi! I\'d like more photos and the price for the tricolour female Jack Russell puppy.'), imageAlt: 'Tricolour female Jack Russell Terrier puppy available in Singapore', imageSrc: imgCard2, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Broken-coat boy', href: whatsappLink('Hi! I\'d like more photos and the price for the broken-coat male Jack Russell puppy.'), imageAlt: 'Broken-coat male Jack Russell Terrier puppy available in Singapore', imageSrc: imgCard3, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'White & black girl', href: whatsappLink('Hi! I\'d like more photos and the price for the white and black female Jack Russell puppy.'), imageAlt: 'White and black female Jack Russell Terrier puppy available in Singapore', imageSrc: imgCard4, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Smooth-coat boy', href: whatsappLink('Hi! I\'d like more photos and the price for the smooth-coat male Jack Russell puppy.'), imageAlt: 'Smooth-coat male Jack Russell Terrier puppy available in Singapore', imageSrc: imgCard5, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Rough-coat girl', href: whatsappLink('Hi! I\'d like more photos and the price for the rough-coat female Jack Russell puppy.'), imageAlt: 'Rough-coat female Jack Russell Terrier puppy available in Singapore', imageSrc: imgCard6, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '12 weeks' },
      ]}
    />
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is a Jack Russell Terrier?"
      definition="The Jack Russell Terrier is a small working terrier of roughly 5 to 8 kg, developed in 19th-century England to run with hunts and go to ground after foxes. Mostly white with tan or black markings, in smooth, broken or rough coats, it is athletic, fearless, extremely intelligent, and famously long-lived at 13 to 16 years."
      bridge="Curious Tails is an AVS licensed pet shop at 2 Balestier Road. We match by lifestyle first, and the Jack Russell gets our most careful matching of all: for active owners it is a once-in-a-lifetime dog; for sedentary homes it is a renovation project."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Jack Russell at a glance</p>
        <ul class="mt-4 space-y-3">
          {[
            'Working terrier: the real engine',
            'Roughly 5 to 8 kg fully grown',
            'Smooth, broken or rough coat, mostly white',
            'Needs an hour of real exercise daily',
            '13 to 16 year lifespan',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Sizes vary by line; ask us about a specific puppy's expected adult weight.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Jack Russell from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$3,888', label: 'Jack Russell pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Jack Russell Temperament: A Big Dog's Engine in a Small Chassis" imageAlt="Jack Russell Terrier puppy sprinting after a ball at a park connector" imageSrc={imgScene2} imagePosition="left">
      <p>Everything about the Jack Russell is calibrated for work: the athleticism, the fearlessness, the problem-solving brain that treats a closed door as a puzzle rather than an answer. For the right owner, someone who runs, hikes the park connectors, or genuinely enjoys daily training, this is the most rewarding dog on our list: funny, devoted, tireless, and clever enough to learn anything you can teach.</p>
      <p>The honest part, and we put it plainly because this breed generates more mismatches than any other: the energy is not a phase, not "puppy energy", and not negotiable. A Jack Russell needs a hard hour a day, every day, for its whole long life, plus mental work. The prey drive is real too: leashes near birds and cats, and think carefully if you keep small pets.</p>
      <p>Wondering if you actually want this much dog? The <a href="/puppies/mini-dachshund/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Mini Dachshund</a> offers terrier-adjacent character at half the throttle, and the <a href="/puppies/cockapoo/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cockapoo</a> is the forgiving family pick.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Jack Russell Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Yes, if and only if the exercise happens. The formula that works for our Jack Russell owners in working households: a hard 30-to-40-minute outing before work, not a stroll, a proper one; food-dispensing toys and chew work for the day; and real play or a second outing in the evening.</p>
      <p>Skip the morning outing and the breed will spend its day on projects: excavating the sofa, auditing the bin, learning to open the playpen. We are not exaggerating for effect. If your mornings genuinely can't fit it, we'll point you at a breed that naps for a living instead.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'You run, hike or walk hard daily',
            'You enjoy training as a hobby',
            'Active older kids; no small pets at home',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Jack Russell Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for the hardest-working small dog in Singapore."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 5 to 8 kg of mostly muscle'] },
        { label: 'Height', values: ['Around 25 to 30 cm at the shoulder'] },
        { label: 'Coat', values: ['Three types: smooth, broken and rough; predominantly white with tan and/or black markings'] },
        { label: 'Lifespan', values: ['13 to 16 years; one of the longest-lived, healthiest breeds there is'] },
        { label: 'Exercise', values: ['60+ minutes of genuine exercise daily, plus mental work; the highest requirement in our lineup'] },
        { label: 'Shedding & allergies', values: ['Sheds more than the coat suggests, smooth coats especially; not an allergy pick'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        The lifespan deserves its own sentence: a healthy Jack Russell routinely reaches 15 or 16, which means the puppy you buy is a commitment into the 2040s, exercising daily the whole way. Beautiful deal for the right owner; read it twice if you're unsure.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Jack Russell Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="Most shops make you WhatsApp them just to learn the number. Here's ours in writing: $3,888 to $5,988, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Jack Russell listings range from about $2,000 to a claimed $9,000',
            'Price usually not published; enquiry required',
            'No energy-honesty briefing before purchase',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$3,888 to $5,988, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and plan the ongoing costs with the <a href="/first-time-owners/budget-guide/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Jack Russell Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Jack Russell leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this breed the outdoor category is the main event: the harness and leash will see more kilometres than any other breed's, and the chew toys are load-bearing equipment, not decoration.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Jack Russell's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Jack Russell Right for Your Lifestyle?"
      subhead="We ask about your routine before recommending any breed. For a Jack Russell we ask twice."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Runner, hiker, or daily hard walker', values: ['Ideal. This is the dog that finally keeps up with you'] },
        { label: 'Enjoys training, agility or trick work', values: ['Ideal. The sharpest working brain in our lineup, and it loves a job'] },
        { label: 'Active family, school-age kids, no small pets', values: ['Great fit. Boisterous, joyful play for hours'] },
        { label: 'Working household, sedentary evenings', values: ['Reconsider honestly. Unspent Jack Russell energy becomes demolition; a Mini Dachshund or Shih Tzu fits better'] },
        { label: 'Home with cats, rabbits or hamsters', values: ['Reconsider. The prey drive is genuine and permanent'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Jack Russell is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. This page means it more than most. Message us your daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my daily routine. Is a Jack Russell the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Jack Russell vs Corgi: Two Big Engines, One HDB Answer" imagePosition="none" variant="dark">
    <p>Both are high-energy, big-personality dogs that need real daily exercise, and buyers weighing one often ask about the other. In Singapore the housing rules split them cleanly: the Jack Russell is on the HDB-approved list; the Corgi is not. If you live in a flat and want a genuinely energetic dog, the Jack Russell is the legal answer.</p>
    <p>Beyond housing: the Corgi is heavier, sheds far more, and herds; the Jack Russell is lighter, faster, and hunts. Both need owners who exercise like they mean it. With us the price, the starter kit, and the aftercare are identical either way.</p>
    <p>In private housing and weighing both? See our <a href="/puppies/corgi/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Corgi puppies</a>, or message us your routine and we'll tell you straight.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
      <ul class="mt-4 space-y-3">
        {[
          'Jack Russell: 5 to 8 kg, HDB-approved, hunting drive',
          'Corgi: 9 to 14 kg, private housing only, herding drive',
          'Same price, same starter kit, same aftercare either way',
        ].map((fact) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fact}
          </li>
        ))}
      </ul>
    </div>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="hdb" class="scroll-mt-40">
    <DefBox
      term="Keeping a Jack Russell in an HDB flat"
      definition="The Jack Russell Terrier is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat. The flat itself is no problem for a dog this size; the exercise contract is what makes flat life work for a working terrier. Every Jack Russell we place has its dog licensing completed at purchase."
      bridge="Is a Jack Russell HDB-approved? Yes, by name on the list, making it the most athletic dog you can legally keep in a flat. Just mind the one-dog-per-flat rule, and if you already have a dog, message us first so we can check your situation."
      citationLabel="Read HDB's guidelines on keeping pets"
