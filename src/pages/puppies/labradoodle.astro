---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';

const title = 'Labradoodle Puppy for Sale Singapore | Curious Tails';
const description =
  'Labradoodle puppies for sale in Singapore from $2,888 all-in. Honest part first: Labradoodles are not HDB-approved. The original doodle, low-shedding and lively, real prices, grooming truth and the $500+ starter kit.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Coat & Grooming', href: '#coat' },
  { label: 'Size', href: '#size' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'Can I keep a Labradoodle in an HDB flat?',
    answer:
      'No. The Labradoodle is a cross of two non-approved breeds, the Labrador Retriever and the Poodle, and it is not on the HDB-approved list at any size. Condos and landed homes may keep up to three dogs, which is where the Labradoodle belongs in Singapore. HDB readers: our HDB-approved breeds guide maps the low-shedding companion crosses that ARE on the list, like the Maltipoo and Cavapoo.',
  },
  {
    question: 'How much does a Labradoodle cost in Singapore?',
    answer:
      'Labradoodle prices in Singapore commonly run $4,000 to $7,500, with mini sizes and multigenerational litters at the top. At Curious Tails, Labradoodle puppies are $2,888 to $4,488, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Are Labradoodles hypoallergenic?',
    answer:
      'Low-shedding is the honest word, not hypoallergenic. A Labradoodle with a fleece or wool coat, especially one with more Poodle in the mix, sheds very little and suits many allergy-sensitive homes; a flatter hair coat sheds more. No cross is a guarantee, so we tell you each puppy\'s coat type honestly and encourage allergy-sensitive families to meet the pup first.',
  },
  {
    question: 'What is the difference between a Labradoodle and a Goldendoodle?',
    answer:
      'Same idea, different retriever. The Labradoodle crosses a Labrador with a Poodle; the Goldendoodle crosses a Golden Retriever with a Poodle. Both are friendly, trainable and low-shedding. Labradoodles often carry a touch more of the Labrador\'s bouncy energy and drive, while Goldendoodles lean a little softer and mellower. We stock both at the same price, so you can choose on temperament, not budget.',
  },
  {
    question: 'How much exercise does a Labradoodle need?',
    answer:
      'A genuine hour a day, sometimes more for the livelier ones, split across the cool hours: a proper walk before 9am and another after 6pm, never hard midday exertion. Both parent breeds are working dogs, so mental work, training games and often a dog-friendly swim are the way to a calm, contented Labradoodle in our climate.',
  },
  {
    question: 'What happens after I reserve a Labradoodle?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items, including the coat-care routine, before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/labradoodle',
    title,
    description,
    aboutName: 'Labradoodle',
    aboutAlternateName: 'Labrapoodle',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Labradoodle',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Labradoodle puppy',
      url: '/puppies/labradoodle',
      description:
        'Labradoodle puppy from an AVS licensed Singapore pet shop, priced $2,888 to $4,488 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '2888',
    },
  ]),
  serviceSchema({
    name: 'Labradoodle Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Labradoodle puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Labradoodle',
    description:
      'The Labradoodle is a Labrador Retriever and Poodle cross, the original doodle, bred for a friendly, trainable temperament and a low-shedding coat. Adult size ranges from mini to standard, roughly 10 to 30 kg. It is not on Singapore\'s HDB-approved list and suits private housing, with a lifespan of about 12 to 15 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Labradoodle',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/labradoodle">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Labradoodle Puppies for Sale in Singapore"
    h1Accent="Labradoodle"
    subhead="The honest part first: Labradoodles are not HDB-approved, so this page is for condo and landed homes. The original doodle pairs a Labrador's bounce with a low-shedding coat — the trade is a grooming schedule, not a vacuum. Prices here run $4,000 to $7,500 elsewhere; ours are $2,888 to $4,488, all-in."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Labradoodle puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $2,888 all-in. Private housing only. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'Low-shedding family cross']}
    imageAlt="Labradoodle puppy sitting in a set-up playpen at a Singapore condo"
    tagLabel="Labradoodle"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies' }, { label: 'Labradoodle', href: '/puppies/labradoodle' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Labradoodle in Singapore?" imageAlt="Labradoodle puppy portrait, one of the Labradoodle puppies available in Singapore" variant="mid">
      <p>Our Labradoodle puppies in Singapore are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, coat type, and exact prices for the Labradoodle puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Labradoodle for sale in Singapore here is between $2,888 and $4,488, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Labradoodle puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Labradoodle photos and prices</a>, or meet our Labradoodle puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Labradoodle Puppies"
      headingAccent="Available"
      subhead="A few of the Labradoodle puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Chocolate boy', href: whatsappLink('Hi! I\'d like more photos and the price for the chocolate male Labradoodle puppy.'), imageAlt: 'Chocolate male Labradoodle puppy available in Singapore', meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Caramel girl', href: whatsappLink('Hi! I\'d like more photos and the price for the caramel female Labradoodle puppy.'), imageAlt: 'Caramel female Labradoodle puppy available in Singapore', meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Cream boy', href: whatsappLink('Hi! I\'d like more photos and the price for the cream male Labradoodle puppy.'), imageAlt: 'Cream male Labradoodle puppy available in Singapore', meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'Black girl', href: whatsappLink('Hi! I\'d like more photos and the price for the black female Labradoodle puppy.'), imageAlt: 'Black female Labradoodle puppy available in Singapore', meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Apricot girl', href: whatsappLink('Hi! I\'d like more photos and the price for the apricot female Labradoodle puppy.'), imageAlt: 'Apricot female Labradoodle puppy available in Singapore', meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '2 months' },
        { title: 'Caramel boy', href: whatsappLink('Hi! I\'d like more photos and the price for the caramel male Labradoodle puppy.'), imageAlt: 'Caramel male Labradoodle puppy available in Singapore', meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '12 weeks' },
      ]}
    />
  </div>

  <div id="hdb" class="relative scroll-mt-40">
    <ScatterFloat />
    <DefBox
      term="Can you keep a Labradoodle in an HDB flat? No"
      definition="The Labradoodle is a cross of two non-approved breeds, the Labrador Retriever and the Poodle, and it is not on the HDB-approved breed list at any size. HDB flats may keep one dog of an approved small breed; condos and landed homes may keep up to three dogs, subject to the estate's own rules, which is where the Labradoodle belongs in Singapore."
      bridge="We tell you this before you fall for the photos. If you're set on a low-shedding companion but live in an HDB flat, our HDB-approved breeds guide maps the crosses that ARE on the list, the Maltipoo and Cavapoo among them. Private housing readers: carry on, the rest of this page is yours."
      citationLabel="Read HDB's guidelines on keeping pets"
      citationHref="https://www.hdb.gov.sg/managing-my-home/home-ownership/keeping-pets"
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The housing rules, straight</p>
        <ul class="mt-4 space-y-3">
          {[
            'HDB flat: Labradoodle not approved',
            'Condo / landed: up to three dogs (AVS limits of ownership)',
            'HDB readers: try the Maltipoo or Cavapoo instead',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">
          Source: <a href="https://avs.nparks.gov.sg/pets/licensing-a-pet/information-on-dog-and-cat-licences/limits-of-ownership/" class="underline underline-offset-2">AVS limits of ownership</a> · Full list: <a href="/first-time-owners/hdb-breeds" class="underline underline-offset-2">HDB-approved breeds guide</a>
        </p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Labradoodle from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$2,888', label: 'Labradoodle pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Labradoodle Temperament: The Original Doodle" imageAlt="Labradoodle puppy playing happily with a family in a garden" imagePosition="left">
      <p>The Labradoodle started it all — first bred in Australia to be a low-shedding guide dog — and the temperament shows its working roots: friendly, outgoing, quick to learn and eager to please. It bonds hard to its family, loves people and other dogs, and brings a cheerful, can-do energy to everything it does. For an active household that wants a low-shedding dog with a bit of get-up-and-go, it is a wonderful match.</p>
      <p>The honest footnotes. First, that Labrador energy is real: the Labradoodle is often a touch livelier than its Goldendoodle cousin, and it needs the daily exercise and mental work to match. Second, it is deeply social and does not enjoy long days alone. Third, as with any cross, temperament varies a little puppy to puppy, so we tell you what we actually see in each one.</p>
      <p>Comparing the family? The <a href="/puppies/goldendoodle" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Goldendoodle</a> is the Golden-based, often mellower cousin, and the <a href="/puppies/golden-retriever" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Golden Retriever</a> is the fully-predictable, heavy-shedding original. All three share our price and aftercare.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Labradoodle Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Moderately, once mature and genuinely exercised, but this is a sociable, energetic cross that does best with company and a job to do. A well-exercised adult settles through a workday; an under-exercised or lonely one gets restless and inventive. The mornings and evenings that belong to the dog are the real contract.</p>
      <p>The room needs the usual tropical basics — ventilation, shade, water — plus a puzzle toy to keep that busy brain occupied, and the exercise and grooming routines below decide the rest.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'Private housing and an active, sociable family',
            'You want low shedding and accept the grooming',
            'Someone walks and engages the dog daily',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="coat" class="scroll-mt-40">
    <CaptionedBlock heading="The Coat: Fleece, Wool or Hair, and What Each Means" imageAlt="Labradoodle having its fleece coat brushed and clipped at a groomer" imagePosition="left">
      <p>Labradoodle coats come in three broad types, and honest owners learn theirs early. Fleece is the soft, wavy coat most people picture, low-shedding and easy to love. Wool is curlier and tightest-shedding, often the best bet for allergy-sensitive homes. Hair coats are flatter, more Labrador-like, and shed more. The more Poodle in the mix, the more likely you are to get a low-shedding fleece or wool coat, and we tell you honestly what each puppy is showing.</p>
      <p>Whichever you get, the trade is the same as for any doodle: low shedding means the coat keeps growing, and a growing coat mats without work. Plan on brushing several times a week down to the skin, and a professional groom every 6 to 8 weeks. Owners who budget for the salon adore the low-shed life; owners who expect wash-and-go get a shock at the first mat.</p>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Labradoodle Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for a cross whose size depends on its Poodle parent."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Mini roughly 10 to 15 kg; medium and standard 15 to 30 kg'] },
        { label: 'Height', values: ['Around 35 to 60 cm at the shoulder, by size variant'] },
        { label: 'Coat', values: ['Fleece, wool or hair; cream, caramel, chocolate, black or apricot'] },
        { label: 'Lifespan', values: ['About 12 to 15 years, smaller sizes tending to live longer'] },
        { label: 'Exercise', values: ['An hour or more daily in the cool hours; loves water and games'] },
        { label: 'Grooming', values: ['Brush several times a week; professional groom every 6 to 8 weeks'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Because a cross's adult size can vary, we tell you the expected size for each specific litter, so you can plan for the dog you'll actually have, not a guess.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Labradoodle Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="The market runs $4,000 to $7,500. Here's ours in writing: $2,888 to $4,488, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Labradoodle price commonly $4,000 to $7,500',
            'Mini and multigenerational litters priced higher',
            'Inclusions rarely spelt out',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$2,888 to $4,488, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and factor the ongoing grooming cost with the <a href="/first-time-owners/budget-guide" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Labradoodle Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Labradoodle leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this coat the brush earns its keep, and on delivery day we show you how to keep that fleece or wool mat-free between grooms.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Labradoodle's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Labradoodle Right for Your Lifestyle?"
      subhead="We ask about your housing, your grooming budget and your energy for exercise before your heart gets a vote. Here's the honest short version."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Private housing, active family, wants low shedding', values: ['Ideal. Bounce, brains and a low-shed coat in one happy package'] },
        { label: 'Allergy-sensitive home', values: ['Often a great fit, especially a wool coat; meet the pup first to be sure'] },
        { label: 'HDB flat', values: ['Not eligible. See the Maltipoo or Cavapoo for the approved low-shed option'] },
        { label: 'Wants a calmer doodle', values: ['Consider the Goldendoodle, which often leans a touch mellower'] },
        { label: 'Sedentary household, no daily walker', values: ['Reconsider. This is a lively, working-bred cross'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Labradoodle is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your housing type and daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my housing type and daily routine. Is a Labradoodle the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Labradoodle vs Goldendoodle vs Golden Retriever" imagePosition="none" variant="dark">
    <p>Three routes to a friendly, family temperament, separated by two questions: coat and energy. The <a href="/puppies/golden-retriever" class="underline underline-offset-2">Golden Retriever</a> is the fully predictable original, mellow and heavy-shedding. The <a href="/puppies/goldendoodle" class="underline underline-offset-2">Goldendoodle</a> is the Golden-based doodle, low-shedding and generally soft-natured. The Labradoodle is the Labrador-based doodle: low-shedding too, and typically the liveliest of the three.</p>
    <p>All are private-housing breeds in Singapore, all need real daily exercise, and with us the price, the starter kit, and the aftercare are identical. Choose on the dog, not the budget: message us your energy levels and grooming appetite and we'll point you to the right one.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
      <ul class="mt-4 space-y-3">
        {[
          'Labradoodle: low-shed, liveliest of the three',
          'Goldendoodle: low-shed, generally mellower',
          'Golden: fully predictable, heavy shedding',
        ].map((fact) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fact}
          </li>
        ))}
      </ul>
    </div>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <div id="health" class="scroll-mt-40">
    <CaptionedBlock heading="Labradoodle Health: What We Check and What to Watch" imageAlt="Labradoodle puppy at a veterinary health check before going home" variant="mid">
      <p>Every Labradoodle goes home vet-checked, vaccinated, dewormed, and microchipped. Crossbreeds often benefit from hybrid vigour, but honest owners still watch what both parent breeds can pass on: hips and elbows in the larger sizes, so controlled growth and no forced running before maturity; eyes, worth a vet's routine check; and ears, because a hairy, floppy doodle ear traps moisture in our humidity and needs regular checking and gentle cleaning. Keeping the coat around the ears trimmed helps a lot.</p>
      <p>Feeding is simple: your puppy comes with the food it is already eating, portioned for its size, and any change should be gradual over a week. See the <a href="/learn/puppy-health" class="underline underline-offset-2 text-[var(--color-accent-hover)]">puppy health checks explained</a> guide.</p>
    </CaptionedBlock>
  </div>
