---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import heroMaltipoo from '../../assets/maltipoo/1-maltipoo-puppy-hero-playpen-balestier.webp';
import companionLap from '../../assets/maltipoo/2-maltipoo-puppy-companion-lap.webp';
import maltipooPortrait from '../../assets/maltipoo/3-maltipoo-puppy-portrait-available.webp';
import maltipooGrooming from '../../assets/maltipoo/4-maltipoo-puppy-grooming-eye-care.webp';
import maltipooVet from '../../assets/maltipoo/5-maltipoo-puppy-vet-health-check.webp';
import maltipooSettling from '../../assets/maltipoo/6-maltipoo-puppy-settling-playpen.webp';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';

const title = 'Maltipoo Singapore | Puppies from $2,888 | Curious Tails';
const description =
  'Maltipoo puppies for sale in Singapore from $2,888, AVS licensed and HDB-approved. Real prices, temperament, grooming and the $500+ starter kit included. WhatsApp us.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Grooming', href: '#grooming' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'How much does a Maltipoo cost in Singapore?',
    answer:
      'The Maltipoo price in Singapore ranges widely, from around $3,000 to $9,000 depending on size, coat, and shop. At Curious Tails, Maltipoo puppies are $2,888 to $4,488, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a Maltipoo HDB-approved?',
    answer:
      'Yes. A Maltipoo is an HDB-approved small breed, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and we complete the dog licensing for you at purchase, so the paperwork is handled.',
  },
  {
    question: 'Can a Maltipoo be left alone while we are at work?',
    answer:
      "Maltipoos are people-oriented and happiest with company, so a full 8am to 6pm alone every weekday is not their ideal. They suit homes with someone around: a family, a retiree, a helper, or remote work. If nobody is home all day, a more independent Cavapoo is often the kinder match, and we'll tell you so.",
  },
  {
    question: 'How big does a Maltipoo get?',
    answer:
      'Most Maltipoos reach roughly 3 to 6 kg fully grown, depending on the Poodle parent. Be cautious with anyone advertising a "teacup" or "micro" Maltipoo; sizes below the normal range often come with real health trade-offs, and no honest seller can guarantee them.',
  },
  {
    question: 'Do Maltipoos have tear stains, and how do I manage them?',
    answer:
      "Light tear staining is common in white and cream Maltipoos. A daily wipe around the eyes with clean water, keeping the face hair trimmed, and regular grooming keep it under control. The grooming tools you need are already in your starter kit.",
  },
  {
    question: 'What happens after I reserve a Maltipoo?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
  {
    question: 'How do I check that a puppy seller is licensed?',
    answer:
      "Search the seller's name or licence number on the AVS public registry of licensed pet shops. Curious Tails holds AVS pet shop licence AS24J00046. If a seller isn't on that registry, they aren't licensed, whatever their listing says.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/maltipoo',
    title,
    description,
    aboutName: 'Maltipoo',
    aboutAlternateName: 'Maltese Poodle',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Maltipoo',
    datePublished: '2026-07-06',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Maltipoo puppy',
      url: '/puppies/maltipoo',
      description:
        'Maltipoo puppy from an AVS licensed Singapore pet shop, priced $2,888 to $4,488 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '2888',
    },
  ]),
  serviceSchema({
    name: 'Maltipoo Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Maltipoo puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Maltipoo',
    description:
      'A Maltipoo is a cross between a Maltese and a Toy or Miniature Poodle. It is a small, affectionate companion dog, roughly 3 to 6 kg, with a soft low-shedding coat, a people-oriented temperament that thrives on company, and a lifespan of 12 to 15 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Maltipoo',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/maltipoo" ogImage="/assets/maltipoo/og-maltipoo.jpg">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Maltipoo Puppies for Sale in Singapore"
    h1Accent="Maltipoo"
    subhead="Maltipoo prices in Singapore run anywhere from $3,000 to $9,000. Ours are $2,888 to $4,488, with the $500+ starter kit, free home delivery and setup, and a free first training lesson already in the price."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Maltipoo puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $2,888 all-in. HDB-approved. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'HDB-approved small breed']}
    imageAlt="Maltipoo puppy with a soft cream coat sitting in a set-up playpen at a Balestier home"
    imageSrc={heroMaltipoo}
    tagLabel="Maltipoo"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies' }, { label: 'Maltipoo', href: '/puppies/maltipoo' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Maltipoo in Singapore?" imageAlt="Maltipoo puppy portrait, one of the Maltipoo puppies available in Singapore" imageSrc={maltipooPortrait} variant="mid">
      <p>Our Maltipoo puppies in Singapore arrive and are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, and exact prices for the Maltipoo puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Maltipoo for sale in Singapore here is between $2,888 and $4,488, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Maltipoo puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Maltipoo photos and prices</a>, or meet our Maltipoo puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Maltipoo Puppies"
      headingAccent="Available"
      subhead="A few of the Maltipoo puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Cream boy', href: whatsappLink('Hi! I\'d like more photos and the price for the cream male Maltipoo puppy.'), imageAlt: 'Cream male Maltipoo puppy available in Singapore', imageSrc: maltipooPortrait, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'White girl', href: whatsappLink('Hi! I\'d like more photos and the price for the white female Maltipoo puppy.'), imageAlt: 'White female Maltipoo puppy cuddled close on a caregiver\'s lap', imageSrc: companionLap, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '11 weeks' },
        { title: 'Apricot girl', href: whatsappLink('Hi! I\'d like more photos and the price for the apricot female Maltipoo puppy.'), imageAlt: 'Apricot female Maltipoo puppy during grooming and coat care', imageSrc: maltipooGrooming, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '3 months' },
      ]}
    />
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is a Maltipoo?"
      definition="A Maltipoo is a cross between a Maltese and a Toy or Miniature Poodle. It is a small, affectionate companion dog, roughly 3 to 6 kg, with a soft low-shedding coat, a people-oriented temperament that thrives on company, and a lifespan of 12 to 15 years."
      bridge="Curious Tails is an AVS licensed pet shop at 2 Balestier Road. We match by lifestyle first, and the Maltipoo suits one kind of home especially well: one where someone is usually around."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Maltipoo at a glance</p>
        <ul class="mt-4 space-y-3">
          {[
            'Maltese x Toy or Miniature Poodle',
            'Roughly 3 to 6 kg fully grown',
            'Soft, low-shedding coat',
            'People-oriented, thrives on company',
            '12 to 15 year lifespan',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Size varies with the Poodle parent; ask us about a specific puppy's expected adult weight.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Maltipoo from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$2,888', label: 'Maltipoo pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Maltipoo Temperament: The Companion That Wants to Be With You" imageAlt="Maltipoo puppy cuddled close on a caregiver's lap at home" imageSrc={companionLap} imagePosition="left">
      <p>Maltipoos are affectionate, playful, and deeply people-oriented. This is a dog that wants to be near you, follows you from room to room, and gives back every bit of attention it gets. For the right home, that devotion is the whole appeal.</p>
      <p>Here is the honest part we lead with, from two years of matching puppies to families: a Maltipoo's need for company is the single thing that decides whether the match works. In a home with someone usually around, a Maltipoo is a joy. In an empty home from 8am to 6pm, that same devotion can turn into whining and separation anxiety.</p>
      <p>They are gentle with children, sociable, and quick to learn. A Maltipoo that gets company and a settled routine is a calm, easy flatmate.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Maltipoo Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Honestly, this is where you should pause. Maltipoos cope least well of our small breeds with long stretches alone, because company is what they are built for. If someone is home for most of the day, a family member, a retiree, a helper, or you working remotely, a Maltipoo thrives.</p>
      <p>If your home is empty from 8am to 6pm every weekday, we will say so plainly, and often point you to a more independent breed instead. We'd rather talk you out of the wrong match than sell you a puppy that spends its days anxious. See our <a href="/puppies/cavapoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoo puppies</a>, which handle alone time more comfortably.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'Someone is usually home during the day',
            'A family member, retiree or helper is around',
            'You work remotely most days',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Maltipoo Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers, including the ones the teacup listings skip."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 3 to 6 kg, depending on the Toy or Miniature Poodle parent'] },
        { label: 'Height', values: ['Around 20 to 30 cm at the shoulder'] },
        { label: 'Coat', values: ['Soft and low-shedding, wavy to curly; common colours include white, cream and apricot'] },
        { label: 'Lifespan', values: ['12 to 15 years'] },
        { label: 'Exercise', values: ['About 30 minutes a day, plus indoor play and company'] },
        { label: 'Shedding & allergies', values: ['Low-shedding and often better tolerated by allergy sufferers, though no dog is truly allergen-free'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        How big do Maltipoos get? The Poodle parent decides, so a Maltipoo from a Toy Poodle stays smaller than one from a Miniature Poodle. The Maltipoo lifespan of 12 to 15 years is dependable with good care, which is one reason to choose health over an unusually tiny size.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Maltipoo Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="Most shops make you WhatsApp them just to learn the number. Here's ours in writing: $2,888 to $4,488, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Maltipoo price commonly $3,000 to $9,000',
            'Price usually not published; enquiry required',
            '"Teacup" and "micro" listings priced at a premium',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$2,888 to $4,488, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price lower and printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and plan the ongoing costs with the <a href="/first-time-owners/budget-guide" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Maltipoo Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Maltipoo leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, small-breed puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For a coat-and-eye breed like the Maltipoo, the grooming tools and the eye-wipe routine start on day one.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Maltipoo's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Maltipoo Right for Your Lifestyle?"
      subhead="We ask about your routine before recommending any breed. Here's the honest short version for a Maltipoo."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Someone home most of the day (family, retiree, helper, remote work)', values: ['Ideal. This is the Maltipoo home; the company is exactly what they want'] },
        { label: 'Family with children wanting an affectionate lap dog', values: ['Great fit. Gentle, playful, and endlessly cuddly'] },
        { label: 'Adding a companion for an existing dog', values: ['Good fit. Sociable and rarely the one to start trouble'] },
        { label: 'Nobody home 8am to 6pm on weekdays', values: ['Reconsider. A Maltipoo may fret; an independent Cavapoo is usually the kinder match'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Maltipoo is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my daily routine. Is a Maltipoo the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Maltipoo vs Cavapoo: Which One Fits Your Home?" imagePosition="none" variant="dark">
    <p>They look alike and cost the same with us, so the honest deciding factor is your day, not the dog. A Maltipoo is more attachment-dependent and wants company; a Cavapoo is noticeably more independent and copes better with a working couple's hours.</p>
    <p>A couple once came to us set on a Maltipoo. Both work 8am to 6pm with nobody home during the day, so we recommended a Cavapoo instead, and Andrew Mak later left a 5-star review for that honest steer. The lesson: the right pick protects the match, not the sale.</p>
    <p>Weighing the two? See our <a href="/puppies/cavapoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoo puppies</a>, or read the <a href="/blog/cavapoo-vs-maltipoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">full Cavapoo vs Maltipoo comparison</a>.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
      <ul class="mt-4 space-y-3">
        {[
          'Maltipoo: wants company, best with someone home most of the day',
          'Cavapoo: more independent, copes better with a working couple\'s hours',
          'Same price, same starter kit, same aftercare either way',
        ].map((fact) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fact}
          </li>
        ))}
      </ul>
    </div>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="hdb" class="scroll-mt-40">
    <DefBox
      term="Keeping a Maltipoo in an HDB flat"
      definition="A Maltipoo is an HDB-approved small breed, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and the Maltipoo's compact 3 to 6 kg size sits well within the small-breed rules. Every Maltipoo we place has its dog licensing completed at purchase, so the paperwork is handled for you."
      bridge="Is a Maltipoo HDB-approved? Yes, and we place them in HDB homes regularly. Just mind the one-dog-per-flat rule, and if you already have a dog, message us first so we can check your situation."
      citationLabel="Read HDB's guidelines on keeping pets"
      citationHref="https://www.hdb.gov.sg/managing-my-home/home-ownership/keeping-pets"
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The rules in brief</p>
        <ul class="mt-4 space-y-3">
          {[
            'The Maltipoo is an approved small breed for HDB flats',
            'One dog of an approved breed per HDB flat (AVS limits of ownership)',
            'Condo and landed homes: up to three dogs, subject to your estate\'s own pet rules',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">
          Source: <a href="https://avs.nparks.gov.sg/pets/licensing-a-pet/information-on-dog-and-cat-licences/limits-of-ownership/" class="underline underline-offset-2">AVS limits of ownership</a>
        </p>
      </div>
    </DefBox>
  </div>

  <div id="grooming" class="scroll-mt-40">
    <CaptionedBlock heading="Grooming and Tear-Stain Care in Our Humid Climate" imageAlt="Maltipoo puppy having its face gently wiped during grooming and tear-stain care" imageSrc={maltipooGrooming} imagePosition="left">
      <p>Maltipoos are low-shedding, which means the coat needs your help instead of dropping on its own. Brush 3 to 4 times a week to prevent matting, and book professional grooming every 6 to 8 weeks. Singapore's humidity speeds up matting, so a consistent routine matters more here than in cooler climates.</p>
      <p>Tear staining is the Maltipoo-specific one. Light reddish-brown marks under the eyes are common in white and cream coats. A daily wipe with clean water, keeping the face hair trimmed, and steady grooming keep it in check. The brush and grooming tools you need are already in the starter kit.</p>
    </CaptionedBlock>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <div id="health" class="scroll-mt-40">
    <CaptionedBlock heading="Maltipoo Health: What We Check Before You Take One Home" imageAlt="Maltipoo puppy at a veterinary health check before going home" imageSrc={maltipooVet} variant="mid">
      <p>Every Maltipoo goes home vet-checked, vaccinated, dewormed, and microchipped. The Maltipoo health points worth knowing are a small few: patellar luxation, a kneecap issue common to small breeds; dental crowding, because small jaws leave little room for teeth; and inherited eye conditions. We say this once, plainly, so you hear it from your seller and not from a forum later.</p>
      <p>Feeding is simple: your puppy comes with the small-breed food it is already eating, and any change should be gradual over a week. For portioning guidance see the <a href="/learn/puppy-health" class="underline underline-offset-2 text-[var(--color-accent-hover)]">puppy health checks explained</a> guide.</p>
    </CaptionedBlock>
  </div>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div class="scroll-mt-40">
    <CaptionedBlock heading="The Truth About Teacup and Micro Maltipoos" imagePosition="none" variant="card">
      <p>You will see "teacup," "micro," and "smallest in Singapore" Maltipoo listings, often at a premium. We don't sell to that label. Dogs bred to be unusually tiny carry higher risks: fragile bones, dental and breathing problems, low blood sugar, and shorter lives.</p>
      <p>A healthy small Maltipoo at 3 to 6 kg is already a compact, flat-friendly dog. If a seller promises a size below that and guarantees it, treat the promise as a warning, not a feature.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Teacup red flags</p>
        <ul class="mt-4 space-y-3">
          {[
            'Guaranteed adult weight below 3 kg',
            'No mention of the parents\' actual size',
            '"Teacup" or "micro" priced at a premium',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M18 6 6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>

    <PawTrail bg="bg-[var(--color-surface)]" colorClass="text-[var(--color-coral-300)]" />
  </div>

  <CaptionedBlock heading="Your Maltipoo's First Week at Home" imageAlt="Maltipoo puppy settling into a set-up playpen during its first week home" imageSrc={maltipooSettling} imagePosition="left">
    <p>Day 0: we deliver, free, at a time that suits you, usually morning or evening. The playpen, bed, water, and toys are set up before your Maltipoo explores the room, and we walk you through all 30+ starter-kit items in person. Learn more about <a href="/delivery" class="underline underline-offset-2 text-[var(--color-accent-hover)]">how our free home delivery and setup works</a>.</p>
    <p>Days 1 to 3: keep it calm and close. Maltipoos settle fastest with gentle company nearby, a fixed feeding routine, and the toilet pads where we placed them. Some night whimpering is normal adjustment.</p>
    <p>Days 4 to 7: the routine sticks. This is the window to book your free first lesson with an AVS-certified trainer; see <a href="/free-training" class="underline underline-offset-2 text-[var(--color-accent-hover)]">what the free AVS-certified training lesson covers</a>. For anything in between, you WhatsApp us.</p>
  </CaptionedBlock>

  <div id="reviews" class="scroll-mt-40">
    <Carousel
      heading="What Curious Tails Owners Say"
      subhead={`${site.reviews.count} Google reviews, ${site.reviews.rating.toFixed(1)} average, and counting.`}
      items={[
