---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import imgHero from '../../assets/miniature-pinscher/1-red-miniature-pinscher-puppy-standing-proudly-in-a-set.webp';
import imgScene1 from '../../assets/miniature-pinscher/2-red-miniature-pinscher-puppy-portrait-one-of-the-min-pi.webp';
import imgScene2 from '../../assets/miniature-pinscher/3-miniature-pinscher-puppy-trotting-proudly-across-a-livi.webp';
import imgScene3 from '../../assets/miniature-pinscher/4-miniature-pinscher-puppy-getting-a-quick-coat-wipe-down.webp';
import imgScene4 from '../../assets/miniature-pinscher/5-miniature-pinscher-puppy-at-a-veterinary-health-check-b.webp';
import imgScene5 from '../../assets/miniature-pinscher/6-miniature-pinscher-puppy-settling-into-a-set-up-playpen.webp';
import imgCard1 from '../../assets/miniature-pinscher/7-red-male-miniature-pinscher-puppy-available-in-singapor.webp';
import imgCard2 from '../../assets/miniature-pinscher/8-black-and-rust-female-miniature-pinscher-puppy-availabl.webp';
import imgCard3 from '../../assets/miniature-pinscher/9-chocolate-and-rust-male-miniature-pinscher-puppy-availa.webp';
import imgCard4 from '../../assets/miniature-pinscher/10-stag-red-female-miniature-pinscher-puppy-available-in-s.webp';
import imgCard5 from '../../assets/miniature-pinscher/11-black-and-rust-male-miniature-pinscher-puppy-available.webp';
import imgCard6 from '../../assets/miniature-pinscher/12-red-female-miniature-pinscher-puppy-available-in-singap.webp';

const title = 'Miniature Pinscher Puppy for Sale Singapore | Curious Tails';
const description =
  'Miniature Pinscher puppies for sale in Singapore from $4,988, AVS licensed and HDB-approved. Real prices, temperament, escape-artist honesty and the $500+ starter kit.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Grooming', href: '#grooming' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'How much does a Miniature Pinscher cost in Singapore?',
    answer:
      'Miniature Pinscher prices in Singapore commonly run from around $2,000 to $4,500 depending on colour and shop. At Curious Tails, Min Pin puppies are $4,988 to $5,988, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a Miniature Pinscher HDB-approved?',
    answer:
      'Yes. The Miniature Pinscher is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and we complete the dog licensing for you at purchase, so the paperwork is handled.',
  },
  {
    question: 'Is the Miniature Pinscher a mini Doberman?',
    answer:
      'No, and the history is the fun part: the Min Pin is the older breed. It was developed in Germany as a farm ratter long before the Doberman existed; the resemblance comes from shared ancestor types, not from shrinking a Doberman. Temperament-wise it is all terrier-like fire and independence, nothing like a guard dog.',
  },
  {
    question: 'Can a Miniature Pinscher be left alone while we are at work?',
    answer:
      'Moderately well once mature. Min Pins are confident, self-directed little dogs, and a settled routine with real exercise around the workday suits them. Two cautions: the escape-artist streak means the playpen and windows need to be genuinely secure, and a bored Min Pin has a sharp watchdog voice that needs early training.',
  },
  {
    question: 'Are Miniature Pinschers good with children?',
    answer:
      'With respectful older children, yes; the energy matches well. With toddlers, no: at 4 to 6 kg the Min Pin is sturdier than a Chihuahua but still small, and its proud temperament has limited patience for grabbing. Young families do better with the Cockapoo or Shih Tzu, and we will say so before you buy.',
  },
  {
    question: 'How much exercise does a Min Pin need?',
    answer:
      'More than its size suggests: about 45 minutes a day, plus play and mental work. The Min Pin was a working ratter and it kept the engine. The famous high-stepping "hackney" trot needs somewhere to go, every day.',
  },
  {
    question: 'Is a teacup Miniature Pinscher a real thing?',
    answer:
      'No. A healthy Min Pin sits around 4 to 6 kg, and there is no separate "teacup" or "micro" variety, however small a listing claims a puppy will stay. Deliberately undersized dogs are more fragile and prone to low blood sugar and dental trouble, and no honest seller can guarantee an adult size below the breed norm. We quote you the honest expected size and match you to a sound, sturdy puppy.',
  },
  {
    question: 'What happens after I reserve a Miniature Pinscher?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/miniature-pinscher',
    title,
    description,
    aboutName: 'Miniature Pinscher',
    aboutAlternateName: 'Min Pin',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Miniature_Pinscher',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Miniature Pinscher puppy',
      url: '/puppies/miniature-pinscher',
      description:
        'Miniature Pinscher puppy from an AVS licensed Singapore pet shop, priced $4,988 to $5,988 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '4988',
      image: imgHero.src,
    },
  ]),
  serviceSchema({
    name: 'Miniature Pinscher Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Min Pin puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Miniature Pinscher',
    description:
      'The Miniature Pinscher is a small German breed of roughly 4 to 6 kg with a sleek short coat in red, black & rust or chocolate & rust, a proud high-stepping gait, and a fearless, energetic temperament. Known as the "King of Toys", it has a lifespan of 12 to 16 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Miniature_Pinscher',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/miniature-pinscher">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Miniature Pinscher Puppies for Sale in Singapore"
    h1Accent="Miniature Pinscher"
    subhead="Min Pin prices in Singapore commonly run $2,000 to $4,500. Ours are $4,988 to $5,988, with the $500+ starter kit, free home delivery and setup, and a free first training lesson already in the price."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Miniature Pinscher puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $4,988 all-in. HDB-approved. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'HDB-approved toy breed']}
    imageAlt="Red Miniature Pinscher puppy standing proudly in a set-up playpen at a Balestier home" imageSrc={imgHero}
    tagLabel="Min Pin"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies' }, { label: 'Miniature Pinscher', href: '/puppies/miniature-pinscher' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Miniature Pinscher in Singapore?" imageAlt="Red Miniature Pinscher puppy portrait, one of the Min Pin puppies available in Singapore" imageSrc={imgScene1} variant="mid">
      <p>Our Miniature Pinscher puppies in Singapore arrive and are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, colour, and exact prices for the Min Pin puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Miniature Pinscher for sale in Singapore here is between $4,988 and $5,988, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Miniature Pinscher puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Min Pin photos and prices</a>, or meet our Miniature Pinscher puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Miniature Pinscher Puppies"
      headingAccent="Available"
      subhead="A few of the Min Pin puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Red boy', href: whatsappLink('Hi! I\'d like more photos and the price for the red male Miniature Pinscher puppy.'), imageAlt: 'Red male Miniature Pinscher puppy available in Singapore', imageSrc: imgCard1, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Black & rust girl', href: whatsappLink('Hi! I\'d like more photos and the price for the black and rust female Miniature Pinscher puppy.'), imageAlt: 'Black and rust female Miniature Pinscher puppy available in Singapore', imageSrc: imgCard2, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Chocolate & rust boy', href: whatsappLink('Hi! I\'d like more photos and the price for the chocolate and rust male Miniature Pinscher puppy.'), imageAlt: 'Chocolate and rust male Miniature Pinscher puppy available in Singapore', imageSrc: imgCard3, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'Stag red girl', href: whatsappLink('Hi! I\'d like more photos and the price for the stag red female Miniature Pinscher puppy.'), imageAlt: 'Stag red female Miniature Pinscher puppy available in Singapore', imageSrc: imgCard4, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Black & rust boy', href: whatsappLink('Hi! I\'d like more photos and the price for the black and rust male Miniature Pinscher puppy.'), imageAlt: 'Black and rust male Miniature Pinscher puppy available in Singapore', imageSrc: imgCard5, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Red girl', href: whatsappLink('Hi! I\'d like more photos and the price for the red female Miniature Pinscher puppy.'), imageAlt: 'Red female Miniature Pinscher puppy available in Singapore', imageSrc: imgCard6, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '12 weeks' },
      ]}
    />
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is a Miniature Pinscher?"
      definition="The Miniature Pinscher is a small German breed of roughly 4 to 6 kg, developed centuries ago as a fearless farm ratter. Sleek-coated in red, black & rust or chocolate & rust, it moves with a signature high-stepping hackney gait and carries itself with a confidence that earned it the nickname 'King of Toys'. Lifespan is 12 to 16 years."
      bridge="Curious Tails is an AVS licensed pet shop at 2 Balestier Road. We match by lifestyle first, and the Min Pin suits experienced or committed owners who want big-dog attitude, real energy, and a wash-and-wear coat in a small frame."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Min Pin at a glance</p>
        <ul class="mt-4 space-y-3">
          {[
            '"King of Toys": fearless and proud',
            'Roughly 4 to 6 kg fully grown',
            'Sleek low-maintenance coat',
            'The signature high-stepping gait',
            '12 to 16 year lifespan',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Sizes vary by line; ask us about a specific puppy's expected adult weight.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Min Pin from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$4,988', label: 'Min Pin pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Min Pin Temperament: The King of Toys Rules His Flat" imageAlt="Miniature Pinscher puppy trotting proudly across a living room" imageSrc={imgScene2} imagePosition="left">
      <p>The Min Pin's nickname isn't marketing; it's a personality report. This is a fearless, curious, self-assured little dog that patrols its home like a landlord, investigates everything, and moves with that unmistakable high-stepping trot that makes strangers stop and ask. It is loyal and playful with its family, reserved with strangers, and convinced beyond argument of its own importance.</p>
      <p>The honest part, from two years of matching puppies to families: the Min Pin is more dog than its size suggests, in every direction. More energy, more independence, more voice, and famously more escape talent; this breed treats gaps in doors, low gates and unattended balconies as personal challenges. Secure the flat, spend the energy daily, train the voice early, and you get a devoted little character with a 15-year warranty.</p>
      <p>If the attitude appeals but the energy doesn't, the <a href="/puppies/chihuahua" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Chihuahua</a> offers big-dog personality at half the throttle; the <a href="/puppies/mini-dachshund" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Mini Dachshund</a> splits the difference.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Min Pin Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Moderately well once mature, with the terrier-style contract honoured: real exercise before and after work, chew work during the day, and a genuinely secure space, because a bored Min Pin doesn't sulk, it engineers. Playpen latches, window gaps and balcony access all need an honest audit before day one.</p>
      <p>If your routine can't fit the exercise, the calmer <a href="/puppies/shih-tzu" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Shih Tzu</a> or the more self-contained <a href="/puppies/cavapoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoo</a> will suit everyone better, and we'll say so.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'You want maximum character, minimum grooming',
            'Active household, daily walks guaranteed',
            'Adults or respectful older children',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Min Pin Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for the King of Toys."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 4 to 6 kg of lean muscle'] },
        { label: 'Height', values: ['Around 25 to 32 cm at the shoulder'] },
        { label: 'Coat', values: ['Short, sleek, close-lying; solid red, stag red, black & rust, chocolate & rust'] },
        { label: 'Lifespan', values: ['12 to 16 years; a robust, long-lived breed'] },
        { label: 'Exercise', values: ['About 45 minutes a day plus play; livelier than its toy-group label suggests'] },
        { label: 'Shedding & allergies', values: ['Light shedding, but present; a middle option for allergy-conscious homes'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        One climate note in the Min Pin's favour: that thin single-layer coat, a liability in German winters, is perfectly suited to Singapore. No coat blows, no heat stress beyond normal sensible-walking rules, and a chamois-cloth shine with almost no effort.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Min Pin Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="Most shops make you WhatsApp them just to learn the number. Here's ours in writing: $4,988 to $5,988, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Min Pin price commonly $2,000 to $4,500',
            'Price usually not published; enquiry required',
            'No energy or escape-proofing briefing before purchase',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$4,988 to $5,988, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and plan the ongoing costs with the <a href="/first-time-owners/budget-guide" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Min Pin Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Miniature Pinscher leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, small-breed puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this breed the playpen earns special attention on setup day, we'll show you how to make it Min-Pin-proof, and the harness matters because this quick little neck should never take a leash correction.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Min Pin's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Min Pin Right for Your Lifestyle?"
      subhead="We ask about your routine before recommending any breed. Here's the honest short version for a Min Pin."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Active adults who want a big character', values: ['Ideal. Nothing this size carries itself with more presence'] },
        { label: 'You want near-zero grooming', values: ['Ideal. A weekly wipe-down keeps the coat gleaming'] },
        { label: 'Working household with real morning walks', values: ['Workable. Spend the energy and secure the flat, and it copes well'] },
        { label: 'Home with toddlers', values: ['Reconsider. Small frame, proud temperament; the Shih Tzu or Cockapoo suits young families better'] },
        { label: 'First dog, want something forgiving', values: ['Reconsider. The Min Pin exploits inconsistency cheerfully; the Cockapoo forgives it'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Min Pin is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my daily routine. Is a Miniature Pinscher the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="No, It's Not a Miniature Doberman" imagePosition="none" variant="dark">
    <p>The question arrives weekly, so here's the record set straight: the Miniature Pinscher is not a shrunken Doberman. It is the older breed by centuries, a German farm ratter that predates Louis Dobermann's guard dog entirely; the resemblance comes from shared ancestor stock, not miniaturisation. Genetically and temperamentally, the Min Pin is its own animal: terrier-hearted, independent, and zero percent guard dog.</p>
    <p>Why it matters practically: buyers expecting a tiny obedient protector get a proud, busy ratter instead, and that mismatch is preventable with one honest paragraph, this one. Come meet one at Balestier and the personality explains itself in about ninety seconds.</p>
    <p>Want the sleek-coat look with a softer temperament? The <a href="/puppies/italian-greyhound" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Italian Greyhound</a> is the gentle counterpart, and we carry both.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The record, straight</p>
      <ul class="mt-4 space-y-3">
        {[
          'Older than the Doberman by centuries',
          'Bred to rat, not to guard',
          'All terrier fire, no guard-dog softness switch',
        ].map((fact) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fact}
          </li>
        ))}
      </ul>
    </div>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="hdb" class="scroll-mt-40">
    <DefBox
      term="Keeping a Min Pin in an HDB flat"
      definition="The Miniature Pinscher is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and the Min Pin sits comfortably inside the small-breed rules. Every Min Pin we place has its dog licensing completed at purchase, so the paperwork is handled for you."
      bridge="Is a Miniature Pinscher HDB-approved? Yes, by name on the list. Just mind the one-dog-per-flat rule, and if you already have a dog, message us first so we can check your situation."
      citationLabel="Read HDB's guidelines on keeping pets"
