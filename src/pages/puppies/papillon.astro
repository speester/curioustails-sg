---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import imgHero from '../../assets/papillon/1-white-and-sable-papillon-puppy-with-butterfly-ears-sitt.webp';
import imgScene1 from '../../assets/papillon/2-white-and-sable-papillon-puppy-portrait-one-of-the-papi.webp';
import imgScene2 from '../../assets/papillon/3-papillon-puppy-learning-a-trick-during-play-at-home.webp';
import imgScene3 from '../../assets/papillon/4-papillon-puppy-having-its-silky-coat-and-ear-fringes-co.webp';
import imgScene4 from '../../assets/papillon/5-papillon-puppy-at-a-veterinary-health-check-before-goin.webp';
import imgScene5 from '../../assets/papillon/6-papillon-puppy-settling-into-a-set-up-playpen-during-it.webp';
import imgCard1 from '../../assets/papillon/7-white-and-sable-male-papillon-puppy-available-in-singap.webp';
import imgCard2 from '../../assets/papillon/8-tricolour-female-papillon-puppy-available-in-singapore.webp';
import imgCard3 from '../../assets/papillon/9-white-and-red-male-papillon-puppy-available-in-singapor.webp';
import imgCard4 from '../../assets/papillon/10-white-and-black-female-papillon-puppy-available-in-sing.webp';
import imgCard5 from '../../assets/papillon/11-sable-male-papillon-puppy-available-in-singapore.webp';
import imgCard6 from '../../assets/papillon/12-female-papillon-puppy-with-classic-butterfly-ears-avail.webp';

const title = 'Papillon Singapore | Price & Puppies | Curious Tails';
const description =
  'Papillon puppies for sale in Singapore from $4,088, AVS licensed and HDB-approved. Real prices, temperament, the famous butterfly ears and the $500+ starter kit included.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Grooming', href: '#grooming' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'How much does a Papillon cost in Singapore?',
    answer:
      'Papillon prices in Singapore commonly run from around $3,000 to $6,000; the breed is uncommon here, which keeps prices firm. At Curious Tails, Papillon puppies are $4,088 to $6,088, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a Papillon HDB-approved?',
    answer:
      'Yes. The Papillon is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and we complete the dog licensing for you at purchase, so the paperwork is handled.',
  },
  {
    question: 'Are Papillons really that smart?',
    answer:
      'Yes, and it is not marketing. The Papillon consistently ranks as the most intelligent of all toy breeds and inside the top ten of every breed, alongside Border Collies and Poodles many times its size. In practice: house training comes fast, tricks come faster, and a bored Papillon will invent its own projects, so plan to use that brain daily.',
  },
  {
    question: 'Can a Papillon be left alone while we are at work?',
    answer:
      'Moderately well, with its brain accounted for. Papillons are devoted but confident little dogs, and a settled routine with real mental work, puzzle feeders, training games morning and evening, keeps a working household workable. Leave that brain idle and it fills the day with barking and invention.',
  },
  {
    question: 'Do Papillons shed? Are they hard to groom?',
    answer:
      'Less than the glamour suggests, on both counts. The Papillon carries a silky single coat with no undercoat: shedding is light, mats are rare, and a comb-through 2 to 3 times a week keeps it show-worthy. No salon schedule is strictly needed, which surprises people comparing it with the Poodle crosses.',
  },
  {
    question: 'Are Papillons good with children?',
    answer:
      'With calm, older children, wonderful: the playfulness matches theirs. With toddlers, no; at 2.5 to 4.5 kg with fine bones, the risk of accidental injury is real, and we say so before you buy. Young families should look at the sturdier Shih Tzu or Cockapoo first.',
  },
  {
    question: 'Are imported or "rare" Papillons in Singapore safe to buy?',
    answer:
      "This is worth taking seriously, because the Papillon's rarity is exactly what makes it a target. You will see listings advertising Papillons \"imported from Australia\" and similar, and some of those turn out to be smuggled in without proper vaccination or health checks, carrying disease and leaving the buyer with no recourse (and a possible fine). Protect yourself simply: buy only from an AVS-licensed shop whose licence you can look up on the public registry, insist on seeing vaccination and microchip records, and meet the puppy in person. Every Papillon we place is licensed, vet-checked and fully documented.",
  },
  {
    question: 'What happens after I reserve a Papillon?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/papillon',
    title,
    description,
    aboutName: 'Papillon',
    aboutAlternateName: 'Papillon dog',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Papillon_(dog)',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Papillon puppy',
      url: '/puppies/papillon',
      description:
        'Papillon puppy from an AVS licensed Singapore pet shop, priced $4,088 to $6,088 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '4088',
      image: imgHero.src,
    },
  ]),
  serviceSchema({
    name: 'Papillon Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Papillon puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Papillon',
    description:
      'The Papillon is a toy spaniel of roughly 2.5 to 4.5 kg, named for its butterfly-wing ears, with a silky single coat and the sharpest mind of any toy breed. Lively, agile and devoted, it has a lifespan of 13 to 16 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Papillon_(dog)',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/papillon">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Papillon Puppies for Sale in Singapore"
    h1Accent="Papillon"
    subhead="Papillon prices in Singapore commonly run $3,000 to $6,000. Ours are $4,088 to $6,088, with the $500+ starter kit, free home delivery and setup, and a free first training lesson already in the price."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Papillon puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $4,088 all-in. HDB-approved. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'HDB-approved toy breed']}
    imageAlt="White and sable Papillon puppy with butterfly ears sitting in a set-up playpen at a Balestier home" imageSrc={imgHero}
    tagLabel="Papillon"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies/' }, { label: 'Papillon', href: '/puppies/papillon/' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <ListingGrid
      heading="Available Papillon Puppies"
      headingAccent="Available"
      subhead="A few of the Papillon puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'White & sable boy', href: whatsappLink('Hi! I\'d like more photos and the price for the white and sable male Papillon puppy.'), imageAlt: 'White and sable male Papillon puppy available in Singapore', imageSrc: imgCard1, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Tricolour girl', href: whatsappLink('Hi! I\'d like more photos and the price for the tricolour female Papillon puppy.'), imageAlt: 'Tricolour female Papillon puppy available in Singapore', imageSrc: imgCard2, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'White & red boy', href: whatsappLink('Hi! I\'d like more photos and the price for the white and red male Papillon puppy.'), imageAlt: 'White and red male Papillon puppy available in Singapore', imageSrc: imgCard3, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'White & black girl', href: whatsappLink('Hi! I\'d like more photos and the price for the white and black female Papillon puppy.'), imageAlt: 'White and black female Papillon puppy available in Singapore', imageSrc: imgCard4, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Sable boy', href: whatsappLink('Hi! I\'d like more photos and the price for the sable male Papillon puppy.'), imageAlt: 'Sable male Papillon puppy available in Singapore', imageSrc: imgCard5, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Butterfly-eared girl', href: whatsappLink('Hi! I\'d like more photos and the price for the female Papillon puppy with the classic butterfly ears.'), imageAlt: 'Female Papillon puppy with classic butterfly ears available in Singapore', imageSrc: imgCard6, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '12 weeks' },
      ]}
    />

    <CaptionedBlock heading="Looking to Buy a Papillon in Singapore?" imageAlt="White and sable Papillon puppy portrait, one of the Papillon puppies available in Singapore" imageSrc={imgScene1} variant="mid">
      <p>Papillons are genuinely uncommon in Singapore, so litters are announced and reserved fast; we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, colour, and exact prices for the Papillon puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Papillon for sale in Singapore here is between $4,088 and $6,088, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Papillon puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Papillon photos and prices</a>, or meet our Papillon puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is a Papillon?"
      definition="The Papillon is a toy spaniel of roughly 2.5 to 4.5 kg, named after the French word for butterfly for its large, fringed, wing-like ears. Painted at the feet of European royalty for five centuries, it pairs a silky single coat with the sharpest mind of any toy breed and a lifespan of 13 to 16 years."
      bridge="Curious Tails is an AVS licensed pet shop at 2 Balestier Road. We match by lifestyle first, and the Papillon suits owners who want a tiny dog that thinks like a big one: quick, agile, and hungry to learn."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Papillon at a glance</p>
        <ul class="mt-4 space-y-3">
          {[
            'The smartest toy breed, by every ranking',
            'Roughly 2.5 to 4.5 kg fully grown',
            'Signature butterfly ears, silky single coat',
            'Lively and agile; loves trick training',
            '13 to 16 year lifespan',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Sizes vary by line; ask us about a specific puppy's expected adult weight.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Papillon from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$4,088', label: 'Papillon pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Papillon Temperament: A Border Collie's Brain at Handbag Scale" imageAlt="Papillon puppy learning a trick during play at home" imageSrc={imgScene2} imagePosition="left">
      <p>Intelligence rankings put the Papillon in the world's top ten, ahead of German Shepherds, and it is the only toy breed on that list. Living with one means living with a dog that learns your routines in a weekend, reads your moods better than some housemates, and treats trick training as the best game ever invented. Papillon owners end up teaching spins, weaves and name-the-toy games not because the dog needs it on paper, but because the dog keeps asking.</p>
      <p>The honest part, from two years of matching puppies to families: that brain is a daily appetite, not a party trick. A Papillon with nothing to learn becomes a tiny, extremely effective alarm system with opinions about every corridor sound. Ten minutes of training twice a day keeps the genius charming; the free first lesson with an AVS-certified trainer shows you exactly how.</p>
      <p>If you love the intelligence but want a more easygoing package, the <a href="/puppies/toy-poodle/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Toy Poodle</a> is the natural comparison, and we sell both honestly.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Papillon Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Moderately well, if the brain is fed around the workday. Papillons are confident rather than clingy, and a settled routine with puzzle feeders, a food-dispensing toy, and training games before and after work carries most of them through a quiet weekday gracefully.</p>
      <p>The failure mode is an idle mind, which converts directly to barking. If your household can't commit to the daily mental work, the calmer Shih Tzu or the independent Cavapoo is the kinder pick.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'You genuinely enjoy training and games',
            'Adults or calm older children at home',
            'You want maximum dog in minimum kilograms',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Papillon Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for the butterfly dog."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 2.5 to 4.5 kg; fine-boned under the fluff'] },
        { label: 'Height', values: ['Around 20 to 28 cm at the shoulder'] },
        { label: 'Coat', values: ['Long, silky single coat, no undercoat; white with sable, red, black or tricolour patches'] },
        { label: 'Lifespan', values: ['13 to 16 years; a famously healthy toy breed'] },
        { label: 'Exercise', values: ['About 30 to 45 minutes a day plus real mental work; livelier than most toys'] },
        { label: 'Shedding & allergies', values: ['Light shedding for all that coat; a middle-ground option for allergy-conscious homes'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        A note on the ears: the erect "butterfly" ear is the famous one, but drop-eared Papillons exist too, called Phalène (moth), and can appear in the same litter. Same dog, same brain, different fold.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Papillon Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="Most shops make you WhatsApp them just to learn the number. Here's ours in writing: $4,088 to $6,088, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Papillon price commonly $3,000 to $6,000',
            'Rare locally; waitlists and import premiums common',
            'Price usually not published; enquiry required',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$4,088 to $6,088, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on our transparent puppy pricing page, and plan the ongoing costs with the first-year puppy budget guide.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Papillon Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Papillon leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, small-breed puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this breed the toys become training equipment on day one, and the oral care set matters because tiny jaws crowd teeth.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Papillon's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See the full 30+ item kit breakdown, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Papillon Right for Your Lifestyle?"
      subhead="We ask about your routine before recommending any breed. Here's the honest short version for a Papillon."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'You love training, games and dog sports', values: ['Ideal. The most trainable toy breed in existence, and it loves the work'] },
        { label: 'Adults or calm older children', values: ['Great fit. Playful, devoted, endlessly entertaining'] },
        { label: 'Working household committed to daily mental work', values: ['Workable. Feed the brain morning and evening and it copes well'] },
        { label: 'Home with boisterous toddlers', values: ['Reconsider. Fine bones at 2.5 to 4.5 kg; the sturdier Shih Tzu is the kinder match'] },
        { label: 'You want a quiet, decorative lapdog', values: ['Reconsider. The Papillon is a working mind in a pretty coat; the Pekingese fits that brief better'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Papillon is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my daily routine. Is a Papillon the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Papillon vs Toy Poodle: The Two Smartest Small Dogs" imagePosition="none" variant="dark">
    <p>These are the two cleverest dogs in the shop, so the choice comes down to coat and flavour. The Toy Poodle's curly coat barely sheds but demands a salon schedule; the Papillon's silky coat sheds lightly and needs almost no professional grooming. Temperament-wise the Poodle is a touch more biddable and settled; the Papillon is quicker, lighter on its feet, and more visibly sparkly.</p>
    <p>Allergy-sensitive homes should lean Poodle; grooming-budget-sensitive homes should lean Papillon. Either way you're getting a tiny dog that learns like a big one. With us the price, the starter kit, and the aftercare are identical.</p>
    <p>Weighing the two? See our <a href="/puppies/toy-poodle/" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Toy Poodle puppies</a>, or message us your routine and we'll tell you straight.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
      <ul class="mt-4 space-y-3">
        {[
          'Papillon: light shedding, no salon needed, sparkier',
          'Toy Poodle: lowest shedding, salon every 4 to 6 weeks',
          'Same price, same starter kit, same aftercare either way',
        ].map((fact) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fact}
          </li>
        ))}
      </ul>
    </div>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="hdb" class="scroll-mt-40">
    <DefBox
      term="Keeping a Papillon in an HDB flat"
      definition="The Papillon is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and at 2.5 to 4.5 kg the Papillon sits deep inside the small-breed rules. Every Papillon we place has its dog licensing completed at purchase, so the paperwork is handled for you."
      bridge="Is a Papillon HDB-approved? Yes, by name on the list. Just mind the one-dog-per-flat rule, and if you already have a dog, message us first so we can check your situation."
      citationLabel="Read HDB's guidelines on keeping pets"
      citationHref="https://www.hdb.gov.sg/managing-my-home/home-ownership/keeping-pets"
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">The rules in brief</p>
        <ul class="mt-4 space-y-3">
          {[
            'The Papillon is named on the HDB-approved breed list',
