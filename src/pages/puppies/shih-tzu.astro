---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Tabs from '../../components/Tabs.astro';
import DefBox from '../../components/DefBox.astro';
import StatStrip from '../../components/StatStrip.astro';
import ComparisonSplit from '../../components/ComparisonSplit.astro';
import CaptionedBlock from '../../components/CaptionedBlock.astro';
import ListingGrid from '../../components/ListingGrid.astro';
import BannerRibbon from '../../components/BannerRibbon.astro';
import FinalCta from '../../components/FinalCta.astro';
import Carousel from '../../components/Carousel.astro';
import FAQ from '../../components/FAQ.astro';
import Schema from '../../components/Schema.astro';
import ScatterFloat from '../../components/decor/ScatterFloat.astro';
import CloudDivider from '../../components/decor/CloudDivider.astro';
import PawTrail from '../../components/decor/PawTrail.astro';
import { site, whatsappLink } from '../../data/site';
import {
  localBusinessSchema,
  personSchema,
  webPageSchema,
  reviewSchema,
  faqPageSchema,
  itemListSchema,
  definedTermSchema,
  serviceSchema,
} from '../../lib/schema';
import starterKit from '../../assets/home/2-starter-kit-items-cavapoo-unboxing.webp';
import imgHero from '../../assets/shih-tzu/1-gold-and-white-shih-tzu-puppy-sitting-in-a-set-up-playp.webp';
import imgScene1 from '../../assets/shih-tzu/2-gold-and-white-shih-tzu-puppy-portrait-one-of-the-shih.webp';
import imgScene2 from '../../assets/shih-tzu/3-shih-tzu-puppy-relaxing-on-a-caregiver-s-lap-at-home.webp';
import imgScene3 from '../../assets/shih-tzu/4-shih-tzu-puppy-having-its-long-coat-brushed-and-face-ti.webp';
import imgScene4 from '../../assets/shih-tzu/5-shih-tzu-puppy-at-a-veterinary-health-check-before-goin.webp';
import imgScene5 from '../../assets/shih-tzu/6-shih-tzu-puppy-settling-into-a-set-up-playpen-during-it.webp';
import imgCard1 from '../../assets/shih-tzu/7-gold-and-white-male-shih-tzu-puppy-available-in-singapo.webp';
import imgCard2 from '../../assets/shih-tzu/8-black-and-white-female-shih-tzu-puppy-available-in-sing.webp';
import imgCard3 from '../../assets/shih-tzu/9-brindle-male-shih-tzu-puppy-available-in-singapore.webp';
import imgCard4 from '../../assets/shih-tzu/10-liver-and-white-female-shih-tzu-puppy-available-in-sing.webp';
import imgCard5 from '../../assets/shih-tzu/11-solid-gold-male-shih-tzu-puppy-available-in-singapore.webp';
import imgCard6 from '../../assets/shih-tzu/12-tri-colour-female-shih-tzu-puppy-available-in-singapore.webp';

const title = 'Shih Tzu Puppy for Sale Singapore | Curious Tails';
const description =
  'Shih Tzu puppies for sale in Singapore from $2,888, AVS licensed and HDB-approved. Real prices, temperament, coat care in our heat, and the $500+ starter kit included.';

const jumpLinks = [
  { label: 'Available', href: '#available' },
  { label: 'Price', href: '#price' },
  { label: 'Temperament', href: '#temperament' },
  { label: 'Size & Coat', href: '#size' },
  { label: 'HDB Rules', href: '#hdb' },
  { label: 'Grooming', href: '#grooming' },
  { label: 'Health', href: '#health' },
  { label: 'FAQ', href: '#faq' },
];

const faqItems = [
  {
    question: 'How much does a Shih Tzu cost in Singapore?',
    answer:
      'Shih Tzu prices in Singapore commonly run from around $2,000 to $5,000 depending on colour, markings and shop. At Curious Tails, Shih Tzu puppies are $2,888 to $4,488, and that price already includes the $500+ starter kit, free home delivery and setup, and a free first training lesson with an AVS-certified trainer.',
  },
  {
    question: 'Is a Shih Tzu HDB-approved?',
    answer:
      'Yes. The Shih Tzu is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and we complete the dog licensing for you at purchase, so the paperwork is handled.',
  },
  {
    question: 'Can a Shih Tzu be left alone while we are at work?',
    answer:
      'Better than most companion breeds, honestly. The Shih Tzu was bred to be a calm palace lapdog, not a working dog, and that history shows: given a safe playpen, a settled routine, and a cool room, most Shih Tzus treat a quiet weekday as one long nap. Keep evenings and weekends warm and people-filled and the breed is content.',
  },
  {
    question: 'Do Shih Tzus shed? Are they good for allergies?',
    answer:
      'The Shih Tzu is one of the classic low-shedding breeds: its long coat behaves more like hair than fur, dropping very little. That makes it a strong pick for allergy-sensitive homes, alongside the Maltese and the Poodle crosses. No dog is truly allergen-free, so spend time with one at our Balestier shop first if allergies are severe.',
  },
  {
    question: 'Are Shih Tzus good with children?',
    answer:
      'One of the best small breeds for families, yes. At 4 to 7.5 kg the Shih Tzu is sturdier than the true toy breeds, and its temperament is famously tolerant and affectionate. As with any puppy, supervise young children and teach gentle handling; the free first training lesson covers how to set those habits.',
  },
  {
    question: 'How do Shih Tzus cope with Singapore heat?',
    answer:
      'This is the one thing to manage. The Shih Tzu is a flat-faced (brachycephalic) breed, so it cools itself less efficiently: walk in the early morning or evening, never at midday, keep water available always, and let it live in your cooler rooms. Managed that way, Shih Tzus have thrived in Singapore for generations; ignored, heat is a genuine danger.',
  },
  {
    question: 'What happens after I reserve a Shih Tzu?',
    answer:
      "You place a deposit, and we board your puppy for free, food and lodging covered, until you're ready. Delivery is scheduled around your availability, and we set up the playpen and walk you through all 30+ starter-kit items before we leave.",
  },
];

const schemas = [
  localBusinessSchema(),
  personSchema(),
  webPageSchema({
    path: '/puppies/shih-tzu',
    title,
    description,
    aboutName: 'Shih Tzu',
    aboutAlternateName: 'Shih Tzu dog',
    aboutSameAs: 'https://en.wikipedia.org/wiki/Shih_Tzu',
    datePublished: '2026-07-09',
    dateModified: new Date().toISOString().split('T')[0],
  }),
  itemListSchema([
    {
      name: 'Shih Tzu puppy',
      url: '/puppies/shih-tzu',
      description:
        'Shih Tzu puppy from an AVS licensed Singapore pet shop, priced $2,888 to $4,488 with a $500+ starter kit, free home delivery and setup, and a free AVS-certified training lesson included.',
      price: '2888',
    },
  ]),
  serviceSchema({
    name: 'Shih Tzu Home Delivery & Playpen Setup',
    description: "Free island-wide home delivery with playpen, bed, and toy setup for every Shih Tzu puppy, scheduled around the owner's availability.",
    price: 'Included',
  }),
  reviewSchema({
    author: 'Andrew Mak',
    reviewBody:
      "Couldn't recommend Curious Tails in Balestier enough after bringing home our puppy. Nelson and Kim gave us a clear care routine to follow, and clearly loves what they do. We loved the aftercare support; you can tell they truly care about the pups and the owners. Will absolutely return and recommend without hesitation.",
    ratingValue: 5,
    datePublished: '2024-07-01',
  }),
  faqPageSchema(faqItems),
  definedTermSchema({
    name: 'Shih Tzu',
    description:
      'The Shih Tzu is a small companion breed of roughly 4 to 7.5 kg, bred for centuries as a palace lapdog, with a long low-shedding coat and a famously affectionate, tolerant temperament. Lifespan is typically 12 to 16 years.',
    sameAs: 'https://en.wikipedia.org/wiki/Shih_Tzu',
  }),
];
---

<BaseLayout {title} {description} canonicalPath="/puppies/shih-tzu">
  <Hero
    eyebrow="AVS Licensed Pet Shop in Balestier"
    h1="Shih Tzu Puppies for Sale in Singapore"
    h1Accent="Shih Tzu"
    subhead="Shih Tzu prices in Singapore commonly run $2,000 to $5,000. Ours are $2,888 to $4,488, with the $500+ starter kit, free home delivery and setup, and a free first training lesson already in the price."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! I'd like to ask about your available Shih Tzu puppies."
    secondaryCtaLabel="See price & what's included"
    secondaryCtaHref="#price"
    priceAnchor="From $2,888 all-in. HDB-approved. No add-ons quietly billed later."
    rating={site.reviews.rating}
    reviewCount={site.reviews.count}
    trustBadges={[`AVS licensed · ${site.license.avsNumber}`, `${site.reviews.count} five-star reviews`, 'HDB-approved companion breed']}
    imageAlt="Gold and white Shih Tzu puppy sitting in a set-up playpen at a Balestier home" imageSrc={imgHero}
    tagLabel="Shih Tzu"
    proofChip="5.0 on Google"
  >
    <Breadcrumb slot="breadcrumb" bare items={[{ label: 'Puppies', href: '/puppies' }, { label: 'Shih Tzu', href: '/puppies/shih-tzu' }]} />
  </Hero>

  <Tabs items={jumpLinks} />

  <div id="available" class="scroll-mt-40">
    <CaptionedBlock heading="Looking to Buy a Shih Tzu in Singapore?" imageAlt="Gold and white Shih Tzu puppy portrait, one of the Shih Tzu puppies available in Singapore" imageSrc={imgScene1} variant="mid">
      <p>Our Shih Tzu puppies in Singapore arrive and are reserved quickly, so we keep availability live on WhatsApp rather than on a page that goes stale. As an AVS licensed pet shop in Singapore, we'll send you photos, gender, age, colour, and exact prices for the Shih Tzu puppies available now.</p>
      <p>Unlike most listings you'll compare us against, we tell you the number upfront: every Shih Tzu for sale in Singapore here is between $2,888 and $4,488, and what you see is the full price. Book a puppy viewing appointment at our Balestier shop to meet them in person, or after you reserve with a deposit we board your puppy for free, food and lodging covered, until your home is ready.</p>
      <p>
        <a href={whatsappLink("Hi! Could you send me photos and prices of your available Shih Tzu puppies?")} class="underline underline-offset-2 text-[var(--color-accent-hover)]">Ask for current Shih Tzu photos and prices</a>, or meet our Shih Tzu puppies at our Balestier pet shop in person, with free home delivery in Singapore once you reserve.
      </p>
    </CaptionedBlock>

    <ListingGrid
      heading="Available Shih Tzu Puppies"
      headingAccent="Available"
      subhead="A few of the Shih Tzu puppies looking for a home right now. Litters move fast, so tap any pup to WhatsApp us for its latest photos, video, and full price, or to arrange a viewing at our Balestier shop."
      items={[
        { title: 'Gold & white boy', href: whatsappLink('Hi! I\'d like more photos and the price for the gold and white male Shih Tzu puppy.'), imageAlt: 'Gold and white male Shih Tzu puppy available in Singapore', imageSrc: imgCard1, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Black & white girl', href: whatsappLink('Hi! I\'d like more photos and the price for the black and white female Shih Tzu puppy.'), imageAlt: 'Black and white female Shih Tzu puppy available in Singapore', imageSrc: imgCard2, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '10 weeks' },
        { title: 'Brindle boy', href: whatsappLink('Hi! I\'d like more photos and the price for the brindle male Shih Tzu puppy.'), imageAlt: 'Brindle male Shih Tzu puppy available in Singapore', imageSrc: imgCard3, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '3 months' },
        { title: 'Liver & white girl', href: whatsappLink('Hi! I\'d like more photos and the price for the liver and white female Shih Tzu puppy.'), imageAlt: 'Liver and white female Shih Tzu puppy available in Singapore', imageSrc: imgCard4, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '9 weeks' },
        { title: 'Solid gold boy', href: whatsappLink('Hi! I\'d like more photos and the price for the solid gold male Shih Tzu puppy.'), imageAlt: 'Solid gold male Shih Tzu puppy available in Singapore', imageSrc: imgCard5, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Male', age: '2 months' },
        { title: 'Tri-colour girl', href: whatsappLink('Hi! I\'d like more photos and the price for the tri-colour female Shih Tzu puppy.'), imageAlt: 'Tri-colour female Shih Tzu puppy available in Singapore', imageSrc: imgCard6, meta: 'WhatsApp for photos & price', tag: 'Available', gender: 'Female', age: '12 weeks' },
      ]}
    />
  </div>

  <div class="relative">
    <ScatterFloat />
    <DefBox
      term="What is a Shih Tzu?"
      definition="The Shih Tzu is a small companion breed of roughly 4 to 7.5 kg, bred for centuries in Chinese palaces to do exactly one job: be excellent company. It carries a long, low-shedding coat, a short muzzle, and one of the most tolerant, affectionate temperaments in the small-dog world, with a lifespan of 12 to 16 years."
      bridge="Curious Tails is an AVS licensed pet shop at 2 Balestier Road. We match by lifestyle first, and the Shih Tzu is one of our easiest recommendations: sturdy enough for families, calm enough for seniors, low-shedding, and HDB-approved."
      citationLabel="Verify our licence on the AVS public registry"
      citationHref={site.license.registryUrl}
    >
      <div slot="side" class="clay h-full bg-[var(--color-lilac-900)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Shih Tzu at a glance</p>
        <ul class="mt-4 space-y-3">
          {[
            'Bred as a palace lapdog; company is the job',
            'Roughly 4 to 7.5 kg fully grown',
            'Long, low-shedding, hair-like coat',
            'Famously tolerant with children',
            '12 to 16 year lifespan',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-white/50">Sizes vary by line; ask us about a specific puppy's expected adult weight.</p>
      </div>
    </DefBox>
  </div>

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <StatStrip
    heading="Why Singapore families get their Shih Tzu from Curious Tails"
    stats={[
      { value: String(site.reviews.count), label: 'five-star Google reviews' },
      { value: '$2,888', label: 'Shih Tzu pricing starts here, all-in' },
      { value: '$500+', label: 'starter kit included free' },
      { value: '2+', label: 'years in Balestier' },
    ]}
  />
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="temperament" class="scroll-mt-40">
    <CaptionedBlock heading="Shih Tzu Temperament: A Thousand Years of Being Good Company" imageAlt="Shih Tzu puppy relaxing on a caregiver's lap at home" imageSrc={imgScene2} imagePosition="left">
      <p>Some breeds were shaped to herd, hunt or guard, and keep those instincts in a flat. The Shih Tzu was shaped for centuries to sit with people and be pleasant about it, and that history is exactly what you live with: an affectionate, even-tempered, slightly comic companion that likes everyone it meets and holds no strong opinions about squirrels.</p>
      <p>The honest part, from two years of matching puppies to families: the Shih Tzu's one training quirk is a gentle stubborn streak. It isn't defiance; it's a lapdog's honest confusion about why anyone would do anything on command. Short, cheerful, treat-led sessions work; drill-sergeant repetition doesn't. Toilet training in particular takes a few weeks longer than a Poodle cross, and knowing that upfront saves frustration.</p>
      <p>With children the Shih Tzu is one of our safest picks: sturdier than the true toys and famously tolerant. If you want the same family fit with faster trainability, compare the <a href="/puppies/cockapoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cockapoo</a>.</p>
    </CaptionedBlock>

    <CaptionedBlock heading="Can a Shih Tzu Be Left Alone During Work Hours?" imagePosition="none" variant="card">
      <p>Better than most companion breeds. A Shih Tzu's idea of a good Tuesday is a long nap in a cool room with water nearby, which happens to describe a working household's weekday perfectly. With a safe playpen and a settled routine, most Shih Tzus handle 8am to 6pm calmly once matured into it.</p>
      <p>The condition is temperature, not company: the room it stays in must stay cool and ventilated, because this flat-faced breed does not sweat out a Singapore afternoon the way other dogs do. Fan or aircon, shaded from the west sun, water always topped up.</p>
      <div slot="side" class="clay h-full bg-[var(--color-peach-100)] p-6 sm:p-8">
        <p class="text-xs font-bold uppercase text-[var(--color-cream-500)]" style="letter-spacing: 0.08em;">Good fit if</p>
        <ul class="mt-4 space-y-3">
          {[
            'Family with children, or a quieter senior home',
            'You want low-shedding without high energy',
            'Working household with a cool room for the day',
          ].map((fact) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-[var(--color-cream-700)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-coral-500)]" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      </div>
    </CaptionedBlock>
  </div>

  <div id="size" class="scroll-mt-40">
    <ComparisonSplit
      heading="Shih Tzu Size, Coat and Lifespan"
      headingAccent="Size"
      subhead="Honest numbers for the breed that invented the lap."
      mode="table"
      tableHeaders={['Trait', 'What to expect']}
      rows={[
        { label: 'Adult weight', values: ['Roughly 4 to 7.5 kg; sturdier than the true toy breeds'] },
        { label: 'Height', values: ['Around 20 to 28 cm at the shoulder'] },
        { label: 'Coat', values: ['Long, dense, hair-like and low-shedding; gold, black, liver, brindle and white combinations'] },
        { label: 'Lifespan', values: ['12 to 16 years with good care'] },
        { label: 'Exercise', values: ['About 20 to 30 minutes of gentle walking a day, in the cool hours, plus indoor play'] },
        { label: 'Shedding & allergies', values: ['Very low-shedding; one of the classic picks for allergy-sensitive homes'] },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        The 4 to 7.5 kg range makes the Shih Tzu a sweet spot: small enough for any flat, sturdy enough for family life. If you're comparing low-shedding companions by size, the <a href="/puppies/maltese" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Maltese</a> is the daintier option and the <a href="/puppies/cavapoo" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Cavapoo</a> the livelier one.
      </p>
    </div>
  </div>

  <div id="price" class="scroll-mt-40">
    <ComparisonSplit
      heading="Shih Tzu Price in Singapore: What You'll Pay and What's Included"
      headingAccent="Price"
      subhead="Most shops make you WhatsApp them just to learn the number. Here's ours in writing: $2,888 to $4,488, all-in."
      mode="split"
      columns={[
        {
          heading: 'Typical Singapore market',
          items: [
            'Shih Tzu price commonly $2,000 to $5,000',
            'Price usually not published; enquiry required',
            'Rare colours and markings priced at a premium',
            'Starter supplies, training and delivery charged separately',
          ],
        },
        {
          heading: 'Curious Tails',
          items: [
            '$2,888 to $4,488, printed right here',
            '$500+ starter kit with 30+ items included',
            'Free home delivery with the playpen set up before you arrive',
            'Free first lesson with an AVS-certified trainer, plus free boarding after deposit',
          ],
          emphasis: true,
        },
      ]}
    />
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 -mt-6 pb-10">
      <p class="text-sm leading-relaxed text-[var(--color-cream-600)]">
        Why is our price printed? We don't carry the marketing spend the bigger names do, and we'd rather win on value and word of mouth. Compare the full picture on <a href="/pricing" class="underline underline-offset-2 text-[var(--color-accent-hover)]">our transparent puppy pricing page</a>, and plan the ongoing costs with the <a href="/first-time-owners/budget-guide" class="underline underline-offset-2 text-[var(--color-accent-hover)]">first-year puppy budget guide</a>.
      </p>
    </div>
  </div>

  <CloudDivider fillClass="fill-[var(--color-mint-100)]" />
  <CaptionedBlock heading="The $500+ Starter Kit Every Shih Tzu Goes Home With" imageAlt="Puppy starter kit with playpen, carrier, grooming tools, food and toys laid out" imageSrc={starterKit} variant="mid">
    <p>Every Shih Tzu leaves us with a starter kit worth $500 and up: more than 30 items across eight categories, a playpen, a carrier, grooming tools, small-breed puppy food, outdoor gear, toilet training supplies, oral health care, and toys. For this breed the grooming tools and the eye and face wipes earn their keep daily, and the oral care items matter because short-muzzled jaws crowd teeth.</p>
    <p>On delivery day, Nelson or Kim walks you through every item: how to use it, and how it fits into your Shih Tzu's daily care. Most of the questions new owners would otherwise ask later are answered before we leave your home.</p>
    <p>See <a href="/starter-kit" class="underline underline-offset-2 text-[var(--color-accent-hover)]">the full 30+ item kit breakdown</a>, category by category.</p>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-mint-100)]" flip />

  <div id="match" class="relative">
    <ScatterFloat />
    <ComparisonSplit
      heading="Is a Shih Tzu Right for Your Lifestyle?"
      subhead="We ask about your routine before recommending any breed. Here's the honest short version for a Shih Tzu."
      mode="table"
      tableHeaders={['Your situation', 'Our honest take']}
      rows={[
        { label: 'Family with young children', values: ['Great fit. Sturdy for its size and famously tolerant; one of our first recommendations for families'] },
        { label: 'Senior or quieter household', values: ['Ideal. Modest exercise needs and a calm, affectionate default setting'] },
        { label: 'Working household with a cool room', values: ['Good fit. Handles alone time better than most companions; temperature is the real requirement'] },
        { label: 'Allergy-sensitive household', values: ['Great fit. One of the classic low-shedding breeds'] },
        { label: 'You want a jogging or hiking partner', values: ['Reconsider. Flat-faced breeds and endurance exercise don\'t mix, especially in our heat; look at the Corgi if you have private housing'] },
      ]}
    />
  </div>

  <BannerRibbon
    heading="Not sure the Shih Tzu is your match?"
    body="We'd rather talk you out of the wrong breed than sell you the wrong dog. Message us your daily routine and we'll tell you straight."
    ctaLabel="WhatsApp us"
    ctaMessage="Hi! Here's my daily routine. Is a Shih Tzu the right fit for us?"
    variant="dark"
  />

  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" />
  <CaptionedBlock heading="Shih Tzu vs Maltese: Which Low-Shedding Classic?" imagePosition="none" variant="dark">
    <p>The two old-money companion breeds, both low-shedding, both HDB-approved, both bred for laps. The honest differences: the Shih Tzu is sturdier at 4 to 7.5 kg and more tolerant of family chaos; the Maltese is daintier at 2 to 4 kg, silkier-coated, and leans harder on having its people around. Grooming effort is similar; both live in a puppy cut happily.</p>
    <p>Pick the Shih Tzu for a family with kids or a home that's empty on weekdays; pick the Maltese for a lighter lap dog in a home with more daytime company. With us the price, the starter kit, and the aftercare are identical either way.</p>
    <p>Weighing the two? See our <a href="/puppies/maltese" class="underline underline-offset-2 text-[var(--color-accent-hover)]">Maltese puppies</a>, or message us your routine and we'll tell you straight.</p>
    <div slot="side" class="clay h-full bg-white/10 p-6 sm:p-8">
      <p class="text-xs font-bold uppercase text-white/60" style="letter-spacing: 0.08em;">Quick comparison</p>
      <ul class="mt-4 space-y-3">
        {[
          'Shih Tzu: 4 to 7.5 kg, sturdier, better alone-time tolerance',
          'Maltese: 2 to 4 kg, daintier, wants more daytime company',
          'Same price, same starter kit, same aftercare either way',
        ].map((fact) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-white/85">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[var(--color-mint-300)]" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fact}
          </li>
        ))}
      </ul>
    </div>
  </CaptionedBlock>
  <CloudDivider fillClass="fill-[var(--color-lilac-900)]" flip />

  <div id="hdb" class="scroll-mt-40">
    <DefBox
      term="Keeping a Shih Tzu in an HDB flat"
      definition="The Shih Tzu is named on the HDB-approved breed list, so you can keep one in an HDB flat. HDB allows one dog of an approved breed per flat, and the Shih Tzu's calm indoor manner makes it one of the easiest approved breeds to live with in one. Every Shih Tzu we place has its dog licensing completed at purchase, so the paperwork is handled for you."
      bridge="Is a Shih Tzu HDB-approved? Yes, by name on the list, and it has been an HDB favourite for decades. Just mind the one-dog-per-flat rule, and if you already have a dog, message us first so we can check your situation."
